<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agent Control Center</title>
    <script src="/static/marked.min.js"></script>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body class="min-h-screen bg-slate-900 text-slate-100 leading-normal font-sans">
    <div class="sticky top-0 z-[100] flex items-center justify-between border-b border-slate-700 bg-gradient-to-br from-slate-800 to-slate-900 px-8 py-5">
        <div>
            <h1 class="bg-gradient-to-r from-blue-400 to-violet-400 bg-clip-text text-2xl font-bold text-transparent">🤖 Agent Control Center</h1>
            <p class="mt-1 text-sm text-slate-400">一键评审 PLAN 并触发开发 - 支持断点续传</p>
        </div>
        <div class="flex items-center gap-3">
            <select id="" class="cursor-pointer rounded-[10px] border border-slate-700 bg-slate-800 px-[0.9rem] py-[0.45rem] text-[0.9375rem] text-slate-100 outline-none transition-all duration-200 hover:border-slate-600 focus:border-blue-500">
                <option>加载中...</option>
            </select>
            <button class="flex h-10 w-10 items-center justify-center rounded-[10px] border border-slate-700 bg-slate-800 text-lg text-slate-100 transition-all duration-200 hover:rotate-180 hover:bg-slate-700" onclick="loadAll()" title="刷新">🔄</button>
        </div>
    </div>

    <div class="mx-auto grid max-w-[1600px] grid-cols-4 gap-4 px-8 py-6 max-[900px]:grid-cols-2">
        <div class="flex items-center gap-4 rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]">
            <div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-emerald-500/15 text-xl">🚀</div>
            <div>
                <div class="text-2xl font-bold" id="">0</div>
                <div class="text-sm text-slate-400">运行中任务</div>
            </div>
        </div>
        <div class="flex items-center gap-4 rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]">
            <div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-blue-500/15 text-xl">🔍</div>
            <div>
                <div class="text-2xl font-bold" id="stat-review">0</div>
                <div class="text-sm text-slate-400">待 Review PR</div>
            </div>
        </div>
        <div class="flex items-center gap-4 rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]">
            <div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-violet-500/15 text-xl">🎉</div>
            <div>
                <div class="text-2xl font-bold" id="stat-merged">0</div>
                <div class="text-sm text-slate-400">最近合并</div>
            </div>
        </div>
        <div class="flex items-center gap-4 rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]">
            <div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-orange-500/15 text-xl">📋</div>
            <div>
                <div class="text-2xl font-bold" id="">0</div>
                <div class="text-sm text-slate-400">待处理 Issue</div>
            </div>
        </div>
    </div>

    <div class="mx-auto max-w-[1600px] px-8 pb-8">
        <div class="mb-6 flex gap-2 overflow-x-auto border-b border-slate-700">
            <button class="tab active group flex cursor-pointer items-center gap-2 whitespace-nowrap border-b-2 border-blue-500 bg-none px-5 py-3 text-[0.9375rem] font-medium text-blue-500 hover:text-slate-100" onclick="switchTab('tab-tasks')" id="tab-btn-tasks">
                🚀 任务 <span class="rounded-full bg-slate-700 px-2 py-0.5 text-xs font-semibold text-slate-400 group-[.active]:bg-blue-500/20 group-[.active]:text-blue-300" id="">0</span>
            </button>
            <button class="tab group flex cursor-pointer items-center gap-2 whitespace-nowrap border-b-2 border-transparent bg-none px-5 py-3 text-[0.9375rem] font-medium text-slate-400 hover:text-slate-100" onclick="switchTab('tab-prs')" id="tab-btn-prs">
                🔍 Pull Requests <span class="rounded-full bg-slate-700 px-2 py-0.5 text-xs font-semibold text-slate-400 group-[.active]:bg-blue-500/20 group-[.active]:text-blue-300" id="">0</span>
            </button>
            <button class="tab group flex cursor-pointer items-center gap-2 whitespace-nowrap border-b-2 border-transparent bg-none px-5 py-3 text-[0.9375rem] font-medium text-slate-400 hover:text-slate-100" onclick="switchTab('tab-issues')" id="tab-btn-issues">
                📋 Issues <span class="rounded-full bg-slate-700 px-2 py-0.5 text-xs font-semibold text-slate-400 group-[.active]:bg-blue-500/20 group-[.active]:text-blue-300" id="">0</span>
            </button>
            <button class="tab group flex cursor-pointer items-center gap-2 whitespace-nowrap border-b-2 border-transparent bg-none px-5 py-3 text-[0.9375rem] font-medium text-slate-400 hover:text-slate-100" onclick="switchTab('tab-logs')" id="tab-btn-logs">
                📄 日志
            </button>
        </div>

        <div id="tab-tasks" class="tab-panel hidden active">
            <div class="grid grid-cols-2 gap-6 max-[1100px]:grid-cols-1">
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">🟢 正在运行</div>
                    <div id="running-tasks" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无运行中的任务</div></div>
                    <div class="my-6 h-px bg-slate-700"></div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">📚 文档检查中</div>
                    <div id="doc-gardener-tasks" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无文档检查任务</div></div>
                    <div class="my-6 h-px bg-slate-700"></div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">⚠️ 可恢复任务</div>
                    <div id="interrupted-tasks" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无中断的任务</div></div>
                </div>
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">📄 最近日志</div>
                    <div id="recent-logs" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无日志</div></div>
                </div>
            </div>
        </div>

        <div id="tab-prs" class="tab-panel hidden">
            <div class="grid grid-cols-2 gap-6 max-[1100px]:grid-cols-1">
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">🔍 等待 Review</div>
                    <div id="pending-prs" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无等待 Review 的 PR</div></div>
                </div>
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">🎉 最近合并 <span class="rounded-full bg-slate-700 px-2 py-0.5 text-xs font-semibold text-slate-400" id="merged-pr-count">0</span></div>
                    <div id="merged-prs" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">暂无最近合并的 PR</div></div>
                </div>
            </div>
        </div>

        <div id="tab-issues" class="tab-panel hidden">
            <div class="mb-4 flex justify-end">
                <button class="primary cursor-pointer rounded-lg border border-slate-700 bg-slate-800/80 px-3.5 py-1.5 text-sm font-medium text-slate-200 transition-all duration-150" onclick="openPMModal()">✨ 新建需求</button>
            </div>
            <div class="grid grid-cols-2 gap-6 max-[1100px]:grid-cols-1">
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">📋 待评审 PLAN</div>
                    <div id="plan-issues" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">加载中...</div></div>
                    <div class="my-6 h-px bg-slate-700"></div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">🟡 PRD 就绪</div>
                    <div id="prd-issues" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">加载中...</div></div>
                </div>
                <div>
                    <div class="mb-4 flex items-center gap-2 text-lg font-semibold">🔍 待分类</div>
                    <div id="triage-issues" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">加载中...</div></div>
                </div>
            </div>
        </div>

        <div id="tab-logs" class="tab-panel hidden">
            <div class="mb-4 flex items-center gap-2 text-lg font-semibold">📄 全部日志</div>
            <div id="all-logs" class="flex flex-col gap-3"><div class="px-4 py-12 text-center text-sm text-slate-400">加载中...</div></div>
        </div>
    </div>

    <div id="" class="fixed bottom-6 right-6 z-[2000] hidden rounded-[10px] bg-emerald-500 px-5 py-3.5 font-medium text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]"></div>

    <div id="" class="fixed inset-0 z-[3000] hidden flex-col items-center justify-center gap-4 bg-slate-900/70 backdrop-blur-sm">
        <div class="h-12 w-12 animate-spin rounded-full border-4 border-blue-500/20 border-t-blue-500"></div>
        <div class="loading-text text-base font-medium text-slate-100">执行中...</div>
    </div>

    <!-- Terminal -->
    <div id="" class="fixed inset-0 z-[1500] hidden items-center justify-center bg-slate-900/85 p-4 backdrop-blur-sm">
        <div class="flex h-[85vh] w-full max-w-[1200px] flex-col overflow-hidden rounded-xl border border-slate-700 bg-[#020617] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)]">
            <div class="flex items-center justify-between border-b border-slate-700 bg-slate-800 px-4 py-3.5">
                <div class="flex items-center gap-3 font-medium">
                    <div class="flex gap-1.5">
                        <span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
                        <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
                        <span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
                    </div>
                    <span id="terminal-filename">tail -f dev-issue-xxx.log</span>
                </div>
                <div class="flex gap-2">
                    <button id="-btn" class="cursor-pointer rounded-md border border-blue-500 bg-blue-500 px-2.5 py-1 text-xs text-white hover:bg-slate-700 hover:text-slate-100" onclick="toggleRenderMode()" title="切换原始/渲染视图">渲染</button>
                    <button class="cursor-pointer rounded-md border border-slate-700 bg-transparent px-2.5 py-1 text-xs text-slate-400 hover:bg-slate-700 hover:text-slate-100" onclick="clearTerminal()" title="清屏">清屏</button>
                    <button class="cursor-pointer rounded-md border border-slate-700 bg-transparent px-2.5 py-1 text-xs text-slate-400 hover:bg-slate-700 hover:text-slate-100" onclick="closeTerminal()" title="关闭 (ESC)">✕</button>
                </div>
            </div>
            <div id="" class="flex-1 overflow-y-auto p-4 font-mono text-[0.8125rem] leading-relaxed text-slate-200"></div>
            <div class="flex items-center justify-between border-t border-slate-700 bg-slate-800 px-4 py-2.5 text-[0.8125rem] text-slate-400">
                <span id="" class="inline-flex items-center gap-2">
                    <span class="inline-flex items-center gap-1.5 text-emerald-500 after:content-[''] after:inline-block after:h-1.5 after:w-1.5 after:rounded-full after:bg-emerald-500 after:animate-[blink_1.2s_infinite]">LIVE</span>
                    <span id="line-count">0 lines</span>
                </span>
                <span id="terminal-info">按 ESC 关闭 | 自动跟随</span>
            </div>
            <button class="absolute bottom-14 right-6 z-10 hidden h-9 w-9 items-center justify-center rounded-full border border-slate-700 bg-slate-800 text-base text-slate-100 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]" id="" onclick="scrollToBottom()" title="滚动到底部">↓</button>
        </div>
    </div>

    <script>
        let eventSource = null;
        let lineCount = 0;
        let isAutoScroll = true;
        let currentLogFile = null;
        let runningTasksData = [];
        let allLogsData = [];
        let designAssetsCache = {}; // issueNumber -> assets[]
        let renderMode = 'rendered'; // 'rendered' | 'raw'
        let rawLogLines = []; // 保留原始行用于切换回原始视图

        const terminalBody = document.getElementById('');
        const terminalOverlay = document.getElementById('');

        terminalBody.addEventListener('scroll', () => {
            const { scrollTop, scrollHeight, clientHeight } = terminalBody;
            const atBottom = scrollHeight - scrollTop - clientHeight < 50;
            isAutoScroll = atBottom;
            document.getElementById('').classList.toggle('flex', !atBottom);
        });

        function scrollToBottom() {
            terminalBody.scrollTop = terminalBody.scrollHeight;
            isAutoScroll = true;
        }

        function showToast(message, isError = false) {
            const  = document.getElementById('');
            .textContent = message;
            .classList.remove('hidden', 'bg-red-500');
            .classList.add('block');
            .style.animation = 'slideIn 0.25s ease';
            if (isError) {
                .classList.remove('bg-emerald-500');
                .classList.add('bg-red-500');
            } else {
                .classList.remove('bg-red-500');
                .classList.add('bg-emerald-500');
            }
            setTimeout(() => {
                .classList.remove('block', 'bg-red-500');
                .style.animation = '';
                .classList.add('hidden', 'bg-emerald-500');
            }, 3000);
        }

        let globalLoadingCount = 0;
        function showGlobalLoading(text) {
            const el = document.getElementById('');
            if (el) {
                el.querySelector('.loading-text').textContent = text || '执行中...';
                el.classList.remove('hidden');
                el.classList.add('flex');
            }
            globalLoadingCount++;
        }
        function hideGlobalLoading() {
            globalLoadingCount = Math.max(0, globalLoadingCount - 1);
            if (globalLoadingCount === 0) {
                const el = document.getElementById('');
                if (el) {
                    el.classList.remove('flex');
                    el.classList.add('hidden');
                }
            }
        }

        function setButtonLoading(btn, loading) {
            if (!btn) return;
            if (loading) {
                btn.disabled = true;
                btn.classList.add('loading');
                btn.dataset.originalText = btn.textContent;
            } else {
                btn.disabled = false;
                btn.classList.remove('loading');
            }
        }

        async function loadProjects() {
            try {
                const response = await fetch('/api/projects');
                const data = await response.json();
                currentProject = data.currentProject;
                const select = document.getElementById('');
                select.innerHTML = '';
                data.projects.forEach((p, idx) => {
                    const opt = document.createElement('option');
                    opt.value = p.name;
                    opt.textContent = p.name;
                    if (idx === data.currentIndex) opt.selected = true;
                    select.appendChild(opt);
                });
                select.onchange = async (e) => {
                    const name = e.target.value;
                    setButtonLoading(select, true);
                    try {
                        const res = await fetch('/api/switch-project', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ projectName: name })
                        });
                        const result = await res.json();
                        if (!res.ok) throw new Error(result.error || 'Switch failed');
                        showToast(result.message);
                        currentProject = data.projects.find(p => p.name === name);
                        await loadAll();
                    } catch (err) {
                        showToast(err.message, true);
                    } finally {
                        setButtonLoading(select, false);
                    }
                };
                return data;
            } catch (error) {
                console.error('Error loading projects:', error);
                return { projects: [], currentProject: null };
            }
        }

        function formatDuration(ms) {
            const seconds = Math.floor(ms / 1000);
            const minutes = Math.floor(seconds / 60);
            const hours = Math.floor(minutes / 60);
            if (hours > 0) return hours + 'h ' + (minutes % 60) + 'm';
            if (minutes > 0) return minutes + 'm ' + (seconds % 60) + 's';
            return seconds + 's';
        }

        async function loadAll() {
            const btn = document.querySelector('.btn-icon');
            if (btn) btn.classList.add('spinning', 'animate-spin');
            
            await Promise.all([
                loadRunningTasks(),
                loadReviewTasks(),
                loadDocGardenerTasks(),
                loadIssues(),
                loadRecentLogs(),
                loadPullRequests(),
                loadMergedPRs()
            ]);
            updateStats();
            
            if (btn) btn.classList.remove('spinning', 'animate-spin');
        }

        async function loadTasks() {
            await Promise.all([
                loadRunningTasks(),
                loadReviewTasks(),
                loadDocGardenerTasks(),
                loadRecentLogs()
            ]);
            updateStats();
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab').forEach(t => {
                t.classList.remove('active', 'text-blue-500', 'border-blue-500');
            });
            document.querySelectorAll('.tab-panel').forEach(p => {
                p.classList.remove('active', 'block');
                p.classList.add('hidden');
            });
            document.getElementById('tab-btn-' + tabId.replace('tab-', '')).classList.add('active', 'text-blue-500', 'border-blue-500');
            const panel = document.getElementById(tabId);
            if (panel) {
                panel.classList.remove('hidden');
                panel.classList.add('block', 'active');
            }
        }

        function updateStats() {
            if (!runningTasksData) runningTasksData = [];
            if (!pullRequestsData) pullRequestsData = [];
            if (!issuesData) issuesData = [];
            const running = runningTasksData.filter(t => t.status === 'running').length;
            const interrupted = runningTasksData.filter(t => t.status === 'interrupted').length;
            const pendingPR = pullRequestsData.length;
            const totalIssues = issuesData.length;
            
            document.getElementById('').textContent = running;
            document.getElementById('stat-review').textContent = pendingPR;
            document.getElementById('stat-merged').textContent = document.getElementById('merged-pr-count')?.textContent || 0;
            document.getElementById('').textContent = totalIssues;
            
            document.getElementById('').textContent = running + interrupted;
            document.getElementById('').textContent = pendingPR;
            document.getElementById('').textContent = totalIssues;
        }

        async function loadIssues() {
            try {
                const response = await fetch('/api/issues');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                const issues = await response.json();
                issuesData = issues;
                
                // 并行预加载设计资产，确保 issue 列表初始渲染时按钮已就位
                const uniqueIssues = [...new Set(issues.map(i => i.number))];
                await Promise.all(uniqueIssues.map(n => {
                    if (designAssetsCache[n] === undefined) {
                        return loadDesignAssets(n);
                    }
                    return Promise.resolve();
                }));
                
                const plans = issues.filter(i => i.labels.some(l => l.name === 'plan-ready')).sort((a, b) => b.number - a.number);
                const prds = issues.filter(i => i.labels.some(l => l.name === 'prd-ready')).sort((a, b) => b.number - a.number);
                const triages = issues.filter(i => !i.labels.some(l => l.name === 'plan-ready' || l.name === 'prd-ready')).sort((a, b) => b.number - a.number);
                
                renderIssues('plan-issues', plans, 'plan-ready');
                renderIssues('prd-issues', prds, 'prd-ready');
                renderIssues('triage-issues', triages, 'triage');
            } catch (error) {
                console.error('Error:', error);
                showToast('加载失败: ' + error.message, true);
            }
        }

        async function loadRunningTasks() {
            try {
                const response = await fetch('/api/running-tasks');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                runningTasksData = await response.json();
                runningTasksData.sort((a, b) => new Date(b.startTime || 0) - new Date(a.startTime || 0));
                renderRunningTasks();
                await renderInterruptedTasks();
            } catch (error) {
                console.error('Error loading running tasks:', error);
            }
        }

        async function loadRecentLogs() {
            try {
                const response = await fetch('/api/logs');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                allLogsData = await response.json();
                allLogsData.sort((a, b) => new Date(b.modifiedAt) - new Date(a.modifiedAt));
                renderLogs(allLogsData.slice(0, 5));
                await renderInterruptedTasks();
            } catch (error) {
                console.error('Error loading logs:', error);
            }
        }

        function renderRunningTasks() {
            const container = document.getElementById('running-tasks');
            if (!runningTasksData) runningTasksData = [];
            const running = runningTasksData.filter(t => t.status === 'running');
            
            if (running.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无运行中的任务</div>';
                return;
            }
            
            container.innerHTML = running.map(task => {
                const startTime = new Date(task.startTime);
                const duration = Date.now() - startTime.getTime();
                const isRework = task.type === 'rework';
                let taskLabel = '🚀 开发中';
                if (task.type === 'rework') taskLabel = '🔧 返工修复中';
                else if (task.type === 'design') taskLabel = '🎨 设计中';
                else if (task.type === 'pm') taskLabel = '📋 PRD 产出中';
                else if (task.type === 'doc-gardener') taskLabel = '📝 Doc Gardener';
                const statusClass = isRework ? 'rework' : 'running';
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px ' + statusClass + '" data-issue="' + task.targetId + '">' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<a href="' + (currentProject && currentProject.repo ? getRepoBaseUrl(currentProject) + '/issues/' : '#') + '' + task.targetId + '" ' +
                           'class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline" target="_blank">' +
                            '#' + task.targetId + ': ' + escapeHtml(task.targetTitle) +
                        '</a>' +
                        '<span class="running-time text-sm font-medium text-emerald-500" data-start="' + task.startTime + '" data-label="' + taskLabel + '">' +
                            taskLabel + ' · ⏱️ ' + formatDuration(duration) +
                        '</span>' +
                    '</div>' +
                    '<div class="mb-3 text-sm text-slate-400">' + startTime.toLocaleString() + ' 开始</div>' +
                    '<div class="actions flex flex-wrap gap-2">' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openLogTerminalByFile(\'' + task.logFile + '\')">🖥️ 监控</button>' +
                        '<button class="bg-red-500 border-red-500 text-white hover:bg-red-600" onclick="stopTask(event, ' + task.targetId + ', \'' + task.type + '\')">⏹️ 停止</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        // 检测并显示可恢复的任务
        async function renderInterruptedTasks() {
            const container = document.getElementById('interrupted-tasks');
            
            // 直接从 runningTasksData 获取 interrupted 状态的任务
            const interrupted = runningTasksData.filter(t => t.status === 'interrupted');
            
            if (interrupted.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无中断的任务</div>';
                return;
            }
            
            container.innerHTML = interrupted.map(task => {
                const logFile = task.logFile.replace(/^logs\//, '');
                const typeLabel = task.type === 'rework' ? '返工修复' : 
                                  task.type === 'doc-gardener' ? '文档检查' : '开发';
                const btnText = task.type === 'rework' ? '🔄 恢复返工' : 
                                task.type === 'doc-gardener' ? '🔄 恢复文档检查' : '🔄 恢复开发';
                const resumeFn = task.type === 'rework' ? 'resumeRework' : 
                                 task.type === 'doc-gardener' ? 'resumeDocGardener' : 'resumeDev';
                const targetLabel = task.type === 'rework' || task.type === 'doc-gardener' ? 
                    'PR #' + task.targetId : 'Issue #' + task.targetId;
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px border-l-4 border-l-orange-500" data-issue="' + task.targetId + '" data-type="' + task.type + '">' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<span class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline">' + targetLabel + '</span>' +
                        '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-orange-500/15 text-orange-400">⏸️ 已中断 (' + typeLabel + ')</span>' +
                    '</div>' +
                    '<div class="mb-2 text-sm text-amber-500">⚠️ 任务因步骤限制中断，点击按钮继续完成</div>' +
                    '<div class="mb-3 text-sm text-slate-400">' + new Date(task.startTime).toLocaleString() + '</div>' +
                    '<div class="actions flex flex-wrap gap-2">' +
                        '<button class="bg-amber-500 border-amber-500 text-slate-900 hover:bg-amber-600" onclick="' + resumeFn + '(event, ' + task.targetId + ', \'' + logFile + '\')">' + btnText + '</button>' +
                        '<button onclick="openLogTerminalByFile(\'' + logFile + '\')">📄 查看日志</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        function renderIssues(containerId, issues, type) {
            const container = document.getElementById(containerId);
            if (!issues) issues = [];
            if (!runningTasksData) runningTasksData = [];
            
            if (issues.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无数据</div>';
                return;
            }
            
            const runningIds = new Set(runningTasksData.filter(t => t.status === 'running').map(t => t.targetId));
            
            container.innerHTML = issues.map(issue => {
                const isRunning = runningIds.has(issue.number);
                const labelsHtml = issue.labels.map(l => '<span class="label rounded-full bg-slate-400/10 border border-slate-400/20 px-2.5 py-0.5 text-xs text-slate-300">' + l.name + '</span>').join('');
                const classification = issue.classification || 'full-stack';
                const designTask = runningTasksData.find(t => t.type === 'design' && t.targetId === issue.number);
                const isDesigning = designTask && designTask.status === 'running';
                const issueType = getIssueType(issue.labels, issue.title, issue.body);
                const display = getIssueTypeDisplay(issueType);
                
                let actionsHtml = '<button onclick="viewIssue(' + issue.number + ')">查看</button>';
                
                if (isRunning) {
                    actionsHtml = '<button disabled>运行中...</button>' + actionsHtml;
                } else {
                    const designAssets = designAssetsCache[issue.number];
                    let viewDesignBtn = '';
                    if (designAssets && designAssets.length > 0) {
                        viewDesignBtn = '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openDesignViewer(' + issue.number + ')">🖼️ 查看设计</button>';
                    }
                    let designBtn = '';
                    if (classification !== 'backend-only') {
                        designBtn = '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="startDesign(event, ' + issue.number + ', \'' +
                            escapeHtml(issue.title) + '\')">🎨 开始设计</button>';
                    }

                    if (issueType === 'ui-feedback') {
                        // UI 反馈类优先设计调整，不显示开发按钮
                        actionsHtml = designBtn + viewDesignBtn + actionsHtml;
                    } else {
                        let devBtnClass = display.className || 'primary';
                        let devBtn = '<button class="' + devBtnClass + '" onclick="startDev(event, ' + issue.number + ', \'' +
                            escapeHtml(issue.title) + '\', \'' + issueType + '\')">' + display.text + '</button>';
                        if (isDesigning) {
                            devBtn = '<button class="bg-emerald-500 border-emerald-500 text-white hover:bg-emerald-600" disabled title="设计任务进行中，建议等待完成后再开发">' + display.text + '（等待设计）</button>';
                        }
                        if (classification === 'backend-only') {
                            actionsHtml = devBtn + actionsHtml;
                        } else {
                            actionsHtml = devBtn + viewDesignBtn + designBtn + actionsHtml;
                        }
                    }
                }
                
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px" data-issue="' + issue.number + '">' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<a href="' + (currentProject && currentProject.repo ? getRepoBaseUrl(currentProject) + '/issues/' : '#') + '' + issue.number + '" ' +
                           'class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline" target="_blank">' +
                            '#' + issue.number + ': ' + escapeHtml(issue.title) +
                        '</a>' +
                    '</div>' +
                    '<div class="mb-3 text-sm text-slate-400">' + new Date(issue.updatedAt).toLocaleString() + '</div>' +
                    '<div class="labels flex flex-wrap gap-1.5 mb-3">' + labelsHtml + '</div>' +
                    '<div class="actions flex flex-wrap gap-2">' + actionsHtml + '</div>' +
                '</div>';
            }).join('');

            // 异步加载设计资产信息（null 表示之前加载过但为空，也需要刷新）
            issues.forEach(issue => {
                if (designAssetsCache[issue.number] === undefined) {
                    loadDesignAssets(issue.number);
                }
            });
        }

        function renderLogs(logs) {
            const container = document.getElementById('recent-logs');
            
            if (logs.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无日志</div>';
                return;
            }
            
            container.innerHTML = logs.map(log => {
                const time = log.modifiedAt ? new Date(log.modifiedAt).toLocaleString() : '未知';
                const size = formatBytes(log.size);
                let title = 'File';
                if (log.filename.startsWith('dev-issue-')) {
                    title = 'Issue #' + log.issueNumber;
                } else if (log.filename.startsWith('review-pr-')) {
                    title = 'PR #' + log.issueNumber + ' Review';
                } else if (log.filename.startsWith('review-report-')) {
                    title = 'PR #' + log.issueNumber + ' Report';
                } else if (log.filename.startsWith('review-state-')) {
                    title = 'PR #' + log.issueNumber + ' State';
                } else if (log.filename.startsWith('pm-issue-')) {
                    title = 'Issue #' + log.issueNumber + ' PRD';
                } else if (log.filename.startsWith('doc-gardener-pr-')) {
                    title = 'PR #' + log.issueNumber + ' Doc Gardener';
                }
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px" class="mb-2 p-3">' +
                    '<div class="flex items-center justify-between">' +
                        '<div>' +
                            '<div class="text-sm text-blue-400">' + title + '</div>' +
                            '<div class="text-xs text-slate-500">' + time + ' · ' + size + '</div>' +
                        '</div>' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openLogTerminalByFile(\'' + log.filename + '\')">🖥️ 查看</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        // PR 相关函数
        async function loadPullRequests() {
            try {
                const response = await fetch('/api/pull-requests');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                const prs = await response.json();
                pullRequestsData = prs.sort((a, b) => b.number - a.number);
                renderPullRequests(prs);
            } catch (error) {
                console.error('Error loading PRs:', error);
                showToast('加载 PR 失败: ' + error.message, true);
                pullRequestsData = [];
                renderPullRequests([]);
            }
        }

        async function loadMergedPRs() {
            try {
                const response = await fetch('/api/pull-requests?state=merged');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                const prs = await response.json();
                renderMergedPRs(prs.sort((a, b) => b.number - a.number));
            } catch (error) {
                console.error('Error loading merged PRs:', error);
                renderMergedPRs([]);
            }
        }

        let reviewTasksData = [];
        let pullRequestsData = [];
        let issuesData = [];
        let currentProject = null;

        function renderPullRequests(prs) {
            const container = document.getElementById('pending-prs');
            
            if (prs.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无等待 Review 的 PR</div>';
                return;
            }
            
            // 获取 review 任务状态
            const reviewingIds = new Set(reviewTasksData.filter(t => t.status === 'running').map(t => t.targetId));
            const knownReviews = new Map(reviewTasksData.filter(t => ['success','failed','stopped','interrupted'].includes(t.status)).map(t => [t.targetId, t]));
            
            container.innerHTML = prs.map(pr => {
                const time = pr.createdAt ? new Date(pr.createdAt).toLocaleString() : '未知';
                const isReviewing = reviewingIds.has(pr.number);
                const reviewTask = knownReviews.get(pr.number);
                
                // 检查返工任务状态（running / failed / interrupted 都需要显示）
                const relatedReworkTask = runningTasksData.find(t =>
                    ['running', 'failed', 'interrupted'].includes(t.status) &&
                    t.type === 'rework' &&
                    t.prNumber === pr.number
                );
                const isReworkRunning = relatedReworkTask && relatedReworkTask.status === 'running';
                const isReworkFailed = relatedReworkTask && (relatedReworkTask.status === 'failed' || relatedReworkTask.status === 'interrupted');

                let statusHtml = '';
                let buttonsHtml = '';
                let extraClass = '';

                // 检测是否为 design PR
                let designIssueNumber = null;
                const designMatch = pr.title.match(/design:\\s+assets\\s+for\\s+issue\\s+#(\\d+)/i);
                if (designMatch) {
                    designIssueNumber = parseInt(designMatch[1], 10);
                    if (designAssetsCache[designIssueNumber] === undefined) {
                        loadDesignAssets(designIssueNumber);
                    }
                }

                if (isReworkRunning) {
                    // 返工修复中
                    statusHtml = '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-amber-500/15 text-amber-400 ml-2">🔧 返工修复中...</span>';
                    extraClass = ' rework';
                    buttonsHtml = '<button disabled>🔧 返工修复中...</button>' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openLogTerminalByFile(\'' + relatedReworkTask.logFile + '\')">📄 查看日志</button>' +
                        '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                } else if (isReworkFailed) {
                    // 返工失败/中断，可恢复
                    statusHtml = '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-red-500/15 text-red-400 ml-2">❌ 返工失败</span>';
                    extraClass = ' border-l-4 border-l-orange-500';
                    const logFile = relatedReworkTask.logFile.replace(/^logs\//, '');
                    buttonsHtml = '<button class="bg-amber-500 border-amber-500 text-slate-900 hover:bg-amber-600" onclick="resumeRework(event, ' + pr.number + ', \'' + logFile + '\')">🔄 恢复返工</button>' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="viewReviewReport(' + pr.number + ')">📋 查看报告</button>' +
                        '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                } else if (isReviewing) {
                    // Review 进行中
                    statusHtml = '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-emerald-500/15 text-emerald-400 ml-2">🔍 Review 中...</span>';
                    extraClass = ' running';
                    const logFile = reviewTasksData.find(t => t.targetId === pr.number)?.logFile?.replace(/^logs\//, '') || '';
                    buttonsHtml = '<button class="bg-red-500 border-red-500 text-white hover:bg-red-600" onclick="stopReviewTask(event, ' + pr.number + ')">⏹️ 停止 Review</button>' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openLogTerminalByFile(\'' + logFile + '\')">📄 查看日志</button>' +
                        '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                } else if (reviewTask) {
                    if (reviewTask.status === 'stopped' || reviewTask.status === 'interrupted') {
                        // Review 被手动停止或中断
                        const statusText = reviewTask.status === 'stopped' ? '⏹️ 已停止' : '⏸️ 已中断';
                        statusHtml = '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-orange-500/15 text-orange-400 ml-2">' + statusText + '</span>';
                        extraClass = ' border-l-4 border-l-orange-500';
                        buttonsHtml = '<button class="bg-emerald-500 border-emerald-500 text-white hover:bg-emerald-600" onclick="agentReviewPR(event, ' + pr.number + ', \'' + pr.branch + '\')">🔄 重新 Review</button>' +
                            '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                    } else {
                        // Review 已完成
                        const isPassed = reviewTask.result === 'passed';
                        const statusClass = isPassed ? 'bg-blue-500/15 text-blue-300' : 'bg-red-500/15 text-red-400';
                        const statusText = isPassed ? '✅ 通过' : '❌ 需修改';
                        let docSyncHint = '';
                        const report = reviewTask.report || '';
                        if (report.includes('文档同步') && (report.includes('❌') || report.includes('文档缺失') || report.includes('缺少文档'))) {
                            docSyncHint = ' <span title="文档同步未通过" class="cursor-help">📚</span>';
                        }
                        statusHtml = '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold ' + statusClass + ' ml-2">' + statusText + '</span>' + docSyncHint;
                        extraClass = isPassed ? '' : ' interrupted';
                        
                        if (isPassed) {
                            // 审查通过，可以合并
                            buttonsHtml = '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="viewReviewReport(' + pr.number + ')">📋 查看报告</button>' +
                                '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="runDocGardener(event, ' + pr.number + ', \'' + (pr.baseRefName || '') + '\')">📚 文档检查</button>' +
                                '<button class="bg-emerald-500 border-emerald-500 text-white hover:bg-emerald-600" onclick="mergePR(event, ' + pr.number + ')">✅ 合并 PR</button>' +
                                '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                        } else {
                            // 需要返工
                            buttonsHtml = '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="viewReviewReport(' + pr.number + ')">📋 查看报告</button>' +
                                '<button class="bg-amber-500 border-amber-500 text-slate-900 hover:bg-amber-600" onclick="reworkPR(event, ' + pr.number + ')">🔧 标记返工</button>' +
                                '<button class="bg-emerald-500 border-emerald-500 text-white hover:bg-emerald-600" onclick="agentReviewPR(event, ' + pr.number + ', \'' + pr.branch + '\')">🔄 重新 Review</button>';
                        }
                    }
                } else {
                    // 尚未 Review
                    buttonsHtml = '<button class="bg-emerald-500 border-emerald-500 text-white hover:bg-emerald-600" onclick="agentReviewPR(event, ' + pr.number + ', \'' + pr.branch + '\')">🤖 Agent Review</button>' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="mergePR(event, ' + pr.number + ')">✅ 直接通过</button>' +
                        '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>';
                }
                
                // 如为 design PR 且设计资产已缓存，追加查看设计按钮
                let designBtnHtml = '';
                if (designIssueNumber && designAssetsCache[designIssueNumber]) {
                    designBtnHtml = '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openDesignViewer(' + designIssueNumber + ')">🖼️ 查看设计</button>';
                }
                
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px' + extraClass + '" data-pr="' + pr.number + '"' + (designIssueNumber ? ' data-design-issue="' + designIssueNumber + '"' : '') + '>' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<a href="' + pr.url + '" class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline" target="_blank">' +
                            '#' + pr.number + ': ' + escapeHtml(pr.title) +
                        '</a>' +
                        statusHtml +
                    '</div>' +
                    '<div class="mb-3 text-sm text-slate-400">' + time + ' · 分支: ' + pr.branch + '</div>' +
                    '<div class="actions flex flex-wrap gap-2">' + designBtnHtml + buttonsHtml + '</div>' +
                '</div>';
            }).join('');
        }

        function renderMergedPRs(prs) {
            const container = document.getElementById('merged-prs');
            const countEl = document.getElementById('merged-pr-count');
            if (countEl) countEl.textContent = prs.length;

            if (prs.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无最近合并的 PR</div>';
                return;
            }

            container.innerHTML = prs.map(pr => {
                const time = pr.createdAt ? new Date(pr.createdAt).toLocaleString() : '未知';
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px" class="opacity-85" data-pr="' + pr.number + '">' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<a href="' + pr.url + '" class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline" target="_blank">' +
                            '#' + pr.number + ': ' + escapeHtml(pr.title) +
                        '</a>' +
                        '<span class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-blue-500/15 text-blue-300">🎉 已合并</span>' +
                    '</div>' +
                    '<div class="mb-3 text-sm text-slate-400">' + time + ' · 分支: ' + pr.branch + '</div>' +
                    '<div class="actions flex flex-wrap gap-2">' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="runMergedDocGardener(event, ' + pr.number + ')">📚 文档检查</button>' +
                        '<button onclick="window.open(\'' + pr.url + '\', \'_blank\')">👁️ 查看 PR</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        async function runMergedDocGardener(event, number) {
            const btn = event && event.target;
            setButtonLoading(btn, true);
            showGlobalLoading('Merged Doc Gardener 启动中...');
            try {
                const response = await fetch('/api/merged-doc-gardener', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prNumber: number })
                });
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                const result = await response.json();
                showToast(result.message);
                openLogTerminalByFile(result.logFile);
            } catch (error) {
                showToast('文档检查启动失败: ' + error.message, true);
            } finally {
                setButtonLoading(btn, false);
                hideGlobalLoading();
            }
        }

        async function loadReviewTasks() {
            try {
                const response = await fetch('/api/review-tasks');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                reviewTasksData = await response.json();
                reviewTasksData.sort((a, b) => new Date(b.startTime || 0) - new Date(a.startTime || 0));
            } catch (error) {
                console.error('Error loading review tasks:', error);
                reviewTasksData = [];
            }
        }

        let docGardenerTasksData = [];

        async function loadDocGardenerTasks() {
            try {
                const response = await fetch('/api/doc-gardener-tasks');
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Unknown error' }));
                    throw new Error(err.error || 'HTTP ' + response.status);
                }
                docGardenerTasksData = await response.json();
                docGardenerTasksData.sort((a, b) => new Date(b.startTime || 0) - new Date(a.startTime || 0));
                renderDocGardenerTasks();
            } catch (error) {
                console.error('Error loading doc gardener tasks:', error);
                docGardenerTasksData = [];
                renderDocGardenerTasks();
            }
        }

        function renderDocGardenerTasks() {
            const container = document.getElementById('doc-gardener-tasks');
            if (!docGardenerTasksData) docGardenerTasksData = [];
            const running = docGardenerTasksData.filter(t => t.status === 'running');
            
            if (running.length === 0) {
                container.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">暂无文档检查任务</div>';
                return;
            }
            
            container.innerHTML = running.map(task => {
                const startTime = new Date(task.startTime);
                const duration = Date.now() - startTime.getTime();
                const label = task.merged ? '已合并 PR 文档补全' : 'PR 文档检查';
                return '<div class="issue-card rounded-xl border border-slate-700 bg-slate-800 p-4 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)] transition-all duration-200 hover:border-slate-600 hover:-translate-y-px border-l-4 border-l-emerald-500" data-pr="' + task.prNumber + '">' +
                    '<div class="issue-header flex items-start justify-between gap-4 mb-2">' +
                        '<span class="text-base font-medium leading-snug text-blue-300 no-underline hover:underline">' + label + ' · PR #' + task.prNumber + '</span>' +
                        '<span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold bg-emerald-500/15 text-emerald-400">📚 检查中</span>' +
                    '</div>' +
                    '<div class="mb-3 text-sm text-slate-400">⏱️ ' + formatDuration(duration) + ' · ' + startTime.toLocaleString() + ' 开始</div>' +
                    '<div class="actions flex flex-wrap gap-2">' +
                        '<button class="bg-blue-500 border-blue-500 text-white hover:bg-blue-600" onclick="openLogTerminalByFile(\'' + task.logFile + '\')">🖥️ 监控</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        async function agentReviewPR(event, number, branch) {
            if (!confirm('确认使用 Agent Review PR #' + number + '?')) {
                return;
            }
            const btn = event && event.target;
            setButtonLoading(btn, true);
            showGlobalLoading('Agent Review 启动中...');
            
            try {
                const response = await fetch('/api/review-pr', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prNumber: number, branch: branch })
                });
                const result = await response.json();
                showToast(result.message);
                
                // 立即刷新显示 Review 状态
                if (result.status === 'started' || result.status === 'already_running') {
                    await loadReviewTasks();
                    await loadPullRequests();
                }
            } catch (error) {
                showToast('Review 启动失败: ' + error.message, true);
