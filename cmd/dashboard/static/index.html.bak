        function openLogTerminalByFile(filename) {
            currentLogFile = filename;
            document.getElementById('terminal-filename').textContent = 'tail -f ' + filename;
            terminalOverlay.classList.remove('hidden');
            terminalOverlay.classList.add('flex');
            
            terminalBody.innerHTML = '';
            lineCount = 0;
            isAutoScroll = true;
            rawLogLines = [];
            parsedBlockPending = null;
            logBuffer = [];
            
            if (eventSource) {
                eventSource.close();
            }
            
            eventSource = new EventSource('/api/log-tail?file=' + encodeURIComponent(filename));
            
            eventSource.onmessage = (e) => {
                logBuffer.push(e.data);
                if (!logFlushPending) {
                    logFlushPending = true;
                    requestAnimationFrame(() => {
                        flushLogBuffer();
                        logFlushPending = false;
                    });
                }
            };
            
            eventSource.onerror = (e) => {
                console.log('SSE error, reconnecting...');
                eventSource.close();
                setTimeout(() => {
                    if (terminalOverlay.classList.contains('flex')) {
                        openLogTerminalByFile(filename);
                    }
                }, 3000);
            };
            
            document.addEventListener('keydown', handleEscKey);
        }

        function createLogLine(text) {
            lineCount++;
            
            const lineDiv = document.createElement('div');
            lineDiv.className = 'log-line py-0.5 whitespace-pre-wrap break-all hover:bg-slate-700/40';
            
            let contentClass = '';
            const lower = text.toLowerCase();
            if (lower.includes('error') || lower.includes('❌') || lower.includes('fail')) {
                contentClass = 'text-red-400';
            } else if (lower.includes('success') || lower.includes('✅') || lower.includes('done')) {
                contentClass = 'text-emerald-400';
            } else if (lower.includes('warn') || lower.includes('⚠️')) {
                contentClass = 'text-amber-400';
            } else if (lower.includes('toolcall') || lower.includes('toolresult')) {
                contentClass = 'text-violet-400';
            } else if (lower.includes('thinkpart')) {
                contentClass = 'text-slate-400 italic';
            } else if (text.startsWith('>') || text.startsWith('$')) {
                contentClass = 'text-blue-400 font-medium';
            }
            
            const escaped = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            
            lineDiv.innerHTML = 
                '<span class="inline-block w-14 select-none pr-3 text-right text-slate-500">' + lineCount + '</span>' +
                '<span class="text-slate-200 ' + contentClass + '">' + escaped + '</span>';
            
            return lineDiv;
        }

        let logBuffer = [];
        let logFlushPending = false;

        function toggleRenderMode() {
            renderMode = renderMode === 'rendered' ? 'raw' : 'rendered';
            const btn = document.getElementById('-btn');
            btn.textContent = renderMode === 'rendered' ? '渲染' : '原始';
            btn.classList.toggle('bg-blue-500', renderMode === 'rendered');
            btn.classList.toggle('text-white', renderMode === 'rendered');
            btn.classList.toggle('border-blue-500', renderMode === 'rendered');
            btn.classList.toggle('bg-slate-900', renderMode !== 'rendered');
            btn.classList.toggle('text-slate-400', renderMode !== 'rendered');
            btn.classList.toggle('border-slate-700', renderMode !== 'rendered');
            // 重新渲染当前内容
            terminalBody.innerHTML = '';
            lineCount = 0;
            parsedBlockPending = null;
            if (rawLogLines.length > 0) {
                const toRender = rawLogLines.slice();
                rawLogLines = [];
                logBuffer = toRender;
                flushLogBuffer();
            }
        }

        // 解析 kimi 结构化日志为块数组
        function parseKimiBlocks(rawTexts) {
            const allLines = [];
            for (const text of rawTexts) {
                if (text) allLines.push(...text.split('\n'));
            }
            const blocks = [];
            let current = parsedBlockPending;
            const topLevelPattern = /^(TurnBegin|TurnEnd|StepBegin|ThinkPart|ToolCall|ToolResult|ToolCallPart|StatusUpdate|TextPart|ToolResultPart)\(/;

            for (const line of allLines) {
                const trimmed = line.trimStart();
                const match = trimmed.match(topLevelPattern);

                if (match) {
                    // 新的顶层对象开始，结束当前块
                    if (current) blocks.push(current);
                    current = { type: match[1], lines: [line] };
                } else {
                    // 累积到当前块（对象内部或 plain 文本）
                    if (!current) current = { type: 'plain', lines: [] };
                    current.lines.push(line);
                }
            }
            parsedBlockPending = current;
            return blocks;
        }

        // 从对象文本中提取 key=value 格式的值
        function extractValue(text, key) {
            const regex = new RegExp(key + "='([^']*?)'(?:,|\\))");
            const m = text.match(regex);
            if (m) return m[1];
            const regex2 = new RegExp(key + '="([^"]*?)"(?:,|\\))');
            const m2 = text.match(regex2);
            if (m2) return m2[1];
            return '';
        }

        // 为多行对象提取指定字段（跨行）
        function extractField(lines, fieldName) {
            const text = lines.join('\n');
            // 先尝试匹配引号包裹的值（支持多行）
            const regex = new RegExp(fieldName + "=['\"]([\\s\\S]*?)['\"](?:,\\s*\\n|\\))");
            const m = text.match(regex);
            if (m) {
                return m[1]
                    .replace(/\\n/g, '\n')
                    .replace(/\\t/g, '\t')
                    .replace(/\\r/g, '\r');
            }
            // 再尝试匹配无引号的简单值（数字、标识符等）
            const regex2 = new RegExp(fieldName + '=([^,\\n\\)]+)');
            const m2 = text.match(regex2);
            if (m2) return m2[1].trim();
            return '';
        }

        function createRenderedBlock(block, isPending) {
            const div = document.createElement('div');
            div.className = 'rendered-block my-1.5';
            if (isPending) div.setAttribute('data-pending', 'true');
            const rawText = block.lines.join('\n');

            switch (block.type.toLowerCase()) {
                case 'turnbegin': {
                    div.className += '  my-2 border-l-[3px] border-l-blue-500 pl-3';
                    const hasPrompt = rawText.includes('user_input=');
                    div.innerHTML = '<div class="font-semibold text-blue-500 cursor-pointer select-none hover:opacity-80" onclick="this.nextElementSibling.classList.toggle(\'hidden\')">🔄 Turn 开始 ' + (hasPrompt ? '(点击展开 prompt)' : '') + '</div>' +
                        '<div class="hidden"><pre class="mt-2 text-xs whitespace-pre-wrap text-slate-400">' + escapeHtml(rawText.substring(0, 500)) + (rawText.length > 500 ? '... (' + rawText.length + ' chars)' : '') + '</pre></div>';
                    break;
                }
                case 'turnend': {
                    div.className += '  text-slate-500 text-xs py-1 border-t border-dashed border-slate-700 mt-2';
                    div.innerHTML = '✓ Turn 结束';
                    break;
                }
                case 'stepbegin': {
                    div.className += '  my-2 rounded-md border border-blue-500/25 bg-blue-500/10 px-3 py-1.5 font-semibold text-blue-400';
                    const n = rawText.match(/n=(\d+)/);
                    div.innerHTML = '▶ Step ' + (n ? n[1] : '?');
                    break;
                }
                case 'thinkpart': {
                    div.className += '  my-1.5 rounded-r-md border-l-[3px] border-l-slate-500 bg-slate-400/5 px-3 py-2';
                    let think = extractField(block.lines, 'think');
                    think = unwrapHardBreaks(think);
                    const thinkHtml = typeof marked !== 'undefined' ? marked.parse(think) : escapeHtml(think);
                    div.innerHTML = '<div class="-header text-xs font-semibold text-slate-400 mb-1">💭 思考</div>' +
                        '<div class="kimi-markdown -body text-slate-300 italic whitespace-pre-wrap">' + thinkHtml + '</div>';
                    break;
                }
                case 'toolcall': {
                    div.className += '  my-1.5 rounded-md border border-violet-500/20 bg-violet-500/5 px-3 py-1.5';
                    const name = extractField(block.lines, 'name');
                    const args = extractField(block.lines, 'arguments');
                    let summary = name || 'Tool';
                    let body = rawText;
                    if (args && args.length > 0) {
                        try {
                            const parsed = JSON.parse(args);
                            if (parsed.command) {
                                summary += ': ' + parsed.command.substring(0, 120);
                            } else if (parsed.path) {
                                summary += ': ' + parsed.path;
                            } else if (parsed.query) {
                                summary += ': ' + parsed.query.substring(0, 120);
                            } else {
                                summary += ': ' + JSON.stringify(parsed).substring(0, 120);
                            }
                            body = JSON.stringify(parsed, null, 2);
                        } catch (e) {
                            summary += ': ' + args.substring(0, 120);
                        }
                    }
                    div.innerHTML = '<div class="text-xs font-semibold text-violet-400 cursor-pointer select-none" onclick="const b=this.nextElementSibling;b.classList.toggle(\'hidden\');b.classList.toggle(\'block\')">🔧 ' + escapeHtml(summary) + '</div>' +
                        '<div class="hidden text-slate-300 mt-1 whitespace-pre-wrap"><pre class="m-0 text-xs leading-relaxed">' + escapeHtml(body) + '</pre></div>';
                    break;
                }
                case 'toolresult': {
                    div.className += '  my-1.5 rounded-r-md border-l-[3px] border-l-emerald-400 bg-emerald-400/5 px-3 py-1.5';
                    const result = extractField(block.lines, 'result') || extractField(block.lines, 'output') || extractField(block.lines, 'content') || rawText;
                    const lines = result.split('\n');
                    const summary = (lines[0] || 'Result').substring(0, 100);
                    const isMd = /^(#{1,6}\s|^\|.+\||^[-*+]\s|^\d+\.\s|\*\*[^*]+\*\*|```|^\[.+\]\(.+\)|^>\s)/m.test(result);
                    let bodyHtml;
                    if (isMd && typeof marked !== 'undefined') {
                        bodyHtml = marked.parse(result);
                    } else {
                        bodyHtml = '<pre class="m-0">' + escapeHtml(result) + '</pre>';
                    }
                    div.innerHTML = '<div class="text-xs font-semibold text-emerald-400 cursor-pointer select-none" onclick="const b=this.nextElementSibling;b.classList.toggle(\'hidden\');b.classList.toggle(\'block\')">📤 ' + escapeHtml(summary) + '</div>' +
                        '<div class="-body hidden text-slate-300 whitespace-pre-wrap text-xs font-mono leading-relaxed mt-1">' + bodyHtml + '</div>';
                    break;
                }
                case 'toolcallpart': {
                    div.className += '  my-1.5 rounded-md border border-violet-500/20 bg-violet-500/5 px-3 py-1.5';
                    const args = extractField(block.lines, 'arguments_part');
                    let summary = 'Tool片段';
                    let body = rawText;
                    if (args && args.length > 0) {
                        try {
                            const parsed = JSON.parse(args);
                            if (parsed.command) summary += ': ' + parsed.command.substring(0, 120);
                            else if (parsed.path) summary += ': ' + parsed.path;
                            else if (parsed.query) summary += ': ' + parsed.query.substring(0, 120);
                            else summary += ': ' + JSON.stringify(parsed).substring(0, 120);
                            body = JSON.stringify(parsed, null, 2);
                        } catch (e) {
                            summary += ': ' + args.substring(0, 120);
                        }
                    }
                    div.innerHTML = '<div class="text-xs font-semibold text-violet-400 cursor-pointer select-none" onclick="this.parentElement.classList.toggle(\'expanded\')">📝 ' + escapeHtml(summary) + '</div>' +
                        '<div class=""><pre class="m-0 text-xs leading-normal">' + escapeHtml(body) + '</pre></div>';
                    break;
                }
                case 'statusupdate': {
                    div.className += '  text-slate-500 text-xs py-0.5 px-2';
                    const usage = extractField(block.lines, 'token_usage');
                    const ctx = extractField(block.lines, 'context_tokens');
                    const maxCtx = extractField(block.lines, 'max_context_tokens');
                    let status = '';
                    if (ctx && maxCtx) {
                        const pct = Math.round((parseInt(ctx) / parseInt(maxCtx)) * 100);
                        status = '📊 Context: ' + ctx + ' / ' + maxCtx + ' (' + pct + '%)';
                    } else if (usage) {
                        status = '📊 Tokens: ' + usage.substring(0, 100);
                    } else {
                        status = '📊 Status Update';
                    }
                    div.textContent = status;
                    break;
                }
                case 'textpart': {
                    div.className += '  my-1.5 rounded-r-md border-l-[3px] border-l-slate-500 bg-slate-400/5 px-3 py-2';
                    let text = extractField(block.lines, 'text');
                    text = unwrapHardBreaks(text);
                    const textHtml = typeof marked !== 'undefined' ? marked.parse(text) : escapeHtml(text);
                    div.innerHTML = '<div class="-header text-xs font-semibold text-slate-400 mb-1">📝 文本</div>' +
                        '<div class="kimi-markdown -body text-slate-300 italic whitespace-pre-wrap">' + textHtml + '</div>';
                    break;
                }
                default: {
                    div.className += '  text-slate-200 whitespace-pre-wrap py-0.5';
                    div.textContent = rawText;
                    break;
                }
            }
            return div;
        }

        function escapeHtml(text) {
            return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        // 去掉 kimi 日志中对长字符串的硬折行（单词中间被截断的换行）
        // 保留 Markdown 列表、空行分隔、缩进段落等自然换行
        function unwrapHardBreaks(text) {
            return text.replace(/(\w)\n(?=\w|-\w)/g, '$1');
        }

        function flushLogBuffer() {
            if (logBuffer.length === 0) return;
            const lines = logBuffer.splice(0, logBuffer.length);
            rawLogLines.push(...lines);
            const frag = document.createDocumentFragment();

            if (renderMode === 'rendered') {
                const blocks = parseKimiBlocks(lines);
                // 移除旧的 pending 块避免重复
                const oldPending = terminalBody.querySelector('[data-pending="true"]');
                if (oldPending) oldPending.remove();
                for (const block of blocks) {
                    frag.appendChild(createRenderedBlock(block));
                    lineCount += block.lines.length || 1;
                }
                // 如果还有未完成的对象，实时渲染（带 pending 标记）
                if (parsedBlockPending) {
                    frag.appendChild(createRenderedBlock(parsedBlockPending, true));
                    lineCount += parsedBlockPending.lines.length || 1;
                }
            } else {
                for (const text of lines) {
                    frag.appendChild(createLogLine(text));
                }
            }
            terminalBody.appendChild(frag);

            while (terminalBody.childElementCount > 5000) {
                terminalBody.removeChild(terminalBody.firstElementChild);
            }

            document.getElementById('line-count').textContent = lineCount + ' lines';

            if (isAutoScroll) {
                scrollToBottom();
            }
        }

        function closeTerminal() {
            terminalOverlay.classList.add('hidden');
            terminalOverlay.classList.remove('flex');
            if (eventSource) {
                eventSource.close();
                eventSource = null;
            }
            logBuffer = [];
            logFlushPending = false;
            document.removeEventListener('keydown', handleEscKey);
        }

        async function loadDesignAssets(issueNumber) {
            try {
                const res = await fetch('/api/design-assets?issueNumber=' + issueNumber);
                const data = await res.json();
                const assets = data.assets || [];
                designAssetsCache[issueNumber] = assets.length > 0 ? assets : null;
                // 局部更新对应 issue 卡片和 design PR 卡片上的按钮与状态标签
                const issueCard = document.querySelector('.issue-card[data-issue="' + issueNumber + '"]');
                const prCard = document.querySelector('.issue-card[data-design-issue="' + issueNumber + '"]');
                [issueCard, prCard].forEach(card => {
                    if (card && assets.length > 0) {
                        // 插入/更新状态标签
                        const header = card.querySelector('.issue-header');
                        if (header && !header.querySelector('.design-ready-badge')) {
                            const badge = document.createElement('span');
                            badge.className = ' inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-semibold bg-blue-500/15 text-blue-300 design-ready-badge';
                            badge.style.marginLeft = '0.5rem';
                            badge.innerHTML = '🎨 设计资产已就绪';
                            header.appendChild(badge);
                        }
                        // 插入查看设计按钮
                        const actions = card.querySelector('.actions');
                        if (actions && !actions.querySelector('[onclick^="openDesignViewer"]')) {
                            const btn = document.createElement('button');
                            btn.className = 'secondary';
                            btn.innerHTML = '🖼️ 查看设计';
                            btn.onclick = () => openDesignViewer(issueNumber);
                            const startDesignBtn = Array.from(actions.children).find(el => el.innerHTML.includes('开始设计'));
                            if (startDesignBtn) {
                                actions.insertBefore(btn, startDesignBtn);
                            } else {
                                actions.insertBefore(btn, actions.firstChild);
                            }
                        }
                    }
                });
                return designAssetsCache[issueNumber];
            } catch (e) {
                designAssetsCache[issueNumber] = null;
                return null;
            }
        }

        function toggleDesignGroup(el) {
            el.parentElement.classList.toggle('collapsed');
            const content = el.parentElement.querySelector('.design-file-group-content');
            if (content) content.classList.toggle('hidden');
            const isCollapsed = el.parentElement.classList.contains('collapsed');
            el.classList.toggle('after:content-[\'_▶\']', isCollapsed);
            el.classList.toggle('after:content-[\'_▼\']', !isCollapsed);
        }

        function openDesignViewer(issueNumber) {
            const assets = designAssetsCache[issueNumber] || [];
            const overlay = document.getElementById('');
            const fileList = document.getElementById('');

            if (assets.length === 0) {
                showToast('暂无设计资产', true);
                return;
            }

            const groups = [
                { key: 'preview', title: '🔥 交互预览', types: ['flutter-web'] },
                { key: 'docs', title: '🌐 原型与文档', types: ['html', 'markdown'] },
                { key: 'visual', title: '🖼️ 设计图', types: ['image'] },
                { key: 'code', title: '💻 组件代码', types: ['code'], collapsed: true },
                { key: 'other', title: '📎 其他', types: ['file'] },
            ];

            let firstIdx = -1;
            let html = '';
            groups.forEach(group => {
                const items = [];
                assets.forEach((asset, idx) => {
                    if (group.types.includes(asset.type)) {
                        items.push({ ...asset, _idx: idx });
                    }
                });
                if (items.length === 0) return;
                if (firstIdx === -1) firstIdx = items[0]._idx;

                const isCollapsed = group.collapsed ? ' collapsed' : '';
                html += '<div class="design-file-group mb-1' + isCollapsed + '">';
                html += '<div class="flex cursor-pointer select-none items-center justify-between rounded-md px-3 py-2 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400 transition-colors duration-150 hover:bg-slate-700 after:content-[\'_▼\'] after:text-[0.6rem] after:ml-1" onclick="toggleDesignGroup(this)">' + group.title + ' <span class="text-[0.7rem] opacity-50">(' + items.length + ')</span></div>';
                html += '<div class="design-file-group-content' + (group.collapsed ? ' hidden' : '') + '">';
                items.forEach(asset => {
                    let icon = '📝';
                    if (asset.type === 'image') icon = '🖼️';
                    else if (asset.type === 'html') icon = '🌐';
                    else if (asset.type === 'flutter-web') icon = '🔥';
                    else if (asset.type === 'code') icon = '💻';
                    html += '<div class="design-file-item flex cursor-pointer items-center gap-2 overflow-hidden text-ellipsis whitespace-nowrap rounded-lg border-l-transparent px-3 py-2.5 text-sm text-slate-400 transition-all duration-150 hover:bg-slate-700 hover:text-slate-100' + (asset._idx === 0 ? ' border-l-[3px] border-l-violet-500' : '') + '" data-idx="' + asset._idx + '" title="' + escapeHtml(asset.name) + '" onclick="selectDesignAsset(' + issueNumber + ', ' + asset._idx + ')">' +
                        '<span>' + icon + '</span>' + escapeHtml(asset.name) + '</div>';
                });
                html += '</div></div>';
            });

            fileList.innerHTML = html;
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            selectDesignAsset(issueNumber, firstIdx >= 0 ? firstIdx : 0);
        }

        function closeDesignViewer() {
            document.getElementById('').classList.add('hidden');
            document.getElementById('').classList.remove('flex');
        }

        function highlightCode(text, filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const isDart = ext === 'dart';
            const isJsLike = ['js','ts','tsx','jsx','css','scss','less'].includes(ext);
            if (!isDart && !isJsLike) return escapeHtml(text);

            const keywords = new Set(['class','extends','implements','with','mixin','abstract','interface','factory','static','final','const','late','required','void','return','if','else','for','while','do','switch','case','break','continue','default','try','catch','finally','throw','assert','async','await','yield','sync','new','this','super','get','set','operator','external','native','covariant','var','dynamic','typedef','enum','part','library','export','import','show','hide','as','is','in','true','false','null','function','let','const','var','typeof','instanceof']);
            const typeKeywords = new Set(['int','double','String','bool','List','Map','Set','Future','Stream','Widget','BuildContext','State','StatefulWidget','StatelessWidget','Element','Key','Object','dynamic','num']);

            let html = '';
            let i = 0;
            while (i < text.length) {
                // 多行注释 /* */
                if (text.substr(i, 2) === '/*') {
                    let end = text.indexOf('*/', i + 2);
                    if (end === -1) { end = text.length; } else { end += 2; }
                    html += '<span style="color:#6a9955;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 单行注释 //
                if (text.substr(i, 2) === '//') {
                    let end = text.indexOf('\n', i);
                    if (end === -1) end = text.length;
                    html += '<span style="color:#6a9955;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 字符串（单引号，含转义）
                if (text[i] === "'") {
                    let end = i + 1;
                    while (end < text.length && text[end] !== "'") {
                        if (text[end] === '\\' && end + 1 < text.length) end++;
                        end++;
                    }
                    if (end < text.length) end++;
                    html += '<span style="color:#ce9178;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 字符串（双引号，含转义）
                if (text[i] === '"') {
                    let end = i + 1;
                    while (end < text.length && text[end] !== '"') {
                        if (text[end] === '\\' && end + 1 < text.length) end++;
                        end++;
                    }
                    if (end < text.length) end++;
                    html += '<span style="color:#ce9178;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 字符串（三引号 ''' 或 """)
                if (text.substr(i, 3) === "'''") {
                    let end = text.indexOf("'''", i + 3);
                    if (end === -1) end = text.length; else end += 3;
                    html += '<span style="color:#ce9178;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                if (text.substr(i, 3) === '"""') {
                    let end = text.indexOf('"""', i + 3);
                    if (end === -1) end = text.length; else end += 3;
                    html += '<span style="color:#ce9178;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 注解 @
                if (text[i] === '@') {
                    let end = i + 1;
                    while (end < text.length && /[a-zA-Z0-9_]/.test(text[end])) end++;
                    html += '<span style="color:#4ec9b0;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 标识符 / 关键字
                if (/[a-zA-Z_]/.test(text[i])) {
                    let end = i + 1;
                    while (end < text.length && /[a-zA-Z0-9_]/.test(text[end])) end++;
                    const word = text.slice(i, end);
                    const esc = escapeHtml(word);
                    if (keywords.has(word)) {
                        html += '<span style="color:#569cd6;">' + esc + '</span>';
                    } else if (typeKeywords.has(word) || /^[A-Z]/.test(word)) {
                        html += '<span style="color:#4ec9b0;">' + esc + '</span>';
                    } else {
                        html += esc;
                    }
                    i = end; continue;
                }
                // 数字
                if (/\d/.test(text[i])) {
                    let end = i + 1;
                    while (end < text.length && /[\d.]/.test(text[end])) end++;
                    html += '<span style="color:#b5cea8;">' + escapeHtml(text.slice(i, end)) + '</span>';
                    i = end; continue;
                }
                // 其他字符
                html += escapeHtml(text[i]);
                i++;
            }
            return html;
        }

        function selectDesignAsset(issueNumber, idx) {
            const assets = designAssetsCache[issueNumber] || [];
            const asset = assets[idx];
            if (!asset) return;

            document.querySelectorAll('.design-file-item').forEach(el => {
                const isActive = parseInt(el.getAttribute('data-idx')) === idx;
                el.classList.toggle('border-l-[3px]', isActive);
                el.classList.toggle('border-l-violet-500', isActive);
                el.classList.toggle('border-l-transparent', !isActive);
            });

            document.getElementById('').textContent = asset.name;
            const body = document.getElementById('');

            if (asset.type === 'image') {
                body.innerHTML = '<img class="max-h-full max-w-full rounded-lg border border-slate-700 object-contain" src="' + asset.url + '" alt="' + escapeHtml(asset.name) + '">';
            } else if (asset.type === 'html' || asset.type === 'flutter-web') {
                body.innerHTML = '<iframe class="h-full w-full rounded-lg border-none bg-white" src="' + asset.url + '"></iframe>';
            } else if (asset.type === 'code') {
                fetch(asset.url)
                    .then(r => r.text())
                    .then(text => {
                        body.innerHTML = '<pre class="h-full w-full overflow-auto whitespace-pre-wrap rounded-lg bg-[#0d1117] p-4 font-mono text-sm leading-relaxed text-slate-200"><code>' + highlightCode(text, asset.name) + '</code></pre>';
                    })
                    .catch(() => {
                        body.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">加载失败</div>';
                    });
            } else if (asset.type === 'markdown') {
                fetch(asset.url)
                    .then(r => r.text())
                    .then(text => {
                        body.innerHTML = '<pre class="h-full w-full overflow-auto whitespace-pre-wrap rounded-lg bg-[#0d1117] p-4 font-mono text-sm leading-relaxed text-slate-200">' + escapeHtml(text) + '</pre>';
                    })
                    .catch(() => {
                        body.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">加载失败</div>';
                    });
            } else {
                body.innerHTML = '<div class="px-4 py-10 text-center text-[0.9375rem] text-slate-400">该文件类型暂不支持预览</div>';
            }
        }

        function clearTerminal() {
            terminalBody.innerHTML = '';
            lineCount = 0;
            logBuffer = [];
            rawLogLines = [];
            parsedBlockPending = null;
            document.getElementById('line-count').textContent = '0 lines';
        }

        function handleEscKey(e) {
            if (e.key === 'Escape') {
                closeTerminal();
            }
        }

        function getRepoBaseUrl(project) {
            if (!project || !project.repo) return '';
            if (project.repo.startsWith('http://') || project.repo.startsWith('https://')) {
                return project.repo.replace(/\/$/, '');
            }
            var host = project.platform === 'gitlab' ? 'https://gitlab.com' : 'https://github.com';
            return host + '/' + project.repo;
        }

        function viewIssue(number) {
            var base = getRepoBaseUrl(currentProject);
            window.open(base ? base + '/issues/' + number : '#', '_blank');
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        function updateRunningTimes() {
            document.querySelectorAll('.running-time').forEach(el => {
                const startTime = new Date(el.dataset.start);
                const duration = Date.now() - startTime.getTime();
                const label = el.dataset.label || '';
                el.textContent = (label ? label + ' · ' : '') + '⏱️ ' + formatDuration(duration);
            });
        }

        // 查看 Review 报告
        async function viewReviewReport(number) {
            try {
                const response = await fetch('/api/review-report?pr=' + number);
                const data = await response.json();
                
                if (data.status === 'not_found') {
                    showToast('未找到该 PR 的 Review 记录', true);
                    return;
                }
                
                const reportHtml = '<div style="max-height: 60vh; overflow-y: auto; text-align: left; font-family: monospace; font-size: 0.875rem;">' +
                    '<div style="margin-bottom: 1rem; padding: 0.75rem; background: #21262d; border-radius: 6px;">' +
                        '<div style="font-weight: bold; margin-bottom: 0.5rem;">📋 Review 报告 - PR #' + number + '</div>' +
                        '<div style="color: #8b949e;">状态: ' + (data.status === "success" ? "✅ 完成" : "❌ 失败") + '</div>' +
                        (data.result ? '<div style="color: #8b949e;">结果: ' + (data.result === "passed" ? "✅ 通过" : "❌ 需修改") + '</div>' : '') +
                        '<div style="color: #8b949e;">开始: ' + new Date(data.startTime).toLocaleString() + '</div>' +
                        (data.endTime ? '<div style="color: #8b949e;">结束: ' + new Date(data.endTime).toLocaleString() + '</div>' : '') +
                    '</div>' +
                    (data.report ? '<div style="margin-bottom: 1rem; padding: 0.75rem; background: #161b22; border-radius: 6px; white-space: pre-wrap;">' + escapeHtml(data.report) + '</div>' : '') +
                    (data.log ? '<div style="padding: 0.75rem; background: #0d1117; border-radius: 6px; overflow-x: auto;"><pre style="margin: 0; white-space: pre-wrap; word-break: break-all;">' + escapeHtml(data.log.substring(0, 5000)) + (data.log.length > 5000 ? "\n\n... (日志已截断)" : "") + '</pre></div>' : '<div style="color: #8b949e;">暂无详细日志</div>') +
                '</div>';
                
                const win = window.open('', '_blank', 'width=800,height=600');
                win.document.write('<!DOCTYPE html><html><head><title>Review Report - PR #' + number + '</title></head><body style="background: #0d1117; color: #c9d1d9; padding: 20px; margin: 0;">' + reportHtml + '</body></html>');
            } catch (error) {
                showToast('查看报告失败: ' + error.message, true);
            }
        }

        // 标记 PR 需要返工
        async function reworkPR(event, number) {
            if (!confirm('确认标记 PR #' + number + ' 需要返工?\n\n这将在飞书通知开发者进行修改。')) {
                return;
            }
            const btn = event && event.target;
            setButtonLoading(btn, true);
            showGlobalLoading('标记返工中...');
            
            try {
                const response = await fetch('/api/rework-pr', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prNumber: number })
                });
                const result = await response.json();
                showToast(result.message);
                await loadReviewTasks();
                await loadPullRequests();
                await loadRunningTasks();
            } catch (error) {
                showToast('标记返工失败: ' + error.message, true);
            } finally {
                setButtonLoading(btn, false);
                hideGlobalLoading();
            }
        }

        (async () => {
            await loadProjects();
            await loadAll();
        })();
        setInterval(loadTasks, 3000);
        setInterval(loadAll, 30000);
        setInterval(updateRunningTimes, 1000);
        
        window.addEventListener('beforeunload', () => {
            if (eventSource) eventSource.close();
        });
    </script>

    <!-- PM Modal -->
    <div id="pm-modal" class="hidden" onclick="if(event.target===this)closePMModal()">
        <div class="w-full max-w-[600px] rounded-xl border border-slate-700 bg-slate-800 p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.3),0_2px_4px_-2px_rgba(0,0,0,0.3)]">
            <h3 class="mb-4 text-xl">✨ 新建 Feature 需求</h3>
            <div class="mb-4">
                <label class="mb-2 block text-sm text-slate-400">标题</label>
                <input id="pm-title" type="text" placeholder="例如：新增任务系统" class="w-full rounded-lg border border-slate-700 bg-slate-900 p-2 text-[0.9375rem] text-slate-100 outline-none">
            </div>
            <div class="mb-6">
                <label class="mb-2 block text-sm text-slate-400">描述</label>
                <textarea id="pm-desc" rows="5" placeholder="描述业务背景、目标用户、核心场景..." class="w-full resize-y rounded-lg border border-slate-700 bg-slate-900 p-2 text-[0.9375rem] text-slate-100 outline-none"></textarea>
            </div>
            <div class="flex justify-end gap-2">
                <button onclick="closePMModal()" class="cursor-pointer rounded-lg border border-slate-700 bg-slate-900 px-4 py-2 text-slate-100">取消</button>
                <button class="primary cursor-pointer rounded-lg px-4 py-2" onclick="startPM()">开始产出 PRD</button>
            </div>
        </div>
    </div>

    <!-- Design Preview -->
    <div id="" class="fixed inset-0 z-[1600] hidden items-center justify-center bg-slate-900/90 p-4 backdrop-blur-sm" onclick="if(event.target===this)closeDesignViewer()">
        <div class="flex h-[90vh] w-full max-w-[1400px] overflow-hidden rounded-xl border border-slate-700 bg-slate-800 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)]">
            <div class="flex w-80 flex-col border-r border-slate-700 bg-slate-900">
                <div class="-header border-b border-slate-700 p-4 font-semibold">🎨 设计资产</div>
                <div id="" class="flex-1 overflow-y-auto p-2"></div>
            </div>
            <div class="flex flex-1 flex-col">
                <div class="flex items-center justify-between border-b border-slate-700 px-4 py-3.5">
                    <span id="">选择文件</span>
                    <div class="flex gap-2">
                        <button class="cursor-pointer rounded-md border border-slate-700 bg-transparent px-2.5 py-1 text-xs text-slate-400 hover:bg-slate-700 hover:text-slate-100" onclick="closeDesignViewer()">✕</button>
                    </div>
                </div>
                <div id="" class="flex flex-1 items-center justify-center overflow-auto bg-[#0b1120] p-4">
                    <div class="px-4 py-12 text-center text-sm text-slate-400">选择左侧文件预览</div>
                </div>
            </div>
        </div>
    </div>
    <!-- Tailwind 扫描占位符 -->
    <div class="hidden after:content-['_▶'] after:content-['_▼'] after:text-[0.6rem]"></div>
</body>
</html>

