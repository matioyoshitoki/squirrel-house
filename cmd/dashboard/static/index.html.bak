            document.getElementById('pm-desc').value = '';
        }
        async function startPM() {
            const titleInput = document.getElementById('pm-title');
            const descInput = document.getElementById('pm-desc');
            const title = titleInput.value.trim();
            const desc = descInput.value.trim();
            if (!title) {
                showToast('请输入需求标题', true);
                return;
            }
            const btn = document.querySelector('#pm-modal button.primary');
            setButtonLoading(btn, true);
            showGlobalLoading('创建 Issue 并启动 PRD 产出...');
            try {
                const response = await fetch('/api/start-pm', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: title, description: desc })
                });
                const result = await response.json();
                if (!response.ok) throw new Error(result.error || 'Unknown error');
                showToast(result.message);
                closePMModal();
                await loadRunningTasks();
                setTimeout(() => {
                    const task = runningTasksData.find(t => t.targetId === result.issueNumber);
                    if (task) {
                        openLogTerminalByFile(task.logFile);
                    }
                }, 2000);
            } catch (error) {
                showToast('启动失败: ' + error.message, true);
            } finally {
                setButtonLoading(btn, false);
                hideGlobalLoading();
            }
        }

