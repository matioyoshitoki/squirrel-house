        function getIssueType(labels, title, body) {
            if (!labels || labels.length === 0) {
                // 无标签时，通过标题和正文关键词推断类型
                const text = ((title || '') + ' ' + (body || '')).toLowerCase();
                if (text.includes('bug') || text.includes('fix') || text.includes('修复') || text.includes('崩溃') || text.includes('crash')) return 'bug';
                if (text.includes('perf') || text.includes('性能') || text.includes('优化') || text.includes('slow') || text.includes('memory')) return 'performance';
                if (text.includes('tech debt') || text.includes('refactor') || text.includes('重构') || text.includes('债务')) return 'tech-debt';
                if (text.includes('ui') || text.includes('design') || text.includes('样式') || text.includes('颜色') || text.includes('布局') || text.includes('font') || text.includes('icon')) return 'ui-feedback';
                // 默认推断为 feature（大多数新功能开发无特定标签）
                return 'feature';
            }
            const names = labels.map(l => l.name.toLowerCase());
            const priority = ['bug', 'feature', 'performance', 'tech-debt', 'ui-feedback'];
            for (const t of priority) {
                if (names.includes(t)) return t;
            }
            return 'default';
        }

        function getIssueTypeDisplay(type) {
            switch (type) {
                case 'bug': return { text: '🐛 Bug Fix', className: 'danger' };
                case 'feature': return { text: '🚀 开发', className: 'primary' };
                case 'performance': return { text: '⚡ 性能优化', className: 'warning' };
                case 'tech-debt': return { text: '🔧 技术债务', className: '' };
                case 'ui-feedback': return { text: '🎨 UI 调整', className: 'secondary' };
                default: return { text: '🚀 开发', className: 'primary' };
            }
        }

