en: "123"\n  },\n  query: {\n    "my-key": "my-value"\n  }\n});\n\n```\n\nis the
short version of:\n\n```\nconst { Manager } = require("socket.io-client");\n\nco
nst manager = new Manager("ws://example.com", {\n  reconnectionDelayMax: 10000,\
