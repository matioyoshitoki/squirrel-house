g: true));\n  try {\n    await _repository.saveServerBaseUrl(state.serverBaseUrl
.trim());\n    _dioClient.updateBaseUrl(state.serverBaseUrl.trim());\n    emit(s
tate.copyWith(isSaving: false, saveSuccess: true));\n  } catch (e) {\n    emit(s
tate.copyWith(isSaving: false, saveSuccess: false));\n    rethrow;\n  }\n}\n```\
