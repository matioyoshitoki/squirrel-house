带 `trace_id` 和 `user_id`\n   213\t\n   214\t```typescript\n   215\tthrow new B
usinessException(1000, "参数错误");\n   216\t```\n   217\t\n   218\t## 日志与监
控\n   219\t\n   220\t- 使用 NestJS 内置 `Logger` 或 `nestjs-pino`\n   221\t- 所
有 Controller 入口记录请求日志（通过 `LoggingInterceptor`）\n   222\t- 错误日志
包含 `traceId` 和用户 ID（如可获取）\n   223\t- 使用 `@TraceId()` 装饰器在 Contr
oller 中注入当前请求的 trace ID\n   224\t\n   225\t```typescript\n   226\t@Get()
\n   227\tasync findAll(@TraceId() traceId: string | null) {\n   228\t  this.log
ger.log({ msg: "findAll", trace_id: traceId });\n   229\t}\n   230\t```\n   231\
t\n   232\t## Socket.io Gateway 规范\n   233\t\n   234\t> 参考 [api.md](api.md) 
中的「实时通信契约」章节。后端 Gateway 是事件契约的**提供方**，必须保证事件可被
前端消费。\n   235\t\n   236\t### 事件发射规则\n   237\t\n   238\t1. **Gateway 
文件位置**：`apps/api/src/modules/<module>/<module>.gateway.ts`\n   239\t2. **事
件命名**：`模块名:动作`，如 `match:created`, `message:received`\n   240\t3. **发
射时机**：必须在数据库事务 **commit 成功后** 发射，避免事件到达时数据尚未持久化\
n   241\t\n   242\t   ```typescript\n   243\t   // ✅ 正确：事务成功后发射\n   2
44\t   await this.dataSource.transaction(async (manager) => {\n   245\t     awai
t manager.save(match);\n   246\t     await manager.save(conversation);\n   247\t
  });\n   248\t   this.server.to(roomId).emit("match:created", payload);\n   249
\t\n   250\t   // ❌ 错误：事务未提交就发射，前端查询不到数据\n   251\t   await 
this.dataSource.transaction(async (manager) => {\n   252\t     await manager.sav
e(match);\n   253\t     this.server.to(roomId).emit("match:created", payload); /
/ 数据可能还未写入\n   254\t   });\n   255\t   ```\n   256\t\n   257\t4. **Paylo
ad 类型**：必须使用 `shared-types` 中定义的 DTO/Interface，禁止内联 `any`\n   25
8\t\n   259\t   ```typescript\n   260\t   // ✅ 正确\n   261\t   import { MatchC
reatedEvent } from "@social-world/shared-types";\n   262\t   this.server.to(room
Id).emit("match:created", matchCreatedEvent);\n   263\t\n   264\t   // ❌ 错误\n
  265\t   this.server.to(roomId).emit("match:created", { match_id: "..." } as an
y);\n   266\t   ```\n   267\t\n   268\t### Gateway 与模块的耦合规则\n   269\t\n 
 270\t| 场景               | 规范                                               
          |\n   271\t| ------------------ | ------------------------------------
------------------------- |\n   272\t| 事件属于哪个业务域 | Gateway 就放在哪个模
块下                                      |\n   273\t| 跨模块事件发射     | 通过
`EventEmitter2` 解耦，禁止直接 import 其他模块的 Gateway |\n   274\t| 认证      
        | Socket.io 连接时必须验证 JWT Token，拒绝未认证连接            |\n   27
5\t\n   276\t### WebSocket Gateway 必须显式注册 ValidationPipe\n   277\t\n   278
\t**WebSocket Gateway 不会继承 `main.ts` 中通过 `app.useGlobalPipes()` 注册的全
局 `ValidationPipe`**。即使 DTO 上写了 `@IsString()`、`@IsIn()` 等装饰器，Gatewa
y 方法上的 `@MessageBody()` 参数也不会被自动校验。\n   279\t\n   280\t必须在 Gat
eway 类上显式添加 `@UsePipes(new ValidationPipe(...))`：\n   281\t\n   282\t```t
ypescript\n   283\timport { UsePipes, ValidationPipe } from "@nestjs/common";\n 
 284\t\n   285\t@WebSocketGateway({ namespace: "im" })\n   286\t@UsePipes(new Va
lidationPipe({ whitelist: true, transform: true }))\n   287\texport class ImGate
way implements OnGatewayConnection, OnGatewayDisconnect {\n   288\t  // ...\n   
289\t}\n   290\t```\n   291\t\n   292\t### Gateway 认证与 CORS 规范\n   293\t\n 
 294\t1. **JWT 认证必须复用 `JwtService`**：禁止在 Gateway 中直接调用 `jwt.verif
y(token, secret)` 手动校验。应注入项目中统一的 `JwtService`，保持认证逻辑与 `Jwt
AuthGuard` 一致，便于集中处理 Token 刷新、黑名单等逻辑。\n   295\t\n   296\t   `
``typescript\n   297\t   // ❌ 错误：手动调用 jwt.verify，与项目认证体系脱节\n  
298\t   handleConnection(client: Socket) {\n   299\t     const decoded = jwt.ver
ify(token, jwtConfig.secret);\n   300\t   }\n   301\t\n   302\t   // ✅ 正确：注
入 JwtService 复用认证逻辑\n   303\t   constructor(private readonly jwtService: 
JwtService) {}\n   304\t\n   305\t   handleConnection(client: Socket) {\n   306\
t     const decoded = this.jwtService.verify(token);\n   307\t   }\n   308\t   `
``\n   309\t\n   310\t2. **CORS 配置禁止运行时修改内部引擎对象**：通过 `afterIni
t` 将 `server` 强转为 `unknown` 再修改 `engine.opts.cors` 属于非公开 API 的 hack
，Socket.io 版本升级后可能失效。应优先通过 `WebSocketGateway` 构造函数选项或 Nes
tJS 全局 CORS 配置处理跨域。\n   311\t\n   312\t   ```typescript\n   313\t   // 
❌ 错误：运行时 hack 内部引擎配置\n   314\t   afterInit(server: Server) {\n   31
5\t     (server as unknown as any).engine.opts.cors = { origin: \'*\' };\n   316
\t   }\n   317\t\n   318\t   // ✅ 正确：通过装饰器选项声明\n   319\t   @WebSock
etGateway({\n   320\t     namespace: \'im\',\n   321\t     cors: { origin: \'*\'
},\n   322\t   })\n   323\t   export class ImGateway { }\n   324\t   ```\n   325
\t\n   326\t## 原生 SQL 查询约束\n   327\t\n   328\t> 详细规范见 [db.md](db.md) 
的「原生 SQL 查询规范」章节。\n   329\t\n   330\t**NestJS 层级的强制规则**：\n  
331\t\n   332\t1. **Service 层优先使用 Repository API 或 QueryBuilder**。只有 Qu
eryBuilder 无法表达时才降级到原生 SQL。\n   333\t2. **原生 SQL 必须使用 `?` 位置
参数**，禁止 `:paramName`：\n   334\t\n   335\t   ```typescript\n   336\t   // 
✅ 正确（Service 层）\n   337\t   await this.repo.query(\n   338\t     `SELECT *
FROM matches WHERE user_a_id = ? OR user_b_id = ?`,\n   339\t     [userId, userI
d],\n   340\t   );\n   341\t\n   342\t   // ❌ 错误：mysql2 不兼容\n   343\t   a
wait this.repo.query(\n   344\t     `SELECT * FROM matches WHERE user_a_id = :us
erId OR user_b_id = :userId`,\n   345\t     { userId },\n   346\t   );\n   347\t
  ```\n   348\t\n   349\t3. **QueryBuilder 是例外**：QueryBuilder 的 `.where(\'x
= :name\', { name })` 由 TypeORM 内部处理，不受 mysql2 原生占位符限制，**仍然推
荐**。\n   350\t\n   351\t## 跨模块事务与解耦\n   352\t\n   353\t当业务操作需要
同时修改本模块数据和触发其他模块行为时，必须遵循以下规则：\n   354\t\n   355\t##
# 禁止在事务中直接调用其他模块的 Service\n   356\t\n   357\t若 Module A 的 Servi
ce 在 `dataSource.transaction()` 内部直接调用 Module B 的 Service，而 B 的 Servi
ce 使用的是标准 Repository（未绑定事务 `manager`），则 B 的操作**不在同一事务中*
*。事务回滚时，A 的数据被回滚，但 B 的数据仍残留，导致数据不一致。\n   358\t\n  
359\t```typescript\n   360\t// ❌ 错误：MatchingService 在事务中调用 ImService，
system message 不在同一事务\n   361\tawait this.dataSource.transaction(async (ma
nager) => {\n   362\t  await manager.save(match);\n   363\t  await manager.save(
conversation);\n   364\t  // ImService.createSystemMessage() 使用的是 this.messa
geRepo.save()，不走 manager\n   365\t  await this.imService.createSystemMessage(
conversation.id, "...");\n   366\t});\n   367\t```\n   368\t\n   369\t### 推荐方
案\n   370\t\n   371\t**方案 A（事务内操作）**：让被调用方法接受可选的 `EntityMa
nager`，在事务内统一使用 `manager.getRepository()`：\n   372\t\n   373\t```types
cript\n   374\t// im.service.ts\n   375\tasync createSystemMessage(\n   376\t  c
onversationId: string,\n   377\t  content: string,\n   378\t  manager?: EntityMa
nager,\n   379\t): Promise<MessageEntity> {\n   380\t  const repo = manager ? ma
nager.getRepository(MessageEntity) : this.messageRepo;\n   381\t  const message 
= repo.create({ conversationId, content, type: \'system\' });\n   382\t  return 
repo.save(message);\n   383\t}\n   384\t\n   385\t// matching.service.ts\n   386
\tawait this.dataSource.transaction(async (manager) => {\n   387\t  await manage
r.save(match);\n   388\t  await manager.save(conversation);\n   389\t  await thi
s.imService.createSystemMessage(conversation.id, \'...\', manager);\n   390\t});
\n   391\t```\n   392\t\n   393\t**方案 B（事务后事件解耦）**：事务提交成功后，
通过 `EventEmitter2` 发布事件，由监听方在独立事务中处理：\n   394\t\n   395\t```
typescript\n   396\t// matching.service.ts\n   397\tawait this.dataSource.transa
ction(async (manager) => {\n   398\t  await manager.save(match);\n   399\t  awai
t manager.save(conversation);\n   400\t});\n   401\t// 事务已提交，再发射事件\n 
 402\tthis.eventEmitter.emit(\'match:created\', { matchId: match.id, conversatio
nId: conversation.id });\n   403\t\n   404\t// im.module.ts 中监听\n   405\t@OnE
vent(\'match:created\')\n   406\tasync handleMatchCreated(payload: MatchCreatedE
vent) {\n   407\t  await this.imService.createSystemMessage(payload.conversation
Id, \'你们已匹配成功，开始聊天吧\');\n   408\t}\n   409\t```\n   410\t\n   411\t
> **原则**：优先使用方案 B 降低模块耦合；只有强一致性要求（如原子性必须包含 mess
age 创建）时才使用方案 A。\n   412\t\n   413\t### 跨模块共享资源（Redis、数据库
连接池）\n   414\t\n   415\t各业务模块禁止自行 `new Redis()` 创建独立的 Redis 客
户端。重复创建会导致连接数翻倍、资源浪费，且配置分散难以维护。\n   416\t\n   417
\t```typescript\n   418\t// ❌ 错误：ImModule 和 MatchingModule 各自创建 Redis 
实例\n   419\t// im.module.ts\n   420\t{ provide: \'REDIS_CLIENT\', useValue: ne
w Redis(redisConfig) }\n   421\t\n   422\t// matching.module.ts\n   423\t{ provi
de: \'REDIS_CLIENT\', useValue: new Redis(redisConfig) }\n   424\t```\n   425\t\
n   426\t**推荐方案**：在 `AppModule` 或 `CommonModule` 中统一提供单例 Redis 客
户端，各业务模块通过 `imports` 共享：\n   427\t\n   428\t```typescript\n   429\t
// common/redis.module.ts\n   430\t@Module({\n   431\t  providers: [\n   432\t  
 { provide: "REDIS_CLIENT", useFactory: () => new Redis(redisConfig) },\n   433\
t  ],\n   434\t  exports: ["REDIS_CLIENT"],\n   435\t})\n   436\texport class Re
disModule {}\n   437\t\n   438\t// im.module.ts\n   439\t@Module({\n   440\t  im
ports: [RedisModule],\n   441\t  providers: [ImService],\n   442\t})\n   443\tex
port class ImModule {}\n   444\t```\n   445\t\n   446\t> **原则**：Redis、数据库
连接池、HTTP Agent 等昂贵资源必须在 `AppModule` / `CommonModule` 中单例化，业务
模块只消费不创建。\n   447\t\n   448\t## 通用中间件注册（main.ts）\n   449\t\n  
450\t```typescript\n   451\tapp.setGlobalPrefix("api/v1");\n   452\tapp.useGloba
lPipes(new ValidationPipe({ whitelist: true, transform: true }));\n   453\tapp.u
seGlobalInterceptors(new LoggingInterceptor());\n   454\tapp.useGlobalFilters(ne
w AllExceptionsFilter());\n   455\t```\n',
