wLikeBadge: event.action == SwipeAction.like,\n    showPassBadge: event.action =
= SwipeAction.pass,\n  );\n  emit(MatchingSwipeInProgress(\n    cards: currentSt
ate.cards,  // 原始列表\n    targetId: event.targetId,\n    action: event.action
