n.ts`\n   280\t- 生成命令：`npm run migration:generate -- -n Description`\n   28
1\t- 运行命令：`npm run migration:run`\n   282\t- **Agent 修改 Entity 后，必须同
时生成并提交 Migration 文件**\n   283\t\n   284\t## 错误处理\n   285\t\n   286\t
- 业务异常统一抛出 `BusinessException`（继承 `HttpException`）\n   287\t- 全局异
常过滤器 `AllExceptionsFilter` 统一格式化响应体（符合 [api.md](api.md) 中的 `cod
e/message/data` 结构）\n   288\t- 未捕获异常自动上报 Sentry，并携带 `trace_id` 
和 `user_id`\n   289\t\n   290\t```typescript\n   291\tthrow new BusinessExcepti
on(1000, "参数错误");\n   292\t```\n   293\t\n   294\t## 日志与监控\n   295\t\n 
 296\t- 使用 NestJS 内置 `Logger` 或 `nestjs-pino`\n   297\t- 所有 Controller 入
口记录请求日志（通过 `LoggingInterceptor`）\n   298\t- 错误日志包含 `traceId` 和
用户 ID（如可获取）\n   299\t- 使用 `@TraceId()` 装饰器在 Controller 中注入当前
请求的 trace ID\n   300\t\n   301\t```typescript\n   302\t@Get()\n   303\tasync 
findAll(@TraceId() traceId: string | null) {\n   304\t  this.logger.log({ msg: "
findAll", trace_id: traceId });\n   305\t}\n   306\t```\n   307\t\n   308\t## So
cket.io Gateway 规范\n   309\t\n   310\t> 参考 [api.md](api.md) 中的「实时通信契
约」章节。后端 Gateway 是事件契约的**提供方**，必须保证事件可被前端消费。\n   31
1\t\n   312\t### 事件发射规则\n   313\t\n   314\t1. **Gateway 文件位置**：`apps/
api/src/modules/<module>/<module>.gateway.ts`\n   315\t2. **事件命名**：`模块名:
动作`，如 `match:created`, `message:received`\n   316\t3. **发射时机**：必须在数
据库事务 **commit 成功后** 发射，避免事件到达时数据尚未持久化\n   317\t\n   318\
t   ```typescript\n   319\t   // ✅ 正确：事务成功后发射\n   320\t   await this.
dataSource.transaction(async (manager) => {\n   321\t     await manager.save(mat
ch);\n   322\t     await manager.save(conversation);\n   323\t   });\n   324\t  
this.server.to(roomId).emit("match:created", payload);\n   325\t\n   326\t   // 
❌ 错误：事务未提交就发射，前端查询不到数据\n   327\t   await this.dataSource.tr
ansaction(async (manager) => {\n   328\t     await manager.save(match);\n   329\
t     this.server.to(roomId).emit("match:created", payload); // 数据可能还未写入
\n   330\t   });\n   331\t   ```\n   332\t\n   333\t4. **Payload 类型**：必须使
用 `shared-types` 中定义的 DTO/Interface，禁止内联 `any`\n   334\t\n   335\t   `
``typescript\n   336\t   // ✅ 正确\n   337\t   import { MatchCreatedEvent } fro
m "@social-world/shared-types";\n   338\t   this.server.to(roomId).emit("match:c
reated", matchCreatedEvent);\n   339\t\n   340\t   // ❌ 错误\n   341\t   this.s
erver.to(roomId).emit("match:created", { match_id: "..." } as any);\n   342\t   
```\n   343\t\n   344\t### Gateway 与模块的耦合规则\n   345\t\n   346\t| 场景   
           | 规范                                                          |\n  
347\t| ------------------ | ----------------------------------------------------
--------- |\n   348\t| 事件属于哪个业务域 | Gateway 就放在哪个模块下            
                         |\n   349\t| 跨模块事件发射     | 通过 `EventEmitter2` 
解耦，禁止直接 import 其他模块的 Gateway |\n   350\t| 认证               | Socke
t.io 连接时必须验证 JWT Token，拒绝未认证连接            |\n   351\t\n   352\t##
# WebSocket Gateway 必须显式注册 ValidationPipe\n   353\t\n   354\t**WebSocket G
ateway 不会继承 `main.ts` 中通过 `app.useGlobalPipes()` 注册的全局 `ValidationPi
pe`**。即使 DTO 上写了 `@IsString()`、`@IsIn()` 等装饰器，Gateway 方法上的 `@Mes
sageBody()` 参数也不会被自动校验。\n   355\t\n   356\t必须在 Gateway 类上显式添
加 `@UsePipes(new ValidationPipe(...))`：\n   357\t\n   358\t```typescript\n   3
59\timport { UsePipes, ValidationPipe } from "@nestjs/common";\n   360\t\n   361
\t@WebSocketGateway({ namespace: "im" })\n   362\t@UsePipes(new ValidationPipe({
whitelist: true, transform: true }))\n   363\texport class ImGateway implements 
OnGatewayConnection, OnGatewayDisconnect {\n   364\t  // ...\n   365\t}\n   366\
t```\n   367\t\n   368\t### Gateway 认证与 CORS 规范\n   369\t\n   370\t1. **JWT
认证必须复用 `JwtService`**：禁止在 Gateway 中直接调用 `jwt.verify(token, secret
)` 手动校验。应注入项目中统一的 `JwtService`，保持认证逻辑与 `JwtAuthGuard` 一致
，便于集中处理 Token 刷新、黑名单等逻辑。\n   371\t\n   372\t   ```typescript\n 
 373\t   // ❌ 错误：手动调用 jwt.verify，与项目认证体系脱节\n   374\t   handleC
onnection(client: Socket) {\n   375\t     const decoded = jwt.verify(token, jwtC
onfig.secret);\n   376\t   }\n   377\t\n   378\t   // ✅ 正确：注入 JwtService 
复用认证逻辑\n   379\t   constructor(private readonly jwtService: JwtService) {}
\n   380\t\n   381\t   handleConnection(client: Socket) {\n   382\t     const de
coded = this.jwtService.verify(token);\n   383\t   }\n   384\t   ```\n   385\t\n
  386\t2. **CORS 配置禁止运行时修改内部引擎对象**：通过 `afterInit` 将 `server` 
强转为 `unknown` 再修改 `engine.opts.cors` 属于非公开 API 的 hack，Socket.io 版
本升级后可能失效。应优先通过 `WebSocketGateway` 构造函数选项或 NestJS 全局 CORS 
配置处理跨域。\n   387\t\n   388\t   ```typescript\n   389\t   // ❌ 错误：运行
时 hack 内部引擎配置\n   390\t   afterInit(server: Server) {\n   391\t     (serv
er as unknown as any).engine.opts.cors = { origin: \'*\' };\n   392\t   }\n   39
3\t\n   394\t   // ✅ 正确：通过装饰器选项声明\n   395\t   @WebSocketGateway({\n
  396\t     namespace: \'im\',\n   397\t     cors: { origin: \'*\' },\n   398\t 
 })\n   399\t   export class ImGateway { }\n   400\t   ```\n   401\t\n   402\t##
原生 SQL 查询约束\n   403\t\n   404\t> 详细规范见 [db.md](db.md) 的「原生 SQL 查
询规范」章节。\n   405\t\n   406\t**NestJS 层级的强制规则**：\n   407\t\n   408\
t1. **Service 层优先使用 Repository API 或 QueryBuilder**。只有 QueryBuilder 无
法表达时才降级到原生 SQL。\n   409\t2. **原生 SQL 必须使用 `?` 位置参数**，禁止 
`:paramName`：\n   410\t\n   411\t   ```typescript\n   412\t   // ✅ 正确（Servi
ce 层）\n   413\t   await this.repo.query(\n   414\t     `SELECT * FROM matches 
WHERE user_a_id = ? OR user_b_id = ?`,\n   415\t     [userId, userId],\n   416\t
  );\n   417\t\n   418\t   // ❌ 错误：mysql2 不兼容\n   419\t   await this.repo
.query(\n   420\t     `SELECT * FROM matches WHERE user_a_id = :userId OR user_b
_id = :userId`,\n   421\t     { userId },\n   422\t   );\n   423\t   ```\n   424
\t\n   425\t3. **QueryBuilder 是例外**：QueryBuilder 的 `.where(\'x = :name\', {
name })` 由 TypeORM 内部处理，不受 mysql2 原生占位符限制，**仍然推荐**。\n   426
\t\n   427\t## 跨模块事务与解耦\n   428\t\n   429\t当业务操作需要同时修改本模块
数据和触发其他模块行为时，必须遵循以下规则：\n   430\t\n   431\t### 禁止在事务中
直接调用其他模块的 Service\n   432\t\n   433\t若 Module A 的 Service 在 `dataSou
rce.transaction()` 内部直接调用 Module B 的 Service，而 B 的 Service 使用的是标
准 Repository（未绑定事务 `manager`），则 B 的操作**不在同一事务中**。事务回滚时
，A 的数据被回滚，但 B 的数据仍残留，导致数据不一致。\n   434\t\n   435\t```type
script\n   436\t// ❌ 错误：MatchingService 在事务中调用 ImService，system messa
ge 不在同一事务\n   437\tawait this.dataSource.transaction(async (manager) => {\
n   438\t  await manager.save(match);\n   439\t  await manager.save(conversation
);\n   440\t  // ImService.createSystemMessage() 使用的是 this.messageRepo.save(
)，不走 manager\n   441\t  await this.imService.createSystemMessage(conversation
.id, "...");\n   442\t});\n   443\t```\n   444\t\n   445\t### 推荐方案\n   446\t
\n   447\t**方案 A（事务内操作）**：让被调用方法接受可选的 `EntityManager`，在事
务内统一使用 `manager.getRepository()`：\n   448\t\n   449\t```typescript\n   45
0\t// im.service.ts\n   451\tasync createSystemMessage(\n   452\t  conversationI
d: string,\n   453\t  content: string,\n   454\t  manager?: EntityManager,\n   4
55\t): Promise<MessageEntity> {\n   456\t  const repo = manager ? manager.getRep
ository(MessageEntity) : this.messageRepo;\n   457\t  const message = repo.creat
e({ conversationId, content, type: \'system\' });\n   458\t  return repo.save(me
ssage);\n   459\t}\n   460\t\n   461\t// matching.service.ts\n   462\tawait this
.dataSource.transaction(async (manager) => {\n   463\t  await manager.save(match
);\n   464\t  await manager.save(conversation);\n   465\t  await this.imService.
createSystemMessage(conversation.id, \'...\', manager);\n   466\t});\n   467\t``
`\n   468\t\n   469\t**方案 B（事务后事件解耦）**：事务提交成功后，通过 `EventEm
itter2` 发布事件，由监听方在独立事务中处理：\n   470\t\n   471\t```typescript\n 
 472\t// matching.service.ts\n   473\tawait this.dataSource.transaction(async (m
anager) => {\n   474\t  await manager.save(match);\n   475\t  await manager.save
(conversation);\n   476\t});\n   477\t// 事务已提交，再发射事件\n   478\tthis.ev
entEmitter.emit(\'match:created\', { matchId: match.id, conversationId: conversa
tion.id });\n   479\t\n   480\t// im.module.ts 中监听\n   481\t@OnEvent(\'match:
created\')\n   482\tasync handleMatchCreated(payload: MatchCreatedEvent) {\n   4
83\t  await this.imService.createSystemMessage(payload.conversationId, \'你们已
匹配成功，开始聊天吧\');\n   484\t}\n   485\t```\n   486\t\n   487\t> **原则**：
优先使用方案 B 降低模块耦合；只有强一致性要求（如原子性必须包含 message 创建）时
才使用方案 A。\n   488\t\n   489\t### 数据库事务与 Redis 的边界\n   490\t\n   49
1\tRedis 等非数据库操作**不得**放在数据库事务（`dataSource.transaction`）内部执
行。原因：\n   492\t\n   493\t1. Redis 不支持参与数据库的两阶段提交，事务回滚时 
Redis 操作无法回滚，导致数据不一致\n   494\t2. Redis 操作可能因网络延迟拖长数据
库事务持有时间，增加锁竞争和连接池压力\n   495\t\n   496\t```typescript\n   497\
t// ❌ 错误：Redis incr 在事务内执行，DB 回滚后 Redis 未读数无法回滚\n   498\taw
ait this.dataSource.transaction(async (manager) => {\n   499\t  await manager.sa
ve(message);\n   500\t  await this.redisClient.incr(`unread_count:${userId}:${co
nversationId}`); // 无法回滚\n   501\t  await manager.save(conversation);\n   50
2\t});\n   503\t\n   504\t// ✅ 正确：Redis 操作在事务提交成功后执行\n   505\taw
ait this.dataSource.transaction(async (manager) => {\n   506\t  await manager.sa
ve(message);\n   507\t  await manager.save(conversation);\n   508\t});\n   509\t
// 事务已提交，再更新 Redis\n   510\tawait this.redisClient.incr(`unread_count:$
{userId}:${conversationId}`);\n   511\t```\n   512\t\n   513\t> **原则**：事务内
只做数据库操作；事务提交成功后，再执行 Redis、消息队列、事件发射等副作用。若 Red
is 失败，应记录降级日志并预留后台补偿机制（如定时任务重新计算未读数）。\n   514\
t\n   515\t### 跨模块共享资源（Redis、数据库连接池）\n   516\t\n   517\t各业务模
块禁止自行 `new Redis()` 创建独立的 Redis 客户端。重复创建会导致连接数翻倍、资源
浪费，且配置分散难以维护。\n   518\t\n   519\t```typescript\n   520\t// ❌ 错误
：ImModule 和 MatchingModule 各自创建 Redis 实例\n   521\t// im.module.ts\n   52
2\t{ provide: \'REDIS_CLIENT\', useValue: new Redis(redisConfig) }\n   523\t\n  
524\t// matching.module.ts\n   525\t{ provide: \'REDIS_CLIENT\', useValue: new R
edis(redisConfig) }\n   526\t```\n   527\t\n   528\t**推荐方案**：在 `AppModule`
或 `CommonModule` 中统一提供单例 Redis 客户端，各业务模块通过 `imports` 共享：\n
  529\t\n   530\t```typescript\n   531\t// common/redis.module.ts\n   532\t@Modu
le({\n   533\t  providers: [\n   534\t    { provide: "REDIS_CLIENT", useFactory:
() => new Redis(redisConfig) },\n   535\t  ],\n   536\t  exports: ["REDIS_CLIENT
"],\n   537\t})\n   538\texport class RedisModule {}\n   539\t\n   540\t// im.mo
dule.ts\n   541\t@Module({\n   542\t  imports: [RedisModule],\n   543\t  provide
rs: [ImService],\n   544\t})\n   545\texport class ImModule {}\n   546\t```\n   
547\t\n   548\t> **原则**：Redis、数据库连接池、HTTP Agent 等昂贵资源必须在 `App
Module` / `CommonModule` 中单例化，业务模块只消费不创建。\n   549\t\n   550\t## 
通用中间件注册（main.ts）\n   551\t\n   552\t```typescript\n   553\tapp.setGloba
lPrefix("api/v1");\n   554\tapp.useGlobalPipes(new ValidationPipe({ whitelist: t
rue, transform: true }));\n   555\tapp.useGlobalInterceptors(new LoggingIntercep
tor());\n   556\tapp.useGlobalFilters(new AllExceptionsFilter());\n   557\t```\n
