ientMessageId) {\n    return m.copyWith(id: event.serverMessageId, sequenceId: e
vent.sequenceId, status: \'sent\');\n  }\n  return m;\n}).toList();\n...\nemit(M
essageSent(messages: updatedMessages));\nemit(MessagesLoaded(...));\n```\nSo if 
