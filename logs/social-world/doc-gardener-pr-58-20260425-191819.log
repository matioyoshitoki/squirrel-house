t// ✅ 正确：使用 Query DTO\n   118\t// dto/get-conversations-query.dto.ts\n   1
19\texport class GetConversationsQueryDto {\n   120\t  @IsOptional()\n   121\t  
@IsInt()\n   122\t  @Min(1)\n   123\t  @Max(50)\n   124\t  @Type(() => Number)\n
