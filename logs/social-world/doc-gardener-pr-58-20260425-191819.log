atchCreatedEvent);\n   236\t\n   237\t   // ❌ 错误\n   238\t   this.server.to(r
oomId).emit("match:created", { match_id: "..." } as any);\n   239\t   ```\n   24
0\t\n   241\t### Gateway 与模块的耦合规则\n   242\t\n   243\t| 场景             
 | 规范                                                          |\n   244\t| --
---------------- | -------------------------------------------------------------
|\n   245\t| 事件属于哪个业务域 | Gateway 就放在哪个模块下                      
               |\n   246\t| 跨模块事件发射     | 通过 `EventEmitter2` 解耦，禁止
直接 import 其他模块的 Gateway |\n   247\t| 认证               | Socket.io 连接
时必须验证 JWT Token，拒绝未认证连接            |\n   248\t\n   249\t### WebSock
et Gateway 必须显式注册 ValidationPipe\n   250\t\n   251\t**WebSocket Gateway 不
会继承 `main.ts` 中通过 `app.useGlobalPipes()` 注册的全局 `ValidationPipe`**。即
使 DTO 上写了 `@IsString()`、`@IsIn()` 等装饰器，Gateway 方法上的 `@MessageBody(
)` 参数也不会被自动校验。\n   252\t\n   253\t必须在 Gateway 类上显式添加 `@UsePi
pes(new ValidationPipe(...))`：\n   254\t\n   255\t```typescript\n   256\timport
{ UsePipes, ValidationPipe } from "@nestjs/common";\n   257\t\n   258\t@WebSocke
tGateway({ namespace: "im" })\n   259\t@UsePipes(new ValidationPipe({ whitelist:
true, transform: true }))\n   260\texport class ImGateway implements OnGatewayCo
nnection, OnGatewayDisconnect {\n   261\t  // ...\n   262\t}\n   263\t```\n   26
4\t\n   265\t## 原生 SQL 查询约束\n   266\t\n   267\t> 详细规范见 [db.md](db.md)
的「原生 SQL 查询规范」章节。\n   268\t\n   269\t**NestJS 层级的强制规则**：\n  
270\t\n   271\t1. **Service 层优先使用 Repository API 或 QueryBuilder**。只有 Qu
eryBuilder 无法表达时才降级到原生 SQL。\n   272\t2. **原生 SQL 必须使用 `?` 位置
参数**，禁止 `:paramName`：\n   273\t\n   274\t   ```typescript\n   275\t   // 
✅ 正确（Service 层）\n   276\t   await this.repo.query(\n   277\t     `SELECT *
FROM matches WHERE user_a_id = ? OR user_b_id = ?`,\n   278\t     [userId, userI
d],\n   279\t   );\n   280\t\n   281\t   // ❌ 错误：mysql2 不兼容\n   282\t   a
wait this.repo.query(\n   283\t     `SELECT * FROM matches WHERE user_a_id = :us
erId OR user_b_id = :userId`,\n   284\t     { userId },\n   285\t   );\n   286\t
  ```\n   287\t\n   288\t3. **QueryBuilder 是例外**：QueryBuilder 的 `.where(\'x
= :name\', { name })` 由 TypeORM 内部处理，不受 mysql2 原生占位符限制，**仍然推
荐**。\n   289\t\n   290\t## 跨模块事务与解耦\n   291\t\n   292\t当业务操作需要
同时修改本模块数据和触发其他模块行为时，必须遵循以下规则：\n   293\t\n   294\t##
# 禁止在事务中直接调用其他模块的 Service\n   295\t\n   296\t若 Module A 的 Servi
ce 在 `dataSource.transaction()` 内部直接调用 Module B 的 Service，而 B 的 Servi
ce 使用的是标准 Repository（未绑定事务 `manager`），则 B 的操作**不在同一事务中*
*。事务回滚时，A 的数据被回滚，但 B 的数据仍残留，导致数据不一致。\n   297\t\n  
298\t```typescript\n   299\t// ❌ 错误：MatchingService 在事务中调用 ImService，
system message 不在同一事务\n   300\tawait this.dataSource.transaction(async (ma
nager) => {\n   301\t  await manager.save(match);\n   302\t  await manager.save(
conversation);\n   303\t  // ImService.createSystemMessage() 使用的是 this.messa
geRepo.save()，不走 manager\n   304\t  await this.imService.createSystemMessage(
conversation.id, "...");\n   305\t});\n   306\t```\n   307\t\n   308\t### 推荐方
案\n   309\t\n   310\t**方案 A（事务内操作）**：让被调用方法接受可选的 `EntityMa
nager`，在事务内统一使用 `manager.getRepository()`：\n   311\t\n   312\t```types
cript\n   313\t// im.service.ts\n   314\tasync createSystemMessage(\n   315\t  c
onversationId: string,\n   316\t  content: string,\n   317\t  manager?: EntityMa
nager,\n   318\t): Promise<MessageEntity> {\n   319\t  const repo = manager ? ma
nager.getRepository(MessageEntity) : this.messageRepo;\n   320\t  const message 
= repo.create({ conversationId, content, type: \'system\' });\n   321\t  return 
repo.save(message);\n   322\t}\n   323\t\n   324\t// matching.service.ts\n   325
\tawait this.dataSource.transaction(async (manager) => {\n   326\t  await manage
r.save(match);\n   327\t  await manager.save(conversation);\n   328\t  await thi
s.imService.createSystemMessage(conversation.id, \'...\', manager);\n   329\t});
\n   330\t```\n   331\t\n   332\t**方案 B（事务后事件解耦）**：事务提交成功后，
通过 `EventEmitter2` 发布事件，由监听方在独立事务中处理：\n   333\t\n   334\t```
typescript\n   335\t// matching.service.ts\n   336\tawait this.dataSource.transa
ction(async (manager) => {\n   337\t  await manager.save(match);\n   338\t  awai
t manager.save(conversation);\n   339\t});\n   340\t// 事务已提交，再发射事件\n 
 341\tthis.eventEmitter.emit(\'match:created\', { matchId: match.id, conversatio
nId: conversation.id });\n   342\t\n   343\t// im.module.ts 中监听\n   344\t@OnE
vent(\'match:created\')\n   345\tasync handleMatchCreated(payload: MatchCreatedE
vent) {\n   346\t  await this.imService.createSystemMessage(payload.conversation
Id, \'你们已匹配成功，开始聊天吧\');\n   347\t}\n   348\t```\n   349\t\n   350\t
> **原则**：优先使用方案 B 降低模块耦合；只有强一致性要求（如原子性必须包含 mess
age 创建）时才使用方案 A。\n   351\t\n   352\t### 跨模块共享资源（Redis、数据库
连接池）\n   353\t\n   354\t各业务模块禁止自行 `new Redis()` 创建独立的 Redis 客
户端。重复创建会导致连接数翻倍、资源浪费，且配置分散难以维护。\n   355\t\n   356
\t```typescript\n   357\t// ❌ 错误：ImModule 和 MatchingModule 各自创建 Redis 
实例\n   358\t// im.module.ts\n   359\t{ provide: \'REDIS_CLIENT\', useValue: ne
w Redis(redisConfig) }\n   360\t\n   361\t// matching.module.ts\n   362\t{ provi
de: \'REDIS_CLIENT\', useValue: new Redis(redisConfig) }\n   363\t```\n   364\t\
n   365\t**推荐方案**：在 `AppModule` 或 `CommonModule` 中统一提供单例 Redis 客
户端，各业务模块通过 `imports` 共享：\n   366\t\n   367\t```typescript\n   368\t
