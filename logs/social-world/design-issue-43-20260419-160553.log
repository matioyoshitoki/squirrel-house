/ 年龄\n  final int age;\n\n  /// 距离文本（如 "2.5km"）\n  final String distanc
e;\n\n  /// 活跃时间文本（如 "刚刚活跃"）\n  final String lastActive;\n\n  /// 
个人签名（可为空）\n  final String? bio;\n\n  /// 当前水平拖动偏移量（由外部手势
管理器传入）\n  /// dx > 0 表示向右拖（Like 方向），dx < 0 表示向左拖（Pass 方向
）\n  final double dragOffset;\n\n  /// 是否显示在堆叠顶层（决定阴影和 z-index 
语义）\n  final bool isTop;\n\n  /// 点击卡片时的回调（用于查看详情，V1 可不实现
）\n  final VoidCallback? onTap;\n\n  /// Accessibility identifier（Maestro 定位
用）\n  final String? identifier;\n\n  const SwipeCard({\n    super.key,\n    re
quired this.imageUrl,\n    required this.nickname,\n    required this.age,\n    
required this.distance,\n    required this.lastActive,\n    this.bio,\n    this.
dragOffset = 0,\n    this.isTop = true,\n    this.onTap,\n    this.identifier,\n
 });\n\n  @override\n  Widget build(BuildContext context) {\n    // 实现约束：\n
   // - 尺寸：宽度填充父容器，高度由外部约束（推荐 460pt 总高，图片区 340pt）\n 
  // - 圆角：DesignTokens.radiusLg (16)\n    // - 阴影：仅 isTop 时显示 BoxShado
w(color: Colors.black.withOpacity(0.08), blurRadius: 20, offset: Offset(0, 4))\n
   // - 图片区：ClipRRect 包裹 Image.network(imageUrl)，fallback 到渐变色背景 + 
占位图标\n    // - 信息区：Padding(DesignTokens.spacingMd)，垂直排列\n    //   -
昵称+年龄：TextStyle(fontSize: DesignTokens.fontSizeTitle, fontWeight: FontWeigh
t.bold, color: DesignTokens.textPrimary)\n    //   - 距离·活跃时间：TextStyle(fo
ntSize: 14, color: Color(0xFF49454F)) —— 使用 Theme.of(context).colorScheme.onSu
rfaceVariant\n    //   - 签名：TextStyle(fontSize: 14, color: DesignTokens.textP
rimary.withOpacity(0.6))，最多两行，overflow: ellipsis\n    // - 图片底部到信息
区之间：必须叠加一个渐变遮罩（从透明到半透明黑），确保白色文字在浅色图片上仍可读
\n    //   - LinearGradient(begin: Alignment.topCenter, end: Alignment.bottomCen
ter, colors: [Colors.transparent, Colors.black.withOpacity(0.4)])\n    //   - 该
渐变覆盖图片底部 120pt 区域\n    // - Badge 区：\n    //   - dragOffset > 60 时
，右上角显示 "LIKE" badge（颜色 success，旋转 -15°）\n    //   - dragOffset < -6
0 时，左上角显示 "PASS" badge（颜色 error，旋转 15°）\n    //   - badge 透明度 =
min(|dragOffset| / 120, 1)\n    // - 必须包裹 Semantics(identifier: identifier, 
label: "$nickname, ${age}岁, 距离$distance")\n    return const Placeholder();\n 
}\n}\n```\n\n#### Widgetbook 用例要求\n\n| 用例名 | 状态组合 |\n|--------|------
