tchingMatchCreated(\n      event.matchSummary,\n      previousCards: currentStat
e.cards,\n      previousMode: currentState.mode,\n    ));\n  } else if (currentS
tate is MatchingSwipeInProgress) {\n    emit(MatchingMatchCreated(\n      event.
