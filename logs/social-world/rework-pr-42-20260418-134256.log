: {\n   135\t    "items": [\n   136\t      {\n   137\t        "match_id": "uuid"
,\n   138\t        "conversation_id": "uuid",\n   139\t        "user_id": "uuid"
,\n   140\t        "nickname": "Alice",\n   141\t        "avatar_url": "https://
