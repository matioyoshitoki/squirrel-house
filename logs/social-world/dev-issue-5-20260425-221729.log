nversationList(ctx, uid, req.Page, req.PageSize)\n}\n\nfunc (s *IMService) GetMe
ssageHistory(ctx context.Context, req *apipb.GetMessageHistoryRequest) (*apipb.G
etMessageHistoryResponse, error) {\n\tuid, err := meta.TryLoadUid(ctx)\n\tif err
