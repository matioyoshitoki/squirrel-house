(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn s.imUC.MarkAsRead(c
tx, uid, req)\n}\n```\n\n---\n\n## 8. WebSocket 实时推送集成\n\n### `internal/se
rvice/wapi/im_ws_handler.go`\n\n```go\npackage wapi\n\nimport (\n\t"context"\n\t
"fmt"\n\t"strconv"\n\n\tapipb "new-world/api/new-world-api/v1"\n\twwspb "new-wor
ld/api/new-world-ws/v1"\n\tsharedpb "new-world/api/shared/v1"\n\t"new-world/inte
rnal/biz"\n\t"new-world/pkg/worldgrpc"\n\n\t"github.com/go-kratos/kratos/v2/log"
\n\t"google.golang.org/protobuf/proto"\n)\n\nconst (\n\tIMMessageType      = "im
.message"\n\tIMReadReceiptType  = "im.read_receipt"\n)\n\ntype IMWsPushHandler s
truct {\n\twwsHandler *biz.WwsHandler\n\tlog        *log.Helper\n}\n\nfunc NewIM
WsPushHandler(wwsHandler *biz.WwsHandler, logger log.Logger) *IMWsPushHandler {\
n\treturn &IMWsPushHandler{\n\t\twwsHandler: wwsHandler,\n\t\tlog:        log.Ne
wHelper(logger),\n\t}\n}\n\n// PushMessage 推送新消息给接收者\nfunc (h *IMWsPush
Handler) PushMessage(ctx context.Context, uid int64, msg *apipb.IMMessageContent
) error {\n\tbody, err := proto.Marshal(msg)\n\tif err != nil {\n\t\treturn err\
n\t}\n\n\treturn h.wwsHandler.Publish(ctx, &wwspb.Message{\n\t\tId:      msg.Mes
sageId,\n\t\tType:    IMMessageType,\n\t\tContentType: sharedpb.ContentType_PROT
OBUF,\n\t\tDestination: &wwspb.Destination{\n\t\t\tType:   wwspb.Destination_Use
r,\n\t\t\tValues: []string{strconv.FormatInt(uid, 10)},\n\t\t},\n\t\tBody: body,
\n\t})\n}\n\n// PushReadReceipt 推送已读回执给发送者\nfunc (h *IMWsPushHandler) 
PushReadReceipt(ctx context.Context, uid int64, conversationID string, messageID
s []string) error {\n\ttype readReceiptPayload struct {\n\t\tConversationID stri
ng   `json:"conversation_id"`\n\t\tMessageIDs     []string `json:"message_ids"`\
n\t}\n\n\tpayload := &readReceiptPayload{\n\t\tConversationID: conversationID,\n
\t\tMessageIDs:     messageIDs,\n\t}\n\n\t// 使用 JSON 或 Protobuf 均可；这里示
例用 JSON 便于前端调试\n\tbody, err := json.Marshal(payload)\n\tif err != nil {\
n\t\treturn err\n\t}\n\n\treturn h.wwsHandler.Publish(ctx, &wwspb.Message{\n\t\t
Id:      fmt.Sprintf("read_%s_%d", conversationID, uid),\n\t\tType:    IMReadRec
eiptType,\n\t\tContentType: sharedpb.ContentType_JSON_TEXT,\n\t\tDestination: &w
wspb.Destination{\n\t\t\tType:   wwspb.Destination_User,\n\t\t\tValues: []string
{strconv.FormatInt(uid, 10)},\n\t\t},\n\t\tBody: body,\n\t})\n}\n\n// 确保 IMWsP
ushHandler 实现 biz.IMPusher 接口\nvar _ wapi.IMPusher = (*IMWsPushHandler)(nil)
\n```\n\n**说明**: 推送复用现有 `biz.WwsHandler.Publish()` 方法，通过 `Destinati
on_User` 将消息路由到目标用户的 WebSocket 连接。用户上线时已在 `WwsHandler.OnOpe
n0` 中自动订阅 `worldgrpc.UserChannel(uid)`，因此 IM 消息可直接送达。\n\n---\n\n
