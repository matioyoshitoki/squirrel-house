   string\n\tMessageType    int32\n\tStatus         int32\n\tSentAt         int6
4\n\tCreatedAt      int64\n\tUpdatedAt      int64\n}\n\n// ReadReceipt 已读回执
实体\ntype ReadReceipt struct {\n\tID        int64\n\tMessageID string\n\tReader
ID  string\n\tReadAt    int64\n\tCreatedAt int64\n}\n\n// IMRepo IM 仓库接口\nty
pe IMRepo interface {\n\t// Conversation 相关\n\tCreateOrGetConversation(ctx con
text.Context, participantA, participantB string) (*Conversation, error)\n\tGetCo
nversationList(ctx context.Context, participant string, page, pageSize int32) ([
]*Conversation, int32, error)\n\tUpdateConversationLastMessage(ctx context.Conte
xt, conversationID, messageID, content string, sentAt int64) error\n\tIncrUnread
Count(ctx context.Context, conversationID string, targetParticipant string) erro
r\n\tClearUnreadCount(ctx context.Context, conversationID string, targetParticip
ant string) error\n\n\t// Message 相关\n\tCreateMessage(ctx context.Context, msg
*IMMessage) error\n\tGetMessageHistory(ctx context.Context, conversationID strin
g, beforeMessageID string, pageSize int32) ([]*IMMessage, bool, error)\n\tGetMes
sagesByIDs(ctx context.Context, messageIDs []string) ([]*IMMessage, error)\n\n\t
// ReadReceipt 相关\n\tBatchCreateReadReceipts(ctx context.Context, receipts []*
ReadReceipt) error\n\tGetReadReceiptsByMessageIDs(ctx context.Context, messageID
s []string) (map[string][]string, error)\n}\n```\n\n---\n\n## 5. Biz 业务用例层\
n\n### `internal/biz/wapi/im.go`\n\n```go\npackage wapi\n\nimport (\n\t"context"
\n\t"fmt"\n\t"time"\n\n\tapipb "new-world/api/new-world-api/v1"\n\t"new-world/in
ternal/biz/repo"\n\t"new-world/pkg/consts/biz_error"\n\t"new-world/pkg/utils/idg
en"\n\n\t"github.com/go-kratos/kratos/v2/log"\n)\n\ntype IMPusher interface {\n\
tPushMessage(ctx context.Context, uid int64, msg *apipb.IMMessageContent) error\
n\tPushReadReceipt(ctx context.Context, uid int64, conversationID string, messag
eIDs []string) error\n}\n\ntype IMUseCase struct {\n\timRepo   repo.IMRepo\n\tus
erRepo repo.UserRepo\n\tpusher   IMPusher\n\tidGen    repo.IdGen\n\tlog      *lo
g.Helper\n}\n\nfunc NewIMUseCase(\n\timRepo repo.IMRepo,\n\tuserRepo repo.UserRe
po,\n\tpusher IMPusher,\n\tidGen repo.IdGen,\n\tlogger log.Logger,\n) *IMUseCase
{\n\treturn &IMUseCase{\n\t\timRepo:   imRepo,\n\t\tuserRepo: userRepo,\n\t\tpus
her:   pusher,\n\t\tidGen:    idGen,\n\t\tlog:      log.NewHelper(logger),\n\t}\
n}\n\nfunc (uc *IMUseCase) nowMs() int64 {\n\treturn time.Now().UnixMilli()\n}\n
\n// SendMessage 发送消息\nfunc (uc *IMUseCase) SendMessage(ctx context.Context,
senderID int64, req *apipb.SendMessageRequest) (*apipb.IMMessageContent, error) 
{\n\t// 1. 获取或创建会话\n\tsenderStr := fmt.Sprintf("%d", senderID)\n\tconv, e
rr := uc.imRepo.CreateOrGetConversation(ctx, senderStr, req.ReceiverId)\n\tif er
r != nil {\n\t\treturn nil, err\n\t}\n\n\t// 2. 生成消息\n\tmsgID := fmt.Sprintf
("%d", uc.idGen.GenInt64())\n\tnow := uc.nowMs()\n\tmsg := &repo.IMMessage{\n\t\
tMessageID:      msgID,\n\t\tConversationID: conv.ConversationID,\n\t\tSenderID:
      senderStr,\n\t\tReceiverID:     req.ReceiverId,\n\t\tContent:        req.C
ontent,\n\t\tMessageType:    int32(req.MessageType),\n\t\tStatus:         1,\n\t
\tSentAt:         now,\n\t\tCreatedAt:      now,\n\t\tUpdatedAt:      now,\n\t}\
n\n\t// 3. 持久化消息 + 更新会话 + 增加未读数（事务）\n\tif err := uc.imRepo.Cre
ateMessage(ctx, msg); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := uc.imR
epo.UpdateConversationLastMessage(ctx, conv.ConversationID, msgID, req.Content, 
now); err != nil {\n\t\tuc.log.Warnw("update conversation last message failed", 
"error", err)\n\t}\n\tif err := uc.imRepo.IncrUnreadCount(ctx, conv.Conversation
ID, req.ReceiverId); err != nil {\n\t\tuc.log.Warnw("incr unread count failed", 
"error", err)\n\t}\n\n\t// 4. 获取发送者名称\n\tsenderName := senderStr\n\tif us
er, err := uc.userRepo.FindOne(ctx, senderID); err == nil && user != nil {\n\t\t
senderName = fmt.Sprintf("%s#%s", user.Name, user.Code)\n\t}\n\n\tresp := &apipb
.IMMessageContent{\n\t\tMessageId:      msgID,\n\t\tConversationId: conv.Convers
ationID,\n\t\tSenderId:       senderStr,\n\t\tSenderName:     senderName,\n\t\tR
eceiverId:     req.ReceiverId,\n\t\tContent:        req.Content,\n\t\tMessageTyp
e:    req.MessageType,\n\t\tSentAt:         now,\n\t\tIsRead:         false,\n\t
}\n\n\t// 5. WebSocket 实时推送给接收者\n\treceiverUID, _ := fmt.Sscanf(req.Rece
iverId, "%d", &receiverUID)\n\t// 更安全的解析方式\n\tvar ruid int64\n\tfmt.Ssca
nf(req.ReceiverId, "%d", &ruid)\n\tif ruid > 0 {\n\t\tif err := uc.pusher.PushMe
ssage(ctx, ruid, resp); err != nil {\n\t\t\tuc.log.Warnw("push message failed", 
"error", err, "receiver", req.ReceiverId)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n
\n// GetConversationList 获取会话列表\nfunc (uc *IMUseCase) GetConversationList(
ctx context.Context, uid int64, page, pageSize int32) (*apipb.GetConversationLis
tResponse, error) {\n\tif page < 1 {\n\t\tpage = 1\n\t}\n\tif pageSize < 1 || pa
geSize > 50 {\n\t\tpageSize = 20\n\t}\n\n\tconversations, totalPage, err := uc.i
mRepo.GetConversationList(ctx, fmt.Sprintf("%d", uid), page, pageSize)\n\tif err
!= nil {\n\t\treturn nil, err\n\t}\n\n\tlist := make([]*apipb.ConversationInfo, 
len(conversations))\n\tfor i, c := range conversations {\n\t\t// 确定对方信息\n\
t\totherID := c.ParticipantA\n\t\tif otherID == fmt.Sprintf("%d", uid) {\n\t\t\t
otherID = c.ParticipantB\n\t\t}\n\n\t\t// 确定未读数\n\t\tunreadCount := c.Unrea
dCountA\n\t\tif fmt.Sprintf("%d", uid) == c.ParticipantA {\n\t\t\tunreadCount = 
c.UnreadCountA\n\t\t} else {\n\t\t\tunreadCount = c.UnreadCountB\n\t\t}\n\n\t\to
therName := otherID\n\t\tif otherUID, err := fmt.Sscanf(otherID, "%d", &otherUID
); err == nil && otherUID > 0 {\n\t\t\tif user, err := uc.userRepo.FindOne(ctx, 
int64(otherUID)); err == nil && user != nil {\n\t\t\t\totherName = fmt.Sprintf("
%s#%s", user.Name, user.Code)\n\t\t\t}\n\t\t}\n\n\t\tlist[i] = &apipb.Conversati
onInfo{\n\t\t\tConversationId:     c.ConversationID,\n\t\t\tParticipantId:      
otherID,\n\t\t\tParticipantName:    otherName,\n\t\t\tLastMessageId:      c.Last
MessageID,\n\t\t\tLastMessageContent: c.LastMessageContent,\n\t\t\tLastMessageAt
:      c.LastMessageAt,\n\t\t\tUnreadCount:        unreadCount,\n\t\t}\n\t}\n\n\
treturn &apipb.GetConversationListResponse{\n\t\tList:        list,\n\t\tCurrent
Page: page,\n\t\tPageSize:    pageSize,\n\t\tTotalPage:   totalPage,\n\t}, nil\n
}\n\n// GetMessageHistory 获取消息历史\nfunc (uc *IMUseCase) GetMessageHistory(c
tx context.Context, uid int64, req *apipb.GetMessageHistoryRequest) (*apipb.GetM
essageHistoryResponse, error) {\n\tpageSize := req.PageSize\n\tif pageSize < 1 |
| pageSize > 50 {\n\t\tpageSize = 20\n\t}\n\n\tmessages, hasMore, err := uc.imRe
po.GetMessageHistory(ctx, req.ConversationId, req.BeforeMessageId, pageSize)\n\t
if err != nil {\n\t\treturn nil, err\n\t}\n\n\t// 批量查询已读状态\n\tmsgIDs := 
make([]string, len(messages))\n\tfor i, m := range messages {\n\t\tmsgIDs[i] = m
.MessageID\n\t}\n\treadMap, _ := uc.imRepo.GetReadReceiptsByMessageIDs(ctx, msgI
Ds)\n\n\tuidStr := fmt.Sprintf("%d", uid)\n\trespMessages := make([]*apipb.IMMes
sageContent, len(messages))\n\tfor i, m := range messages {\n\t\tisRead := false
\n\t\tif m.SenderID == uidStr {\n\t\t\t// 自己发的消息，看对方是否已读\n\t\t\tre
aders := readMap[m.MessageID]\n\t\t\tfor _, r := range readers {\n\t\t\t\tif r !
= uidStr {\n\t\t\t\t\tisRead = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} 
else {\n\t\t\t// 对方发的消息，默认已显示即已读（前端调 markAsRead）\n\t\t\tisRe
ad = true\n\t\t}\n\n\t\trespMessages[i] = &apipb.IMMessageContent{\n\t\t\tMessag
eId:      m.MessageID,\n\t\t\tConversationId: m.ConversationID,\n\t\t\tSenderId:
      m.SenderID,\n\t\t\tReceiverId:     m.ReceiverID,\n\t\t\tContent:        m.
Content,\n\t\t\tMessageType:    apipb.IMMessageType(m.MessageType),\n\t\t\tSentA
t:         m.SentAt,\n\t\t\tIsRead:         isRead,\n\t\t}\n\t}\n\n\treturn &api
pb.GetMessageHistoryResponse{\n\t\tMessages: respMessages,\n\t\tHasMore:  hasMor
e,\n\t}, nil\n}\n\n// MarkAsRead 标记已读\nfunc (uc *IMUseCase) MarkAsRead(ctx c
ontext.Context, uid int64, req *apipb.MarkAsReadRequest) (*apipb.MarkAsReadRespo
nse, error) {\n\tif len(req.MessageIds) == 0 {\n\t\treturn &apipb.MarkAsReadResp
onse{ReadCount: 0}, nil\n\t}\n\n\tuidStr := fmt.Sprintf("%d", uid)\n\tnow := uc.
nowMs()\n\n\t// 1. 批量写入已读回执\n\treceipts := make([]*repo.ReadReceipt, 0, 
len(req.MessageIds))\n\tfor _, msgID := range req.MessageIds {\n\t\treceipts = a
ppend(receipts, &repo.ReadReceipt{\n\t\t\tMessageID: msgID,\n\t\t\tReaderID:  ui
dStr,\n\t\t\tReadAt:    now,\n\t\t\tCreatedAt: now,\n\t\t})\n\t}\n\tif err := uc
.imRepo.BatchCreateReadReceipts(ctx, receipts); err != nil {\n\t\tuc.log.Warnw("
batch create read receipts failed", "error", err)\n\t}\n\n\t// 2. 清空该会话未读
数\n\tif err := uc.imRepo.ClearUnreadCount(ctx, req.ConversationId, uidStr); err
!= nil {\n\t\tuc.log.Warnw("clear unread count failed", "error", err)\n\t}\n\n\t
// 3. 推送已读回执给会话中的对方（通过消息中的 sender_id 推断）\n\tmessages, err
:= uc.imRepo.GetMessagesByIDs(ctx, req.MessageIds)\n\tif err != nil {\n\t\tretur
n nil, err\n\t}\n\n\t// 按 sender 分组通知\n\tsenderMap := make(map[string][]str
ing)\n\tfor _, m := range messages {\n\t\tif m.SenderID != uidStr {\n\t\t\tsende
rMap[m.SenderID] = append(senderMap[m.SenderID], m.MessageID)\n\t\t}\n\t}\n\n\tf
or senderID, msgIDs := range senderMap {\n\t\tvar sUID int64\n\t\tif _, err := f
mt.Sscanf(senderID, "%d", &sUID); err == nil && sUID > 0 {\n\t\t\tif err := uc.p
usher.PushReadReceipt(ctx, sUID, req.ConversationId, msgIDs); err != nil {\n\t\t
\t\tuc.log.Warnw("push read receipt failed", "error", err)\n\t\t\t}\n\t\t}\n\t}\
n\n\treturn &apipb.MarkAsReadResponse{ReadCount: int32(len(req.MessageIds))}, ni
l\n}\n```\n\n---\n\n## 6. Data 数据实现层\n\n### `internal/data/wapi/im.go`\n\n`
``go\npackage wapi\n\nimport (\n\t"context"\n\t"fmt"\n\t"time"\n\n\t"new-world/i
nternal/biz/repo"\n\t"new-world/internal/data/world/ent"\n\t"new-world/internal/
data/world/ent/conversation"\n\t"new-world/internal/data/world/ent/immessage"\n\
t"new-world/internal/data/world/ent/immessagereadreceipt"\n\n\t"github.com/go-kr
atos/kratos/v2/log"\n)\n\ntype imRepo struct {\n\tworldDB *ent.Client\n\tlog    
*log.Helper\n}\n\nfunc NewIMRepo(data *Data, logger log.Logger) repo.IMRepo {\n\
treturn &imRepo{\n\t\tworldDB: data.WorldDB,\n\t\tlog:     log.NewHelper(logger)
,\n\t}\n}\n\nfunc (r *imRepo) CreateOrGetConversation(ctx context.Context, a, b 
string) (*repo.Conversation, error) {\n\t// 保证顺序一致，避免重复会话\n\tp1, p2
:= a, b\n\tif a > b {\n\t\tp1, p2 = b, a\n\t}\n\n\tconv, err := r.worldDB.Conver
sation.Query().\n\t\tWhere(conversation.ParticipantA(p1), conversation.Participa
ntB(p2)).\n\t\tFirst(ctx)\n\tif err == nil {\n\t\treturn r.toRepoConversation(co
nv), nil\n\t}\n\tif !ent.IsNotFound(err) {\n\t\treturn nil, err\n\t}\n\n\tnow :=
time.Now().UnixMilli()\n\tconvID := fmt.Sprintf("conv_%d", now)\n\tnewConv, err 
:= r.worldDB.Conversation.Create().\n\t\tSetConversationID(convID).\n\t\tSetPart
icipantA(p1).\n\t\tSetParticipantB(p2).\n\t\tSetCreatedAt(now).\n\t\tSetUpdatedA
t(now).\n\t\tSave(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn r.
toRepoConversation(newConv), nil\n}\n\nfunc (r *imRepo) GetConversationList(ctx 
context.Context, participant string, page, pageSize int32) ([]*repo.Conversation
, int32, error) {\n\tquery := r.worldDB.Conversation.Query().\n\t\tWhere(\n\t\t\
tconversation.Or(\n\t\t\t\tconversation.ParticipantA(participant),\n\t\t\t\tconv
ersation.ParticipantB(participant),\n\t\t\t),\n\t\t)\n\n\ttotal, err := query.Co
unt(ctx)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\toffset := (page - 
1) * pageSize\n\tentities, err := query.\n\t\tOrder(ent.Desc(conversation.FieldL
astMessageAt)).\n\t\tOffset(int(offset)).\n\t\tLimit(int(pageSize)).\n\t\tAll(ct
x)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tlist := make([]*repo.Con
versation, len(entities))\n\tfor i, e := range entities {\n\t\tlist[i] = r.toRep
oConversation(e)\n\t}\n\n\ttotalPage := int32(total) / pageSize\n\tif int32(tota
l)%pageSize != 0 {\n\t\ttotalPage++\n\t}\n\tif totalPage == 0 {\n\t\ttotalPage =
1\n\t}\n\treturn list, totalPage, nil\n}\n\nfunc (r *imRepo) UpdateConversationL
astMessage(ctx context.Context, conversationID, messageID, content string, sentA
t int64) error {\n\t_, err := r.worldDB.Conversation.Update().\n\t\tWhere(conver
sation.ConversationID(conversationID)).\n\t\tSetLastMessageID(messageID).\n\t\tS
etLastMessageContent(content).\n\t\tSetLastMessageAt(sentAt).\n\t\tSetUpdatedAt(
time.Now().UnixMilli()).\n\t\tSave(ctx)\n\treturn err\n}\n\nfunc (r *imRepo) Inc
rUnreadCount(ctx context.Context, conversationID string, targetParticipant strin
g) error {\n\tc, err := r.worldDB.Conversation.Query().\n\t\tWhere(conversation.
ConversationID(conversationID)).\n\t\tFirst(ctx)\n\tif err != nil {\n\t\treturn 
err\n\t}\n\n\tif c.ParticipantA == targetParticipant {\n\t\treturn r.worldDB.Con
versation.Update().\n\t\t\tWhere(conversation.ConversationID(conversationID)).\n
\t\t\tAddUnreadCountA(1).\n\t\t\tSetUpdatedAt(time.Now().UnixMilli()).\n\t\t\tEx
ec(ctx)\n\t}\n\treturn r.worldDB.Conversation.Update().\n\t\tWhere(conversation.
ConversationID(conversationID)).\n\t\tAddUnreadCountB(1).\n\t\tSetUpdatedAt(time
.Now().UnixMilli()).\n\t\tExec(ctx)\n}\n\nfunc (r *imRepo) ClearUnreadCount(ctx 
context.Context, conversationID string, targetParticipant string) error {\n\tc, 
err := r.worldDB.Conversation.Query().\n\t\tWhere(conversation.ConversationID(co
nversationID)).\n\t\tFirst(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif 
c.ParticipantA == targetParticipant {\n\t\treturn r.worldDB.Conversation.Update(
).\n\t\t\tWhere(conversation.ConversationID(conversationID)).\n\t\t\tSetUnreadCo
untA(0).\n\t\t\tSetUpdatedAt(time.Now().UnixMilli()).\n\t\t\tExec(ctx)\n\t}\n\tr
eturn r.worldDB.Conversation.Update().\n\t\tWhere(conversation.ConversationID(co
nversationID)).\n\t\tSetUnreadCountB(0).\n\t\tSetUpdatedAt(time.Now().UnixMilli(
)).\n\t\tExec(ctx)\n}\n\nfunc (r *imRepo) CreateMessage(ctx context.Context, msg
*repo.IMMessage) error {\n\tnow := time.Now().UnixMilli()\n\t_, err := r.worldDB
.IMMessage.Create().\n\t\tSetMessageID(msg.MessageID).\n\t\tSetConversationID(ms
g.ConversationID).\n\t\tSetSenderID(msg.SenderID).\n\t\tSetReceiverID(msg.Receiv
erID).\n\t\tSetContent(msg.Content).\n\t\tSetMessageType(int(msg.MessageType)).\
n\t\tSetStatus(int(msg.Status)).\n\t\tSetSentAt(msg.SentAt).\n\t\tSetCreatedAt(n
ow).\n\t\tSetUpdatedAt(now).\n\t\tSave(ctx)\n\treturn err\n}\n\nfunc (r *imRepo)
GetMessageHistory(ctx context.Context, conversationID string, beforeMessageID st
ring, pageSize int32) ([]*repo.IMMessage, bool, error) {\n\tquery := r.worldDB.I
MMessage.Query().\n\t\tWhere(immessage.ConversationID(conversationID))\n\n\tif b
eforeMessageID != "" {\n\t\t// 找到该消息的 sent_at，然后取更小的\n\t\trefMsg, e
rr := r.worldDB.IMMessage.Query().\n\t\t\tWhere(immessage.MessageID(beforeMessag
eID)).\n\t\t\tFirst(ctx)\n\t\tif err == nil && refMsg != nil {\n\t\t\tquery = qu
ery.Where(immessage.SentAtLT(refMsg.SentAt))\n\t\t}\n\t}\n\n\ttotal, err := quer
y.Count(ctx)\n\tif err != nil {\n\t\treturn nil, false, err\n\t}\n\n\tentities, 
err := query.\n\t\tOrder(ent.Desc(immessage.FieldSentAt)).\n\t\tLimit(int(pageSi
ze) + 1).\n\t\tAll(ctx)\n\tif err != nil {\n\t\treturn nil, false, err\n\t}\n\n\
thasMore := len(entities) > int(pageSize)\n\tif hasMore {\n\t\tentities = entiti
es[:pageSize]\n\t}\n\n\tlist := make([]*repo.IMMessage, len(entities))\n\tfor i,
e := range entities {\n\t\tlist[i] = r.toRepoMessage(e)\n\t}\n\treturn list, has
More, nil\n}\n\nfunc (r *imRepo) GetMessagesByIDs(ctx context.Context, messageID
s []string) ([]*repo.IMMessage, error) {\n\tentities, err := r.worldDB.IMMessage
.Query().\n\t\tWhere(immessage.MessageIDIn(messageIDs...)).\n\t\tAll(ctx)\n\tif 
err != nil {\n\t\treturn nil, err\n\t}\n\tlist := make([]*repo.IMMessage, len(en
tities))\n\tfor i, e := range entities {\n\t\tlist[i] = r.toRepoMessage(e)\n\t}\
n\treturn list, nil\n}\n\nfunc (r *imRepo) BatchCreateReadReceipts(ctx context.C
ontext, receipts []*repo.ReadReceipt) error {\n\tif len(receipts) == 0 {\n\t\tre
turn nil\n\t}\n\tcreates := make([]*ent.IMMessageReadReceiptCreate, len(receipts
))\n\tfor i, rc := range receipts {\n\t\tcreates[i] = r.worldDB.IMMessageReadRec
eipt.Create().\n\t\t\tSetMessageID(rc.MessageID).\n\t\t\tSetReaderID(rc.ReaderID
).\n\t\t\tSetReadAt(rc.ReadAt).\n\t\t\tSetCreatedAt(time.Now().UnixMilli())\n\t}
\n\treturn r.worldDB.IMMessageReadReceipt.CreateBulk(creates...).Exec(ctx)\n}\n\
nfunc (r *imRepo) GetReadReceiptsByMessageIDs(ctx context.Context, messageIDs []
string) (map[string][]string, error) {\n\tentities, err := r.worldDB.IMMessageRe
adReceipt.Query().\n\t\tWhere(immessagereadreceipt.MessageIDIn(messageIDs...)).\
n\t\tAll(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tresult := make(map
[string][]string)\n\tfor _, e := range entities {\n\t\tresult[e.MessageID] = app
end(result[e.MessageID], e.ReaderID)\n\t}\n\treturn result, nil\n}\n\nfunc (r *i
mRepo) toRepoConversation(e *ent.Conversation) *repo.Conversation {\n\treturn &r
epo.Conversation{\n\t\tID:                 int64(e.ID),\n\t\tConversationID:    
e.ConversationID,\n\t\tParticipantA:       e.ParticipantA,\n\t\tParticipantB:   
   e.ParticipantB,\n\t\tLastMessageID:      e.LastMessageID,\n\t\tLastMessageCon
tent: e.LastMessageContent,\n\t\tLastMessageAt:      e.LastMessageAt,\n\t\tUnrea
dCountA:       int32(e.UnreadCountA),\n\t\tUnreadCountB:       int32(e.UnreadCou
ntB),\n\t\tCreatedAt:          e.CreatedAt,\n\t\tUpdatedAt:          e.UpdatedAt
,\n\t}\n}\n\nfunc (r *imRepo) toRepoMessage(e *ent.IMMessage) *repo.IMMessage {\
n\treturn &repo.IMMessage{\n\t\tID:             int64(e.ID),\n\t\tMessageID:    
 e.MessageID,\n\t\tConversationID: e.ConversationID,\n\t\tSenderID:       e.Send
erID,\n\t\tReceiverID:     e.ReceiverID,\n\t\tContent:        e.Content,\n\t\tMe
ssageType:    int32(e.MessageType),\n\t\tStatus:         int32(e.Status),\n\t\tS
entAt:         e.SentAt,\n\t\tCreatedAt:      e.CreatedAt,\n\t\tUpdatedAt:      
e.UpdatedAt,\n\t}\n}\n```\n\n---\n\n## 7. Service 服务层\n\n### `internal/servic
e/wapi/im.go`\n\n```go\npackage wapi\n\nimport (\n\t"context"\n\n\tapipb "new-wo
rld/api/new-world-api/v1"\n\t"new-world/internal/biz/wapi"\n\t"new-world/pkg/uti
ls/meta"\n)\n\ntype IMService struct {\n\tapipb.UnimplementedIMServer\n\timUC *w
api.IMUseCase\n}\n\nfunc NewIMService(imUC *wapi.IMUseCase) *IMService {\n\tretu
rn &IMService{imUC: imUC}\n}\n\nfunc (s *IMService) SendMessage(ctx context.Cont
ext, req *apipb.SendMessageRequest) (*apipb.SendMessageResponse, error) {\n\tuid
, err := meta.TryLoadUid(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tms
g, err := s.imUC.SendMessage(ctx, uid, req)\n\tif err != nil {\n\t\treturn nil, 
err\n\t}\n\treturn &apipb.SendMessageResponse{Message: msg}, nil\n}\n\nfunc (s *
