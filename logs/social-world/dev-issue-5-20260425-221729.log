ws_handler.go`\n\n```go\npackage wapi\n\nimport (\n\t"context"\n\t"fmt"\n\t"strc
onv"\n\n\tapipb "new-world/api/new-world-api/v1"\n\twwspb "new-world/api/new-wor
ld-ws/v1"\n\tsharedpb "new-world/api/shared/v1"\n\t"new-world/internal/biz"\n\t"
new-world/pkg/worldgrpc"\n\n\t"github.com/go-kratos/kratos/v2/log"\n\t"google.go
lang.org/protobuf/proto"\n)\n\nconst (\n\tIMMessageType      = "im.message"\n\tI
MReadReceiptType  = "im.read_receipt"\n)\n\ntype IMWsPushHandler struct {\n\twws
Handler *biz.WwsHandler\n\tlog        *log.Helper\n}\n\nfunc NewIMWsPushHandler(
wwsHandler *biz.WwsHandler, logger log.Logger) *IMWsPushHandler {\n\treturn &IMW
sPushHandler{\n\t\twwsHandler: wwsHandler,\n\t\tlog:        log.NewHelper(logger
),\n\t}\n}\n\n// PushMessage 推送新消息给接收者\nfunc (h *IMWsPushHandler) PushM
essage(ctx context.Context, uid int64, msg *apipb.IMMessageContent) error {\n\tb
ody, err := proto.Marshal(msg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tretu
rn h.wwsHandler.Publish(ctx, &wwspb.Message{\n\t\tId:      msg.MessageId,\n\t\tT
ype:    IMMessageType,\n\t\tContentType: sharedpb.ContentType_PROTOBUF,\n\t\tDes
tination: &wwspb.Destination{\n\t\t\tType:   wwspb.Destination_User,\n\t\t\tValu
es: []string{strconv.FormatInt(uid, 10)},\n\t\t},\n\t\tBody: body,\n\t})\n}\n\n/
/ PushReadReceipt 推送已读回执给发送者\nfunc (h *IMWsPushHandler) PushReadReceip
t(ctx context.Context, uid int64, conversationID string, messageIDs []string) er
ror {\n\ttype readReceiptPayload struct {\n\t\tConversationID string   `json:"co
nversation_id"`\n\t\tMessageIDs     []string `json:"message_ids"`\n\t}\n\n\tpayl
oad := &readReceiptPayload{\n\t\tConversationID: conversationID,\n\t\tMessageIDs
:     messageIDs,\n\t}\n\n\t// 使用 JSON 或 Protobuf 均可；这里示例用 JSON 便于
前端调试\n\tbody, err := json.Marshal(payload)\n\tif err != nil {\n\t\treturn er
r\n\t}\n\n\treturn h.wwsHandler.Publish(ctx, &wwspb.Message{\n\t\tId:      fmt.S
printf("read_%s_%d", conversationID, uid),\n\t\tType:    IMReadReceiptType,\n\t\
tContentType: sharedpb.ContentType_JSON_TEXT,\n\t\tDestination: &wwspb.Destinati
on{\n\t\t\tType:   wwspb.Destination_User,\n\t\t\tValues: []string{strconv.Forma
tInt(uid, 10)},\n\t\t},\n\t\tBody: body,\n\t})\n}\n\n// 确保 IMWsPushHandler 实
现 biz.IMPusher 接口\nvar _ wapi.IMPusher = (*IMWsPushHandler)(nil)\n```\n\n**说
明**: 推送复用现有 `biz.WwsHandler.Publish()` 方法，通过 `Destination_User` 将消
息路由到目标用户的 WebSocket 连接。用户上线时已在 `WwsHandler.OnOpen0` 中自动订
阅 `worldgrpc.UserChannel(uid)`，因此 IM 消息可直接送达。\n\n---\n\n## 9. Server
