n\t\tOffset(int(offset)).\n\t\tLimit(int(pageSize)).\n\t\tAll(ctx)\n\tif err != 
nil {\n\t\treturn nil, 0, err\n\t}\n\n\tlist := make([]*repo.Conversation, len(e
ntities))\n\tfor i, e := range entities {\n\t\tlist[i] = r.toRepoConversation(e)
\n\t}\n\n\ttotalPage := int32(total) / pageSize\n\tif int32(total)%pageSize != 0
