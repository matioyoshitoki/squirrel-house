otobuf API 定义\n\n### `api/new-world-api/v1/im.proto`\n\n```protobuf\nsyntax = 
"proto3";\n\npackage new_world.v1;\n\nimport "google/api/annotations.proto";\n\n
option go_package = "new-world/api/new-world-api/v1;apipb";\n\nservice IM {\n  /
/ 发送消息\n  rpc SendMessage (SendMessageRequest) returns (SendMessageResponse)
{\n    option (google.api.http) = {\n      post: "/api/v1/im/send",\n      body:
"*"\n    };\n  }\n\n  // 获取会话列表\n  rpc GetConversationList (GetConversatio
nListRequest) returns (GetConversationListResponse) {\n    option (google.api.ht
tp) = {\n      post: "/api/v1/im/conversations",\n      body: "*"\n    };\n  }\n
\n  // 获取消息历史\n  rpc GetMessageHistory (GetMessageHistoryRequest) returns 
(GetMessageHistoryResponse) {\n    option (google.api.http) = {\n      post: "/a
pi/v1/im/history",\n      body: "*"\n    };\n  }\n\n  // 标记已读（发送已读回执
）\n  rpc MarkAsRead (MarkAsReadRequest) returns (MarkAsReadResponse) {\n    opt
ion (google.api.http) = {\n      post: "/api/v1/im/read",\n      body: "*"\n    
};\n  }\n}\n\nenum IMMessageType {\n  IM_MESSAGE_TYPE_UNSPECIFIED = 0;\n  IM_MES
SAGE_TYPE_TEXT = 1;\n  IM_MESSAGE_TYPE_IMAGE = 2;\n  IM_MESSAGE_TYPE_VOICE = 3;\
n}\n\nmessage IMMessageContent {\n  string message_id = 1;\n  string conversatio
n_id = 2;\n  string sender_id = 3;\n  string sender_name = 4;\n  string receiver
_id = 5;\n  string content = 6;\n  IMMessageType message_type = 7;\n  int64 sent
_at = 8;\n  bool is_read = 9;\n}\n\nmessage SendMessageRequest {\n  string recei
ver_id = 1;\n  string content = 2;\n  IMMessageType message_type = 3;\n}\n\nmess
age SendMessageResponse {\n  IMMessageContent message = 1;\n}\n\nmessage GetConv
ersationListRequest {\n  int32 page = 1;\n  int32 page_size = 2;\n}\n\nmessage C
onversationInfo {\n  string conversation_id = 1;\n  string participant_id = 2;  
// 对方 UID\n  string participant_name = 3;\n  string last_message_id = 4;\n  st
ring last_message_content = 5;\n  int64 last_message_at = 6;\n  int32 unread_cou
nt = 7;\n}\n\nmessage GetConversationListResponse {\n  repeated ConversationInfo
list = 1;\n  int32 current_page = 2;\n  int32 page_size = 3;\n  int32 total_page
= 4;\n}\n\nmessage GetMessageHistoryRequest {\n  string conversation_id = 1;\n  
string before_message_id = 2; // 分页游标，空表示最新\n  int32 page_size = 3;\n}
\n\nmessage GetMessageHistoryResponse {\n  repeated IMMessageContent messages = 
1;\n  bool has_more = 2;\n}\n\nmessage MarkAsReadRequest {\n  string conversatio
n_id = 1;\n  repeated string message_ids = 2;\n}\n\nmessage MarkAsReadResponse {
\n  int32 read_count = 1;\n}\n```\n\n---\n\n## 4. Repo 接口层\n\n### `internal/b
iz/repo/im.go`\n\n```go\npackage repo\n\nimport "context"\n\n// Conversation 会
话实体\ntype Conversation struct {\n\tID                 int64\n\tConversationID
    string\n\tParticipantA       string\n\tParticipantB       string\n\tLastMess
ageID      string\n\tLastMessageContent string\n\tLastMessageAt      int64\n\tUn
readCountA       int32\n\tUnreadCountB       int32\n\tCreatedAt          int64\n
\tUpdatedAt          int64\n}\n\n// IMMessage 消息实体\ntype IMMessage struct {\
n\tID             int64\n\tMessageID      string\n\tConversationID string\n\tSen
derID       string\n\tReceiverID     string\n\tContent        string\n\tMessageT
ype    int32\n\tStatus         int32\n\tSentAt         int64\n\tCreatedAt      i
nt64\n\tUpdatedAt      int64\n}\n\n// ReadReceipt 已读回执实体\ntype ReadReceipt
struct {\n\tID        int64\n\tMessageID string\n\tReaderID  string\n\tReadAt   
int64\n\tCreatedAt int64\n}\n\n// IMRepo IM 仓库接口\ntype IMRepo interface {\n\
t// Conversation 相关\n\tCreateOrGetConversation(ctx context.Context, participan
tA, participantB string) (*Conversation, error)\n\tGetConversationList(ctx conte
xt.Context, participant string, page, pageSize int32) ([]*Conversation, int32, e
rror)\n\tUpdateConversationLastMessage(ctx context.Context, conversationID, mess
ageID, content string, sentAt int64) error\n\tIncrUnreadCount(ctx context.Contex
t, conversationID string, targetParticipant string) error\n\tClearUnreadCount(ct
x context.Context, conversationID string, targetParticipant string) error\n\n\t/
/ Message 相关\n\tCreateMessage(ctx context.Context, msg *IMMessage) error\n\tGe
tMessageHistory(ctx context.Context, conversationID string, beforeMessageID stri
ng, pageSize int32) ([]*IMMessage, bool, error)\n\tGetMessagesByIDs(ctx context.
Context, messageIDs []string) ([]*IMMessage, error)\n\n\t// ReadReceipt 相关\n\t
BatchCreateReadReceipts(ctx context.Context, receipts []*ReadReceipt) error\n\tG
etReadReceiptsByMessageIDs(ctx context.Context, messageIDs []string) (map[string
][]string, error)\n}\n```\n\n---\n\n## 5. Biz 业务用例层\n\n### `internal/biz/wa
pi/im.go`\n\n```go\npackage wapi\n\nimport (\n\t"context"\n\t"fmt"\n\t"time"\n\n
\tapipb "new-world/api/new-world-api/v1"\n\t"new-world/internal/biz/repo"\n\t"ne
w-world/pkg/consts/biz_error"\n\t"new-world/pkg/utils/idgen"\n\n\t"github.com/go
-kratos/kratos/v2/log"\n)\n\ntype IMPusher interface {\n\tPushMessage(ctx contex
t.Context, uid int64, msg *apipb.IMMessageContent) error\n\tPushReadReceipt(ctx 
context.Context, uid int64, conversationID string, messageIDs []string) error\n}
\n\ntype IMUseCase struct {\n\timRepo   repo.IMRepo\n\tuserRepo repo.UserRepo\n\
tpusher   IMPusher\n\tidGen    repo.IdGen\n\tlog      *log.Helper\n}\n\nfunc New
IMUseCase(\n\timRepo repo.IMRepo,\n\tuserRepo repo.UserRepo,\n\tpusher IMPusher,
\n\tidGen repo.IdGen,\n\tlogger log.Logger,\n) *IMUseCase {\n\treturn &IMUseCase
{\n\t\timRepo:   imRepo,\n\t\tuserRepo: userRepo,\n\t\tpusher:   pusher,\n\t\tid
Gen:    idGen,\n\t\tlog:      log.NewHelper(logger),\n\t}\n}\n\nfunc (uc *IMUseC
ase) nowMs() int64 {\n\treturn time.Now().UnixMilli()\n}\n\n// SendMessage 发送
消息\nfunc (uc *IMUseCase) SendMessage(ctx context.Context, senderID int64, req 
*apipb.SendMessageRequest) (*apipb.IMMessageContent, error) {\n\t// 1. 获取或创
建会话\n\tsenderStr := fmt.Sprintf("%d", senderID)\n\tconv, err := uc.imRepo.Cre
ateOrGetConversation(ctx, senderStr, req.ReceiverId)\n\tif err != nil {\n\t\tret
urn nil, err\n\t}\n\n\t// 2. 生成消息\n\tmsgID := fmt.Sprintf("%d", uc.idGen.Gen
Int64())\n\tnow := uc.nowMs()\n\tmsg := &repo.IMMessage{\n\t\tMessageID:      ms
gID,\n\t\tConversationID: conv.ConversationID,\n\t\tSenderID:       senderStr,\n
\t\tReceiverID:     req.ReceiverId,\n\t\tContent:        req.Content,\n\t\tMessa
geType:    int32(req.MessageType),\n\t\tStatus:         1,\n\t\tSentAt:         
now,\n\t\tCreatedAt:      now,\n\t\tUpdatedAt:      now,\n\t}\n\n\t// 3. 持久化
消息 + 更新会话 + 增加未读数（事务）\n\tif err := uc.imRepo.CreateMessage(ctx, m
sg); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := uc.imRepo.UpdateConvers
ationLastMessage(ctx, conv.ConversationID, msgID, req.Content, now); err != nil 
{\n\t\tuc.log.Warnw("update conversation last message failed", "error", err)\n\t
}\n\tif err := uc.imRepo.IncrUnreadCount(ctx, conv.ConversationID, req.ReceiverI
d); err != nil {\n\t\tuc.log.Warnw("incr unread count failed", "error", err)\n\t
}\n\n\t// 4. 获取发送者名称\n\tsenderName := senderStr\n\tif user, err := uc.use
rRepo.FindOne(ctx, senderID); err == nil && user != nil {\n\t\tsenderName = fmt.
Sprintf("%s#%s", user.Name, user.Code)\n\t}\n\n\tresp := &apipb.IMMessageContent
{\n\t\tMessageId:      msgID,\n\t\tConversationId: conv.ConversationID,\n\t\tSen
derId:       senderStr,\n\t\tSenderName:     senderName,\n\t\tReceiverId:     re
q.ReceiverId,\n\t\tContent:        req.Content,\n\t\tMessageType:    req.Message
Type,\n\t\tSentAt:         now,\n\t\tIsRead:         false,\n\t}\n\n\t// 5. WebS
ocket 实时推送给接收者\n\treceiverUID, _ := fmt.Sscanf(req.ReceiverId, "%d", &re
ceiverUID)\n\t// 更安全的解析方式\n\tvar ruid int64\n\tfmt.Sscanf(req.ReceiverId
, "%d", &ruid)\n\tif ruid > 0 {\n\t\tif err := uc.pusher.PushMessage(ctx, ruid, 
resp); err != nil {\n\t\t\tuc.log.Warnw("push message failed", "error", err, "re
ceiver", req.ReceiverId)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\n// GetConversat
ionList 获取会话列表\nfunc (uc *IMUseCase) GetConversationList(ctx context.Conte
xt, uid int64, page, pageSize int32) (*apipb.GetConversationListResponse, error)
{\n\tif page < 1 {\n\t\tpage = 1\n\t}\n\tif pageSize < 1 || pageSize > 50 {\n\t\
tpageSize = 20\n\t}\n\n\tconversations, totalPage, err := uc.imRepo.GetConversat
ionList(ctx, fmt.Sprintf("%d", uid), page, pageSize)\n\tif err != nil {\n\t\tret
urn nil, err\n\t}\n\n\tlist := make([]*apipb.ConversationInfo, len(conversations
))\n\tfor i, c := range conversations {\n\t\t// 确定对方信息\n\t\totherID := c.P
articipantA\n\t\tif otherID == fmt.Sprintf("%d", uid) {\n\t\t\totherID = c.Parti
cipantB\n\t\t}\n\n\t\t// 确定未读数\n\t\tunreadCount := c.UnreadCountA\n\t\tif f
mt.Sprintf("%d", uid) == c.ParticipantA {\n\t\t\tunreadCount = c.UnreadCountA\n\
t\t} else {\n\t\t\tunreadCount = c.UnreadCountB\n\t\t}\n\n\t\totherName := other
ID\n\t\tif otherUID, err := fmt.Sscanf(otherID, "%d", &otherUID); err == nil && 
otherUID > 0 {\n\t\t\tif user, err := uc.userRepo.FindOne(ctx, int64(otherUID));
err == nil && user != nil {\n\t\t\t\totherName = fmt.Sprintf("%s#%s", user.Name,
user.Code)\n\t\t\t}\n\t\t}\n\n\t\tlist[i] = &apipb.ConversationInfo{\n\t\t\tConv
ersationId:     c.ConversationID,\n\t\t\tParticipantId:      otherID,\n\t\t\tPar
ticipantName:    otherName,\n\t\t\tLastMessageId:      c.LastMessageID,\n\t\t\tL
astMessageContent: c.LastMessageContent,\n\t\t\tLastMessageAt:      c.LastMessag
eAt,\n\t\t\tUnreadCount:        unreadCount,\n\t\t}\n\t}\n\n\treturn &apipb.GetC
onversationListResponse{\n\t\tList:        list,\n\t\tCurrentPage: page,\n\t\tPa
geSize:    pageSize,\n\t\tTotalPage:   totalPage,\n\t}, nil\n}\n\n// GetMessageH
istory 获取消息历史\nfunc (uc *IMUseCase) GetMessageHistory(ctx context.Context,
uid int64, req *apipb.GetMessageHistoryRequest) (*apipb.GetMessageHistoryRespons
e, error) {\n\tpageSize := req.PageSize\n\tif pageSize < 1 || pageSize > 50 {\n\
t\tpageSize = 20\n\t}\n\n\tmessages, hasMore, err := uc.imRepo.GetMessageHistory
(ctx, req.ConversationId, req.BeforeMessageId, pageSize)\n\tif err != nil {\n\t\
treturn nil, err\n\t}\n\n\t// 批量查询已读状态\n\tmsgIDs := make([]string, len(m
essages))\n\tfor i, m := range messages {\n\t\tmsgIDs[i] = m.MessageID\n\t}\n\tr
eadMap, _ := uc.imRepo.GetReadReceiptsByMessageIDs(ctx, msgIDs)\n\n\tuidStr := f
mt.Sprintf("%d", uid)\n\trespMessages := make([]*apipb.IMMessageContent, len(mes
sages))\n\tfor i, m := range messages {\n\t\tisRead := false\n\t\tif m.SenderID 
== uidStr {\n\t\t\t// 自己发的消息，看对方是否已读\n\t\t\treaders := readMap[m.M
essageID]\n\t\t\tfor _, r := range readers {\n\t\t\t\tif r != uidStr {\n\t\t\t\t
\tisRead = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\t// 对
方发的消息，默认已显示即已读（前端调 markAsRead）\n\t\t\tisRead = true\n\t\t}\n\
n\t\trespMessages[i] = &apipb.IMMessageContent{\n\t\t\tMessageId:      m.Message
ID,\n\t\t\tConversationId: m.ConversationID,\n\t\t\tSenderId:       m.SenderID,\
n\t\t\tReceiverId:     m.ReceiverID,\n\t\t\tContent:        m.Content,\n\t\t\tMe
ssageType:    apipb.IMMessageType(m.MessageType),\n\t\t\tSentAt:         m.SentA
t,\n\t\t\tIsRead:         isRead,\n\t\t}\n\t}\n\n\treturn &apipb.GetMessageHisto
ryResponse{\n\t\tMessages: respMessages,\n\t\tHasMore:  hasMore,\n\t}, nil\n}\n\
n// MarkAsRead 标记已读\nfunc (uc *IMUseCase) MarkAsRead(ctx context.Context, ui
d int64, req *apipb.MarkAsReadRequest) (*apipb.MarkAsReadResponse, error) {\n\ti
f len(req.MessageIds) == 0 {\n\t\treturn &apipb.MarkAsReadResponse{ReadCount: 0}
, nil\n\t}\n\n\tuidStr := fmt.Sprintf("%d", uid)\n\tnow := uc.nowMs()\n\n\t// 1.
批量写入已读回执\n\treceipts := make([]*repo.ReadReceipt, 0, len(req.MessageIds)
)\n\tfor _, msgID := range req.MessageIds {\n\t\treceipts = append(receipts, &re
po.ReadReceipt{\n\t\t\tMessageID: msgID,\n\t\t\tReaderID:  uidStr,\n\t\t\tReadAt
:    now,\n\t\t\tCreatedAt: now,\n\t\t})\n\t}\n\tif err := uc.imRepo.BatchCreate
ReadReceipts(ctx, receipts); err != nil {\n\t\tuc.log.Warnw("batch create read r
eceipts failed", "error", err)\n\t}\n\n\t// 2. 清空该会话未读数\n\tif err := uc.
imRepo.ClearUnreadCount(ctx, req.ConversationId, uidStr); err != nil {\n\t\tuc.l
og.Warnw("clear unread count failed", "error", err)\n\t}\n\n\t// 3. 推送已读回执
给会话中的对方（通过消息中的 sender_id 推断）\n\tmessages, err := uc.imRepo.GetM
essagesByIDs(ctx, req.MessageIds)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n
\n\t// 按 sender 分组通知\n\tsenderMap := make(map[string][]string)\n\tfor _, m 
:= range messages {\n\t\tif m.SenderID != uidStr {\n\t\t\tsenderMap[m.SenderID] 
= append(senderMap[m.SenderID], m.MessageID)\n\t\t}\n\t}\n\n\tfor senderID, msgI
Ds := range senderMap {\n\t\tvar sUID int64\n\t\tif _, err := fmt.Sscanf(senderI
D, "%d", &sUID); err == nil && sUID > 0 {\n\t\t\tif err := uc.pusher.PushReadRec
eipt(ctx, sUID, req.ConversationId, msgIDs); err != nil {\n\t\t\t\tuc.log.Warnw(
"push read receipt failed", "error", err)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn &apip
b.MarkAsReadResponse{ReadCount: int32(len(req.MessageIds))}, nil\n}\n```\n\n---\
