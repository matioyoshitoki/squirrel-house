``protobuf\nsyntax = "proto3";\n\npackage new_world.v1;\n\nimport "google/api/an
notations.proto";\n\noption go_package = "new-world/api/new-world-api/v1;apipb";
\n\nservice IM {\n  // 发送消息\n  rpc SendMessage (SendMessageRequest) returns 
(SendMessageResponse) {\n    option (google.api.http) = {\n      post: "/api/v1/
im/send",\n      body: "*"\n    };\n  }\n\n  // 获取会话列表\n  rpc GetConversat
ionList (GetConversationListRequest) returns (GetConversationListResponse) {\n  
 option (google.api.http) = {\n      post: "/api/v1/im/conversations",\n      bo
dy: "*"\n    };\n  }\n\n  // 获取消息历史\n  rpc GetMessageHistory (GetMessageHi
storyRequest) returns (GetMessageHistoryResponse) {\n    option (google.api.http
) = {\n      post: "/api/v1/im/history",\n      body: "*"\n    };\n  }\n\n  // 
标记已读（发送已读回执）\n  rpc MarkAsRead (MarkAsReadRequest) returns (MarkAsRe
adResponse) {\n    option (google.api.http) = {\n      post: "/api/v1/im/read",\
n      body: "*"\n    };\n  }\n}\n\nenum IMMessageType {\n  IM_MESSAGE_TYPE_UNSP
ECIFIED = 0;\n  IM_MESSAGE_TYPE_TEXT = 1;\n  IM_MESSAGE_TYPE_IMAGE = 2;\n  IM_ME
SSAGE_TYPE_VOICE = 3;\n}\n\nmessage IMMessageContent {\n  string message_id = 1;
\n  string conversation_id = 2;\n  string sender_id = 3;\n  string sender_name =
4;\n  string receiver_id = 5;\n  string content = 6;\n  IMMessageType message_ty
pe = 7;\n  int64 sent_at = 8;\n  bool is_read = 9;\n}\n\nmessage SendMessageRequ
est {\n  string receiver_id = 1;\n  string content = 2;\n  IMMessageType message
_type = 3;\n}\n\nmessage SendMessageResponse {\n  IMMessageContent message = 1;\
n}\n\nmessage GetConversationListRequest {\n  int32 page = 1;\n  int32 page_size
= 2;\n}\n\nmessage ConversationInfo {\n  string conversation_id = 1;\n  string p
articipant_id = 2;   // 对方 UID\n  string participant_name = 3;\n  string last_
message_id = 4;\n  string last_message_content = 5;\n  int64 last_message_at = 6
;\n  int32 unread_count = 7;\n}\n\nmessage GetConversationListResponse {\n  repe
ated ConversationInfo list = 1;\n  int32 current_page = 2;\n  int32 page_size = 
3;\n  int32 total_page = 4;\n}\n\nmessage GetMessageHistoryRequest {\n  string c
onversation_id = 1;\n  string before_message_id = 2; // 分页游标，空表示最新\n  
int32 page_size = 3;\n}\n\nmessage GetMessageHistoryResponse {\n  repeated IMMes
sageContent messages = 1;\n  bool has_more = 2;\n}\n\nmessage MarkAsReadRequest 
{\n  string conversation_id = 1;\n  repeated string message_ids = 2;\n}\n\nmessa
ge MarkAsReadResponse {\n  int32 read_count = 1;\n}\n```\n\n---\n\n## 4. Repo 接
口层\n\n### `internal/biz/repo/im.go`\n\n```go\npackage repo\n\nimport "context"
\n\n// Conversation 会话实体\ntype Conversation struct {\n\tID                 i
nt64\n\tConversationID     string\n\tParticipantA       string\n\tParticipantB  
    string\n\tLastMessageID      string\n\tLastMessageContent string\n\tLastMess
ageAt      int64\n\tUnreadCountA       int32\n\tUnreadCountB       int32\n\tCrea
