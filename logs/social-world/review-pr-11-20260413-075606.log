is.redis = new Redis(redisConfig);\n+  }\n+\n+  async canActivate(context: Execu
tionContext): Promise<boolean> {\n+    const request = context.switchToHttp().ge
tRequest<Request>();\n+    const token = this.extractTokenFromHeader(request);\n
