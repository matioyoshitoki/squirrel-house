));\n  _initSocket();\n}\n\nvoid _initSocket() {\n  final authState = context.re
ad<AuthBloc>().state;\n  if (authState is AuthAuthenticated) {\n    _socketClien
t = MatchingSocketClient(\n      userId: authState.userId,\n      onMatchCreated
: (summary) {\n        context.read<MatchingBloc>().add(ExternalMatchReceived(su
mmary));\n      },\n    );\n    _socketClient.connect();\n  }\n}\n\n@override\nv
oid dispose() {\n  _socketClient?.disconnect();\n  super.dispose();\n}\n```\n\nF
or `MatchingSocketClient`:\n```dart\nimport \'package:socket_io_client/socket_io
_client.dart\' as io;\nimport \'../../data/models/match_summary.dart\';\n\nclass
MatchingSocketClient {\n  final String userId;\n  final void Function(MatchSumma
ry) onMatchCreated;\n  io.Socket? _socket;\n\n  MatchingSocketClient({\n    requ
ired this.userId,\n    required this.onMatchCreated,\n  });\n\n  void connect() 
{\n    final baseUrl = const String.fromEnvironment(\n      \'API_BASE_URL\',\n 
    defaultValue: \'http://localhost:3000\',\n    );\n    _socket = io.io(baseUr
l, <String, dynamic>{\n      \'transports\': [\'websocket\'],\n      \'autoConne
ct\': true,\n      \'query\': {\'userId\': userId},\n    });\n    _socket?.conne
ct();\n    _socket?.on(\'match:created\', (data) {\n      if (data != null) {\n 
      final summary = MatchSummary.fromJson(data as Map<String, dynamic>);\n    
