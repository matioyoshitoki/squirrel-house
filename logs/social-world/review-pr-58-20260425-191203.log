able(_messages)));\n   264\t  } else {\n   265\t    _pendingMessages.putIfAbsent
(event.message.conversationId, () => []).add(event.message);\n   266\t  }\n   26
7\t}\n   268\t\n   269\t// 切换会话时合并缓冲区\n   270\tvoid setCurrentConversa
tion(String? conversationId, String? userId) {\n   271\t  _currentConversationId
= conversationId;\n   272\t  if (conversationId != null && _pendingMessages.cont
ainsKey(conversationId)) {\n   273\t    _messages.addAll(_pendingMessages[conver
sationId]!);\n   274\t    _pendingMessages.remove(conversationId);\n   275\t    
emit(ImMessagesLoaded(List.unmodifiable(_messages)));\n   276\t  }\n   277\t}\n 
 278\t```\n   279\t\n   280\t> **原则**：BLoC 必须保证任何收到的消息至少被缓存到
对应会话的缓冲区，不能依赖 API 轮询作为唯一兜底。\n   281\t\n   282\t### 7. 聊天
页分页加载的滚动控制\n   283\t\n   284\t加载更早历史消息（分页）后，**禁止**自动
滚动到列表底部，否则用户无法阅读刚加载的内容。\n   285\t\n   286\t```dart\n   28
7\t// ❌ 错误：任何 ImMessagesLoaded 都触发滚动到底部\n   288\tlistener: (contex
t, state) {\n   289\t  if (state is ImMessagesLoaded) {\n   290\t    _scrollToBo
ttom(); // 分页加载时也滚动，导致 UX 断裂\n   291\t  }\n   292\t}\n   293\t\n   
294\t// ✅ 正确：仅在新消息发送或初始加载时滚动\n   295\tlistener: (context, sta
te) {\n   296\t  if (state is ImMessageSent) {\n   297\t    _scrollToBottom();\n
  298\t  }\n   299\t  if (state is ImMessagesLoaded && state.isInitialLoad) {\n 
 300\t    _scrollToBottom();\n   301\t  }\n   302\t}\n   303\t```\n   304\t\n   
305\t> **原则**：`_scrollToBottom()` 仅应在「发送新消息」或「首次进入页面」时触
发；分页加载历史消息时保持当前滚动位置。\n   306\t\n   307\t## UI 规范\n   308\t
\n   309\t- 不使用硬编码颜色/字号，统一从 `packages/design-system` 的 `AppTheme`
读取\n   310\t- 页面之间使用 `go_router` 导航\n   311\t- 图片资源使用 `flutter_g
en` 自动生成引用\n   312\t- 字符串使用 `intl` / `flutter_localizations` 管理（优
先中文）\n   313\t\n   314\t## 页面级 UI 开发前置规范\n   315\t\n   316\t任何涉
及**新页面、新核心交互模式、新组件**的功能开发，必须严格遵守以下前置流程。Issue 
#2（Auth Login）因跳过该流程导致 LoginPage 未使用 design-system 组件、无 Widgetb
ook 用例、无原型图 review，已产生技术债务。\n   317\t\n   318\t### 强制前置条件
（Must Have）\n   319\t\n   320\t1. **低保真原型图评审通过**\n   321\t   - PM Ag
ent 必须产出至少包含关键页面布局、交互状态、异常状态的低保真线框图（可存放于 `do
cs/design-docs/ui-specs/<feature>/`）。\n   322\t   - 人类确认原型图通过 review 
后，才能进入 design-system 组件开发。\n   323\t\n   324\t2. **Design-Only PR 先
走，且必须附带可查看的视觉产物**\n   325\t   - 在写后端 API、数据库 Entity、Dio 
网络请求之前，先提交独立的 Design-Only PR。\n   326\t   - Design-Only PR 的变更
范围**仅限于** `designs/issue-XXX/` 下的设计资产：\n   327\t     - `designs/issu
e-XXX/flutter-widgets/`（`.dart` 纯 UI Widget、Widgetbook 用例、Golden Test）\n 
 328\t     - `designs/issue-XXX/design-spec.md`（设计规范文档，含 Token 提案）\n
  329\t     - `designs/issue-XXX/flutter-widgets/MANIFEST.md`（迁移清单）\n   33
0\t     - `designs/issue-XXX/` 下的原型图、视觉资产\n   331\t   - **禁止**在 Des
ign-Only PR 中直接写入 `packages/`、`apps/` 或仓库根目录下的任何正式代码文件。如
需新增/修改 Design Token，应在 `design-spec.md` 中声明提案并在 `MANIFEST.md` 中
列出迁移清单，由后续功能开发 PR 统一迁入 `packages/design-system/`。\n   332\t  
- **PR 中必须包含至少一张视觉产物**，供人类在不运行代码的情况下快速 review。推荐
方式（按优先级排序）：\n   333\t     - **方案 A（推荐）**：提交 Golden File 截图
测试。运行 `flutter test --update-goldens` 生成 `*.png`，将生成的 golden 图片一
并提交到 PR 中。人类可直接在 GitHub 上查看组件渲染效果。\n   334\t     - **方案 
B**：若 golden file 暂时无法生成，PR 描述中必须包含运行命令，由人类在本地运行 `f
lutter run -d chrome -t lib/widgetbook/main.dart` 或模拟器后，**截图并作为 PR re
view comment 贴回**，确认后方可合并。\n   335\t     - **方案 C（仅作补充）**：可
用 Markdown / Mermaid / ASCII art 绘制线框逻辑图，但**不能替代**方案 A 或 B 的视
觉验收。\n   336\t\n   337\t3. **组件原子化评审**\n   338\t   - 页面中的任何可复
用元素（按钮、输入框、卡片、列表项、弹窗）若 design-system 中不存在，必须先按 `a
tom → molecule → organism` 层级在 design-system 中实现。\n   339\t   - **禁止**
在 `pages/` 中直接使用原生 Material 组件（如 `TextField`、`ElevatedButton`、`Out
lineInputBorder`）替代 design-system 组件。\n   340\t\n   341\t### 验收 Checklis
t\n   342\t\n   343\t在提交任何包含 Mobile UI 的 PR 前，PR 描述中必须勾选：\n   
344\t\n   345\t- [ ] 该功能已产出低保真/高保真原型图，且已通过人类 review\n   34
6\t- [ ] 所有新增/修改的组件已在 `widgetbook/main.dart` 中注册\n   347\t- [ ] PR
中附带 Golden File 截图或 Widgetbook 运行截图，供人类直接查看视觉产物\n   348\t-
[ ] `pages/` 中未使用 `Color(0xFF...)`、`TextField`、`ElevatedButton` 等硬编码或
原生 Material 组件替代 design-system\n   349\t- [ ] 页面中的状态（加载、空态、错
误、禁用）在原型图中有明确定义\n   350\t\n   351\t### 违规回滚策略\n   352\t\n  
353\t若发现已进入代码合并的页面存在未使用 design-system 组件、未走 Design-Only P
R 的情况：\n   354\t\n   355\t- 标记为 **技术债务**，录入 `docs/exec-plans/tech-
debt-tracker.md`\n   356\t- 在下一个迭代中优先安排 **Redesign-Only PR** 进行重构
，不得在旧基础上继续堆叠业务逻辑。\n   357\t\n   358\t## 设计系统（Widgetbook）\
n   359\t\n   360\t`packages/design-system/` 是本项目的**唯一设计源文件**。\n   
361\t\n   362\t### 结构\n   363\t\n   364\t```\n   365\tpackages/design-system/\
n   366\t├── lib/\n   367\t│   ├── src/\n   368\t│   │   ├── theme/          # t
okens + app_theme\n   369\t│   │   ├── atoms/          # 原子组件（按钮、头像、
标签）\n   370\t│   │   ├── molecules/      # 分子组件（输入框组合、用户卡片）\n
  371\t│   │   └── organisms/      # 有机体组件（底部导航、匹配弹窗）\n   372\t│
  ├── widgetbook/         # 组件展示平台\n   373\t│   │   └── main.dart       # 
所有组件的可交互展示\n   374\t│   └── social_world_design_system.dart\n   375\t└
── pubspec.yaml\n   376\t```\n   377\t\n   378\t### 强制规范\n   379\t\n   380\t
1. **新增组件必须在 Widgetbook 注册**：每个 `atom`/`molecule`/`organism` 类都必
须在 `widgetbook/main.dart` 中有至少一个展示用例\n   381\t2. **禁止写死设计 Toke
n**：所有颜色、字号、间距、圆角必须从 `DesignTokens` 读取。**Design-Only PR 在 `
designs/issue-XXX/flutter-widgets/` 下的预览代码也必须遵守此规范**，禁止以"临时
预览"为由使用 `Color(0xFF...)`\n   382\t3. **组件分类规则**：\n   383\t   - `ato
ms/`：不可再分的最小 UI 元素\n   384\t   - `molecules/`：多个 atom 的组合\n   38
5\t   - `organisms/`：包含业务语义的复杂组件\n   386\t\n   387\t### Token 使用指
南\n   388\t\n   389\t`packages/design-system/lib/src/theme/tokens.dart` 中存在
三套容易混淆的颜色系统，必须严格区分：\n   390\t\n   391\t| 系统               |
来源                                                   | 使用方式               
                             | 说明                                             
                                                                    |\n   392\t|
------------------ | ------------------------------------------------------ | --
-------------------------------------------------- | ---------------------------
--------------------------------------------------------------------------------
---------- |\n   393\t| **`DesignTokens`** | `tokens.dart` 中的静态常量         
                   | `DesignTokens.primary` / `DesignTokens.background`   | 项目
的核心设计 Token，**优先使用**                                                  
                                 |\n   394\t| **`ColorScheme`**  | `Theme.of(con
text).colorScheme`                        | `Theme.of(context).colorScheme.surfa
ce` / `.outline` | Flutter Material 的动态色板，设计规范中若引用 `ColorScheme.xx
x`，必须通过 Theme 读取                                  |\n   395\t| **Legacy a
liases** | `tokens.dart` 中的别名，如 `surfaceColor = background` | ~~`DesignTok
ens.surfaceColor`~~                      | **禁止在新代码中使用**。别名仅为兼容
旧代码保留，新组件/新页面必须直接使用主 Token 名或在 MANIFEST.md 中提案新增 Toke
n |\n   396\t\n   397\t**常见陷阱**：\n   398\t\n   399\t- `DesignTokens.surface
Color` 被别名为 `background`（`#FFFBFE`），但设计规范中的 `ColorScheme.surface` 
是 `#F3EDF7`。两者色值不同，**不可互换**。\n   400\t- 当设计 spec 需要一个新的语
义色（如 `likeActionColor`），禁止直接在代码中写 `Color(0xFF2E7D32)`。正确做法：
在 `design-spec.md` 中声明 Token 提案，在代码中通过临时常量或已注册的 Token 引用
，并在 `MANIFEST.md` 中列出迁移清单。\n   401\t\n   402\t## Debug-Only Widget 条
件编译模式\n   403\t\n   404\t当实现开发/调试专用 Widget（如 Dev Tools Drawer）
时，必须遵守以下规范：\n   405\t\n   406\t1. **所有调试工具 Widget 必须包裹在 `i
f (kDebugMode) ...` 中**\n   407\t   - 入口注入示例：\n   408\t     ```dart\n   
409\t     Widget build(BuildContext context) {\n   410\t       return MaterialAp
p.router(\n   411\t         // ...\n   412\t         builder: (context, child) {
\n   413\t           if (kDebugMode) {\n   414\t             return DevToolsWrap
per(child: child!);\n   415\t           }\n   416\t           return child!;\n  
417\t         },\n   418\t       );\n   419\t     }\n   420\t     ```\n   421\t\
n   422\t2. **禁止在 Release 模式下将调试 Widget 编译进产物**\n   423\t   - 通过
`const bool.fromEnvironment(\'dart.vm.product\')` 或 `kDebugMode` 进行编译期/运
行期隔离。\n   424\t   - 与调试相关的路由、Repository、Cubit 注册同样应在 `kDebu
gMode` 分支下完成，避免增加 Release 包体积。\n   425\t\n   426\t3. **调试工具状
态管理建议**\n   427\t   - 允许使用 `StatefulWidget` / `ValueNotifier`（因仅开发
期使用，逻辑通常较简单）。\n   428\t   - **建议统一使用 Cubit**，保持与生产代码
一致的可读性和可维护性。\n   429\t\n   430\t## StatefulWidget 输入组件与 Bloc 配
合最佳实践\n   431\t\n   432\t当 `TextEditingController` 与 `BlocBuilder`/`BlocL
istener` 配合使用时，需避免 Bloc state 变化直接覆盖用户正在编辑的内容，导致输入
框重置、光标跳转或复制粘贴失效。\n   433\t\n   434\t### 推荐做法\n   435\t\n   4
36\t1. **由 `TextEditingController` 持有输入的单一真实来源**\n   437\t   - 使用 
`controller.text` 作为当前输入值的来源。\n   438\t   - `onChanged` 仅用于通知 Cu
bit 做校验或派生状态计算，**不反向覆盖 controller**。\n   439\t\n   440\t2. **安
全同步异步加载的初始值**\n   441\t   - 若初始值来自异步加载（如 SharedPreference
s），`initState` 中可能只能拿到空值。\n   442\t   - 推荐使用受控的 `BlocListener
`，通过严格的 `listenWhen` 仅在首次加载完成后同步，且避开用户编辑时段：\n   443\
t     ```dart\n   444\t     @override\n   445\t     Widget build(BuildContext co
ntext) {\n   446\t       return BlocListener<MyCubit, MyState>(\n   447\t       
 listenWhen: (previous, current) =>\n   448\t             previous.initialValue.
isEmpty &&\n   449\t             current.initialValue.isNotEmpty &&\n   450\t   
         _controller.text.isEmpty &&\n   451\t             !_focusNode.hasFocus,
\n   452\t         listener: (context, state) {\n   453\t           _controller.
text = state.initialValue;\n   454\t         },\n   455\t         child: ...\n  
456\t       );\n   457\t     }\n   458\t     ```\n   459\t\n   460\t3. **避免无
条件的 `BlocListener` 覆盖 controller.text**\n   461\t   - 不要通过没有 `listenW
hen` 限制的 `BlocListener` 在 `serverBaseUrl` 等字段变化时执行 `_controller.text
= state.xxx`。\n   462\t   - 如果需要响应外部重置指令，应通过独立事件（如 `reset
ToDefault`）并在 handler 中显式更新 controller。\n   463\t\n   464\t### 反例\n  
465\t\n   466\t```dart\n   467\t// ❌ 错误：缺少 listenWhen 限制的 BlocListener 
会在每次 state 变化时重置输入内容\n   468\tBlocListener<MyCubit, MyState>(\n   4
69\t  listener: (context, state) {\n   470\t    _controller.text = state.serverB
aseUrl; // 导致用户输入被覆盖\n   471\t  },\n   472\t  child: ...\n   473\t)\n  
474\t```\n   475\t\n   476\t## Accessibility 编码规范\n   477\t\n   478\t所有 Wi
dget 必须考虑 **TalkBack（屏幕阅读器）** 和 **Maestro E2E** 的双重可访问性要求。
\n   479\t\n   480\t### Semantics 三要素\n   481\t\n   482\t需要通过 Maestro 定
位或点击的 Widget，必须声明以下 `Semantics` 属性：\n   483\t\n   484\t| 属性    
           | 作用                     | 对应 Android       | 对应 Maestro       
                    |\n   485\t| ------------------- | ------------------------ 
| ------------------ | --------------------------------------- |\n   486\t| `ide
ntifier: \'xxx\'` | 生成稳定的 `resource-id` | `resource-id`      | `tapOn: { id
: "xxx" }`                  |\n   487\t| `label: \'xxx\'`      | 暴露文本描述   
         | `content-desc`     | `tapOn: "xxx"` / `assertVisible: "xxx"` |\n   48
8\t| `button: true`      | 标记为可点击按钮         | `clickable="true"` | 自动
识别为可交互元素                    |\n   489\t| `container: true`   | 限制 boun
ds 不溢出子节点 | —                  | 防止 bounds 扩展到父容器                |
\n   490\t\n   491\t**最小示例**：\n   492\t\n   493\t```dart\n   494\tSemantics
(\n   495\t  identifier: \'save_button\',\n   496\t  label: \'保存配置\',\n   49
7\t  button: true,\n   498\t  child: GestureDetector(\n   499\t    onTapDown: (_
) => onSave(),\n   500\t    child: const Text(\'保存配置\'),\n   501\t  ),\n   5
02\t)\n   503\t```\n   504\t\n   505\t### `Stack` 中悬浮/覆盖 Widget 的 bounds 
限制\n   506\t\n   507\t`Stack` 中的子 Widget（悬浮按钮、Toast、Badge、抽屉触发
器等）必须使用 `Positioned` 并显式指定 `width`/`height`。**严禁使用 `Align`**，
否则 accessibility bounds 会扩展为全屏，导致 Maestro 点击位置错误。\n   508\t\n 
 509\t```dart\n   510\t// ❌ 错误：Align 导致 accessibility bounds 全屏\n   511\
treturn Align(\n   512\t  alignment: Alignment.centerRight,\n   513\t  child: Ge
stureDetector(onTap: onTap, child: SizedBox(width: 56, height: 56)),\n   514\t);
\n   515\t\n   516\t// ✅ 正确：Positioned + 明确尺寸，bounds 严格限制在 56×56\n
  517\treturn Positioned(\n   518\t  right: DesignTokens.spacingXs,\n   519\t  t
op: screenHeight / 2 - 28,\n   520\t  width: 56,\n   521\t  height: 56,\n   522\
t  child: GestureDetector(onTapDown: (_) => onTap(), child: SizedBox(width: 56, 
height: 56)),\n   523\t);\n   524\t```\n   525\t\n   526\t### Maestro 点击兼容性
\n   527\t\n   528\tMaestro 使用 Android Accessibility API 的 `performAction(ACT
ION_CLICK)`，其事件序列（仅 `ACTION_DOWN` → `ACTION_UP`，无完整手势轨迹）**无法
触发 Flutter 的 `GestureDetector.onTap`**（需要完整的手势识别）。\n   529\t\n   
530\t**必须**将需要 Maestro 点击的交互回调改为 `onTapDown`：\n   531\t\n   532\t
| 组件              | ❌ 不兼容   | ✅ 兼容                 |\n   533\t| -------
---------- | ----------- | ----------------------- |\n   534\t| `GestureDetector
` | `onTap`     | `onTapDown`             |\n   535\t| `InkWell`         | `onTa
p`     | `onTapDown`             |\n   536\t| `IconButton`      | `onPressed` | 
不推荐用于 Maestro 场景 |\n   537\t\n   538\t```dart\n   539\t// ✅ 适用于 Maest
ro 的悬浮按钮\n   540\tGestureDetector(\n   541\t  behavior: HitTestBehavior.opa
que,  // 确保空白区域也可点击\n   542\t  onTapDown: (_) => onTap(),         // A
CTION_DOWN 即响应\n   543\t  child: Container(...),\n   544\t)\n   545\t```\n   
546\t\n   547\t### TextField / 输入框的 Accessibility 与 E2E 规范\n   548\t\n   
549\t输入框是 Maestro E2E 的高风险区域，必须同时处理 **文本同步** 和 **自动全选*
* 两个问题：\n   550\t\n   551\t#### 1. 使用 `controller.addListener` 替代 `Text
Field.onChanged`\n   552\t\n   553\t`TextField.onChanged` 在 Maestro `inputText`
、ADB `input text` 等通过 Accessibility API 直接操作文本的方式下**不会触发**。必
须使用 `TextEditingController.addListener` 确保任何文本变更都能同步到 Cubit：\n 
 554\t\n   555\t```dart\n   556\t// ❌ 错误：Maestro inputText 不触发 onChanged
，Cubit 无法同步\n   557\tTextField(\n   558\t  controller: _controller,\n   559
\t  onChanged: cubit.onUrlChanged,\n   560\t)\n   561\t\n   562\t// ✅ 正确：con
troller listener 在任何文本变更时触发\n   563\t@override\n   564\tvoid initState
() {\n   565\t  super.initState();\n   566\t  _controller = TextEditingControlle
r();\n   567\t  _controller.addListener(() {\n   568\t    cubit.onUrlChanged(_co
ntroller.text);\n   569\t  });\n   570\t}\n   571\t```\n   572\t\n   573\t#### 2
. 获得焦点时自动全选旧内容\n   574\t\n   575\tMaestro `inputText` 在 Flutter Tex
tField 上的行为是**追加**而非替换。若旧内容未被清除，新输入会与旧值拼接成无效内
容。必须在获得焦点时自动全选：\n   576\t\n   577\t```dart\n   578\t_focusNode.ad
dListener(() {\n   579\t  if (_focusNode.hasFocus) {\n   580\t    _controller.se
lection = TextSelection(\n   581\t      baseOffset: 0,\n   582\t      extentOffs
et: _controller.text.length,\n   583\t    );\n   584\t  }\n   585\t});\n   586\t
```\n   587\t\n   588\t#### 3. 输入框必须暴露 `Semantics(identifier: \'xxx\')`\n
  589\t\n   590\tMaestro 通过 `tapOn: { id: \'xxx\' }` 精确定位输入框，避免匹配
到 Label 等非输入元素：\n   591\t\n   592\t```dart\n   593\t// ❌ 错误：无 ident
ifier，Maestro 可能匹配到 Label\n   594\tSwTextField(labelText: \'服务器地址\')\
n   595\t\n   596\t// ✅ 正确：有 identifier，Maestro 精确定位到输入框\n   597\t
SwTextField(\n   598\t  labelText: \'服务器地址\',\n   599\t  identifier: \'serv
er_base_url_field\',\n   600\t)\n   601\t```\n   602\t\n   603\t对应的 Maestro f
low：\n   604\t\n   605\t```yaml\n   606\t# ✅ 正确：通过 id 定位输入框（触发全
选），inputText 自动替换旧内容\n   607\t- tapOn:\n   608\t    id: "server_base_u
rl_field"\n   609\t- inputText: "http://example.com:8080/api/v2"\n   610\t\n   6
11\t# ❌ 错误：通过 label 定位可能匹配到 Text Label，不触发全选\n   612\t- tapOn
: "服务器地址"\n   613\t- inputText: "http://example.com:8080/api/v2" # 追加到旧
内容后\n   614\t```\n   615\t\n   616\t### 禁止的写法\n   617\t\n   618\t以下写
法会导致 Maestro 定位或点击失败，**禁止**在需要通过 E2E 验证的组件中使用：\n   6
19\t\n   620\t1. `Align` 包裹 `GestureDetector` 放在 `Stack` 中\n   621\t2. `Ico
n(semanticLabel: \'xxx\')` 或 `IconButton(tooltip: \'xxx\')` 作为唯一的 accessib
ility 标记\n   622\t3. `GestureDetector(onTap: ...)` 或 `InkWell(onTap: ...)` 用
于 Maestro 必须点击的组件\n   623\t4. `Semantics` 缺少 `container: true`，导致子
节点的 bounds 溢出到父容器\n   624\t5. **输入框使用 `TextField.onChanged` 同步 C
ubit state**\n   625\t6. **输入框未在获得焦点时自动全选旧内容**\n   626\t7. **输
入框缺少 `Semantics(identifier: \'xxx\')`**\n   627\t\n   628\t### 完整参考：悬
浮按钮（已通过 Maestro 验证）\n   629\t\n   630\t```dart\n   631\timport \'packa
ge:flutter/material.dart\';\n   632\timport \'package:social_world_design_system
/social_world_design_system.dart\';\n   633\t\n   634\tclass FloatingActionButto
n extends StatelessWidget {\n   635\t  final VoidCallback onTap;\n   636\t\n   6
37\t  const FloatingActionButton({super.key, required this.onTap});\n   638\t\n 
 639\t  @override\n   640\t  Widget build(BuildContext context) {\n   641\t    f
inal screenHeight = MediaQuery.of(context).size.height;\n   642\t    return Posi
tioned(\n   643\t      right: DesignTokens.spacingXs,\n   644\t      top: screen
Height / 2 - 28,\n   645\t      width: 56,\n   646\t      height: 56,\n   647\t 
    child: Semantics(\n   648\t        identifier: \'dev_tools_toggle_button\',\
n   649\t        label: \'开发工具\',\n   650\t        button: true,\n   651\t  
     container: true,\n   652\t        child: GestureDetector(\n   653\t        
 behavior: HitTestBehavior.opaque,\n   654\t          onTapDown: (_) => onTap(),
\n   655\t          child: Container(\n   656\t            decoration: const Box
Decoration(\n   657\t              color: Colors.black26,\n   658\t             
shape: BoxShape.circle,\n   659\t            ),\n   660\t            child: cons
t Icon(\n   661\t              Icons.construction,\n   662\t              color:
Colors.white,\n   663\t              size: 24,\n   664\t            ),\n   665\t
         ),\n   666\t        ),\n   667\t      ),\n   668\t    );\n   669\t  }\n
  670\t}\n   671\t```\n   672\t\n   673\t## E2E 测试约束\n   674\t\n   675\t任何
涉及用户交互流程的 Mobile 变更，必须遵守 `docs/design-docs/testing.md` 中的 **Mo
