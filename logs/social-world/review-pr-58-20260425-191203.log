yImpl({Dio? dio}) : _dio = dio ?? DioClient().dio;\n   153\t```\n   154\t\n   15
5\t## Socket.io 客户端生命周期\n   156\t\n   157\tIM 等实时通信模块使用 `socket_
io_client` 建立 WebSocket 连接。必须遵循以下规范，避免频繁重连、消息丢失或内存泄
漏。\n   158\t\n   159\t### 1. 连接由 App 生命周期统一管理\n   160\t\n   161\t不
要在单个页面（如 `ChatPage`）的 `initState`/`dispose` 中连接/断开 Socket。应在 `
app.dart` 的 `MultiBlocProvider` 层级统一维护 `ImBloc`（或独立 `SocketClient`）
，仅在用户登出时断开。\n   162\t\n   163\t```dart\n   164\t// ✅ 正确：App 级别
管理连接\n   165\tclass App extends StatefulWidget {\n   166\t  @override\n   16
7\t  State<App> createState() => _AppState();\n   168\t}\n   169\t\n   170\tclas
s _AppState extends State<App> {\n   171\t  @override\n   172\t  void initState(
) {\n   173\t    super.initState();\n   174\t    // 登录状态变更时统一连接/断开\
n   175\t    context.read<AuthBloc>().stream.listen((state) {\n   176\t      if 
(state is AuthAuthenticated) {\n   177\t        context.read<ImBloc>().add(ImCon
nectRequested(state.token));\n   178\t      } else if (state is AuthUnauthentica
ted) {\n   179\t        context.read<ImBloc>().add(const ImDisconnectRequested()
);\n   180\t      }\n   181\t    });\n   182\t  }\n   183\t}\n   184\t```\n   18
5\t\n   186\t### 2. 显式配置重连策略\n   187\t\n   188\t`socket_io_client` 默认
自动重连，但参数不可控。必须在 `io()` 选项中显式声明：\n   189\t\n   190\t```dar
t\n   191\t_socket = io.io(namespaceUrl, <String, dynamic>{\n   192\t  \'transpo
rts\': [\'websocket\'],\n   193\t  \'autoConnect\': true,\n   194\t  \'reconnect
ion\': true,\n   195\t  \'reconnectionAttempts\': 5,\n   196\t  \'reconnectionDe
lay\': 1000,\n   197\t  \'reconnectionDelayMax\': 5000,\n   198\t  \'auth\': <St
ring, dynamic>{\'token\': token},\n   199\t});\n   200\t```\n   201\t\n   202\t#
## 3. 连接状态不得覆盖消息列表状态\n   203\t\n   204\tBLoC 中 `ImConnected` / `I
mDisconnected` 等连接状态**不应**作为独立 state 类直接 `emit`，否则 `BlocConsume
r` 的 builder 会因无法识别新状态而回退到 `CircularProgressIndicator`，导致消息列
表瞬间清空。\n   205\t\n   206\t```dart\n   207\t// ❌ 错误：独立状态类导致 UI 
骨架重置\n   208\tclass ImConnected extends ImState {}\n   209\tclass ImDisconne
cted extends ImState {}\n   210\t\n   211\t// ✅ 正确：在现有消息状态中附加连接
标记\n   212\tclass ImMessagesLoaded extends ImState {\n   213\t  final List<Mes
sageItem> messages;\n   214\t  final bool isConnected; // 附加连接标记\n   215\t
 // ...\n   216\t}\n   217\t```\n   218\t\n   219\t### 4. 消息发送失败必须有降级
处理\n   220\t\n   221\tSocket 未连接时发送消息，不能仅停留在 `"sending"` 状态。
应在发送前检查连接状态，未连接时标记为 `"failed"` 或加入本地待发队列，并暴露 `on
Retry` 回调供 UI 重试。\n   222\t\n   223\t```dart\n   224\t// im_bloc.dart\n   
225\tif (_socketClient?.isConnected ?? false) {\n   226\t  _socketClient!.sendMe
ssage(...);\n   227\t} else {\n   228\t  _messages[index] = tempMessage.copyWith
(status: \'failed\');\n   229\t  emit(ImMessagesLoaded(List.unmodifiable(_messag
es)));\n   230\t}\n   231\t```\n   232\t\n   233\t### 5. 进入/离开会话时清理上下
文\n   234\t\n   235\t`ChatPage` 离开时应调用 `setCurrentConversation(null, null
)`，防止旧会话继续接收已读回执或错误地将新消息追加到已离开的会话。\n   236\t\n  
237\t```dart\n   238\t@override\n   239\tvoid dispose() {\n   240\t  context.rea
d<ImBloc>().setCurrentConversation(null, null);\n   241\t  _scrollController.dis
pose();\n   242\t  super.dispose();\n   243\t}\n   244\t```\n   245\t\n   246\t#
## 6. 跨会话消息隔离与分级缓存\n   247\t\n   248\t当 Socket 收到不属于当前显示会
话的消息时，不能直接丢弃，否则用户进入该会话前无法看到最新消息。必须在 BLoC 中按
会话 ID 分级缓存，切换会话时合并。\n   249\t\n   250\t```dart\n   251\t// ❌ 错
误：非当前会话消息直接 return，导致数据丢失\n   252\tvoid _onMessageReceived(ImM
essageReceived event, Emitter<ImState> emit) {\n   253\t  if (event.message.conv
ersationId != _currentConversationId) return;\n   254\t  _messages.add(event.mes
sage);\n   255\t}\n   256\t\n   257\t// ✅ 正确：按 conversationId 分级缓冲\n   
258\tfinal Map<String, List<MessageItem>> _pendingMessages = {};\n   259\t\n   2
60\tvoid _onMessageReceived(ImMessageReceived event, Emitter<ImState> emit) {\n 
 261\t  if (event.message.conversationId == _currentConversationId) {\n   262\t 
