IR/docs/api-contracts"\nTS_OUT="$ROOT_DIR/packages/shared-types/src/generated"\n
DART_OUT="$ROOT_DIR/apps/mobile/lib/models/generated"\n\necho "=== Generating ty
pes from OpenAPI contracts ==="\n\n# Ensure output directories exist\nmkdir -p "
$TS_OUT"\nmkdir -p "$DART_OUT"\n\n# Collect YAML files (exclude INDEX.md)\nYAML_
FILES=("$CONTRACTS_DIR"/*.yaml)\n\nfor yaml_file in "${YAML_FILES[@]}"; do\n  if
[[ "$(basename "$yaml_file")" == "INDEX.md" ]]; then\n    continue\n  fi\n\n  BA
SENAME=$(basename "$yaml_file" .yaml)\n  echo "--- Generating for $BASENAME ---"
\n\n  # Clean only the target subdirectory\n  rm -rf "$TS_OUT/$BASENAME"\n  rm -
rf "$DART_OUT/$BASENAME"\n\n  # Generate TypeScript client\n  pnpm exec openapi-
generator-cli generate \\\n    -i "$yaml_file" \\\n    -g typescript-fetch \\\n 
  -o "$TS_OUT/$BASENAME" \\\n    --additional-properties=modelPropertyNaming=ori
ginal,supportsES6=true,npmName=@social-world/shared-types-$BASENAME-typescript \
\\n    > /dev/null\n\n  # Generate Dart models\n  pnpm exec openapi-generator-cl
i generate \\\n    -i "$yaml_file" \\\n    -g dart \\\n    -o "$DART_OUT/$BASENA
ME" \\\n    --additional-properties=pubName=social_world_${BASENAME}_models \\\n
   > /dev/null\ndone\n\n# Rebuild shared-types index.ts exports\nINDEX_FILE="$RO
OT_DIR/packages/shared-types/src/index.ts"\ncat > "$INDEX_FILE" << \'EOF\'\n// S
hared types and API contracts for Social World\n// This package serves as the si
ngle source of truth for API interfaces.\n\nexport interface ApiResponse<T> {\n 
code: number;\n  message: string;\n  data: T;\n}\n\nexport interface CursorPagin
ation<T> {\n  items: T[];\n  next_cursor: string | null;\n  has_more: boolean;\n
}\n\nEOF\n\nfor dir in "$TS_OUT"/*/; do\n  if [ -f "$dir/package.json" ] || [ -f
