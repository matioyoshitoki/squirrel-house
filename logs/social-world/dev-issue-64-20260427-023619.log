ith:"; do\n    if ! grep -q "$tag" "$f"; then\n      echo "❌ flow 缺少元数据 $t
ag: $f"\n      ERRORS=$((ERRORS + 1))\n    fi\n  done\ndone\n\n# 4. regression: 
