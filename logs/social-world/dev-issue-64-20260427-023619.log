aestro/flows"\nCONFIG_FILE=".maestro/config.yaml"\n\necho "[maestro-check] Runni
ng Maestro harness checks..."\n\n# 1. config.yaml 必须存在且包含 appId\nif [[ ! 
-f "$CONFIG_FILE" ]]; then\n  echo "❌ 缺少全局配置: $CONFIG_FILE"\n  ERRORS=$((
ERRORS + 1))\nelse\n  if ! grep -q "^appId:" "$CONFIG_FILE"; then\n    echo "❌ 
$CONFIG_FILE 缺少 appId"\n    ERRORS=$((ERRORS + 1))\n  fi\nfi\n\n# 2. flows/ 下
只允许子目录，禁止顶层 YAML\nfor f in "$FLOW_DIR"/*.yaml; do\n  if [[ -f "$f" ]]
; then\n    echo "❌ flows/ 下存在未分类的顶层 YAML: $f"\n    echo "   修复: 将
其移动到 flows/<module>/ 子目录下"\n    ERRORS=$((ERRORS + 1))\n  fi\ndone\n\n# 
3. 每个 .yaml 必须包含 @flow 元数据头（_*.yaml 为 partial include，跳过）\nfor f
in $(find "$FLOW_DIR" -name "*.yaml" 2>/dev/null); do\n  if [[ "$(basename "$f")
" == _* ]]; then\n    continue\n  fi\n  if ! head -n 1 "$f" | grep -q "# @flow";
then\n    echo "❌ flow 缺少 @flow 头: $f"\n    ERRORS=$((ERRORS + 1))\n  fi\n  
