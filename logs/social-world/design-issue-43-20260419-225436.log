ntCard.querySelector(\'.swipe-badge.pass\');\n      if (likeBadge) likeBadge.sty
le.opacity = currentX > 60 ? Math.min(currentX / 120, 1) : 0;\n      if (passBad
ge) passBadge.style.opacity = currentX < -60 ? Math.min(Math.abs(currentX) / 120
, 1) : 0;\n    }\n\n    function endDrag() {\n      if (!isDragging || !currentC
ard) return;\n      isDragging = false;\n      currentCard.style.transition = \'
