  conversationId: string,\n    content: string,\n    manager?: EntityManager,\n 
): Promise<MessageEntity> {\n    const repo = manager ? manager.getRepository(Me
ssageEntity) : this.messageRepo;\n    const message = repo.create({ ... });\n   
await repo.save(message);\n    return message;\n  }\n  ```\n并在 `MatchingServic
