ger.of(context).showSnackBar(\n      const SnackBar(content: Text(\'请输入手机号
和6位验证码\')),\n    );\n    return;\n  }\n  context.read<AuthBloc>().add(Login
Requested(phone: phone, code: code));\n}\n```\n\nAnd the AuthBloc `_onLoginReque
sted`:\n```dart\nemit(const AuthAuthenticating());\ntry {\n  final loginResponse
