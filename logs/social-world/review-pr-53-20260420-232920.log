ing_state.dart\nabstract class MatchingState {}\nclass MatchingInitial extends M
atchingState {}\nclass MatchingLoadInProgress extends MatchingState {}\nclass Ma
tchingLoadSuccess extends MatchingState {\n  final List<RecommendationCard> card
s;\n  final String mode;\n}\nclass MatchingLoadEmpty extends MatchingState {\n  
