ActionButtonVariant.pass \\n      ? \'swipe_pass_button\' \\n      : \'swipe_lik
e_button\',\\n  label: variant == SwActionButtonVariant.pass ? \'跳过\' : \'喜欢
\',\\n  button: true,\\n  child: GestureDetector(\\n    onTapDown: isDisabled ? 
