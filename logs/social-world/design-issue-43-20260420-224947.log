itioned(\n   404\t      right: DesignTokens.spacingXs,\n   405\t      top: scree
nHeight / 2 - 28,\n   406\t      width: 56,\n   407\t      height: 56,\n   408\t
     child: Semantics(\n   409\t        identifier: \'dev_tools_toggle_button\',
\n   410\t        label: \'开发工具\',\n   411\t        button: true,\n   412\t 
      container: true,\n   413\t        child: GestureDetector(\n   414\t       
  behavior: HitTestBehavior.opaque,\n   415\t          onTapDown: (_) => onTap()
,\n   416\t          child: Container(\n   417\t            decoration: const Bo
xDecoration(\n   418\t              color: Colors.black26,\n   419\t            
 shape: BoxShape.circle,\n   420\t            ),\n   421\t            child: con
st Icon(\n   422\t              Icons.construction,\n   423\t              color
: Colors.white,\n   424\t              size: 24,\n   425\t            ),\n   426
