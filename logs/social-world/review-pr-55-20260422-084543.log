dCallback onTap;\n   412\t\n   413\t  const FloatingActionButton({super.key, req
uired this.onTap});\n   414\t\n   415\t  @override\n   416\t  Widget build(Build
Context context) {\n   417\t    final screenHeight = MediaQuery.of(context).size
.height;\n   418\t    return Positioned(\n   419\t      right: DesignTokens.spac
ingXs,\n   420\t      top: screenHeight / 2 - 28,\n   421\t      width: 56,\n   
422\t      height: 56,\n   423\t      child: Semantics(\n   424\t        identif
ier: \'dev_tools_toggle_button\',\n   425\t        label: \'开发工具\',\n   426\
t        button: true,\n   427\t        container: true,\n   428\t        child:
GestureDetector(\n   429\t          behavior: HitTestBehavior.opaque,\n   430\t 
        onTapDown: (_) => onTap(),\n   431\t          child: Container(\n   432\
t            decoration: const BoxDecoration(\n   433\t              color: Colo
rs.black26,\n   434\t              shape: BoxShape.circle,\n   435\t            
),\n   436\t            child: const Icon(\n   437\t              Icons.construc
tion,\n   438\t              color: Colors.white,\n   439\t              size: 2
4,\n   440\t            ),\n   441\t          ),\n   442\t        ),\n   443\t  
   ),\n   444\t    );\n   445\t  }\n   446\t}\n   447\t```\n   448\t\n   449\t##
E2E 测试约束\n   450\t\n   451\t任何涉及用户交互流程的 Mobile 变更，必须遵守 `do
cs/design-docs/testing.md` 中的 **Mobile UI E2E 测试（Maestro）** 规范：\n   452
\t\n   453\t- 新建/修改 `.maestro/flows/*.yaml`\n   454\t- Commit 前在本地 emula
tor 跑通 `make test-mobile-e2e-login`\n   455\t- 定位优先使用 `Semantics(identif
ier: \'xxx\')` 生成的 `resource-id`，或 `Semantics(label: \'xxx\')` 暴露的 `cont
