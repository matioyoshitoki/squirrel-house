eturn;\\n    emit(state.copyWith(isSaving: true));\\n    await _repository.saveS
erverBaseUrl(state.serverBaseUrl);\\n    emit(state.copyWith(isSaving: false, sa
veSuccess: true));\\n  }\\n}\\n```\\n\\n#### Repository 接口（Domain 层）\\n\\n`
``dart\\n// apps/mobile/lib/domain/repositories/dev_tools_repository.dart\\nabst
ract class DevToolsRepository {\\n  Future<String> getServerBaseUrl();\\n  Futur
