AME=$(basename "$yaml_file" .yaml)\n  echo "--- Generating for $BASENAME ---"\n\
n  # Clean only the target subdirectory\n  rm -rf "$TS_OUT/$BASENAME"\n  rm -rf 
"$DART_OUT/$BASENAME"\n\n  # Generate TypeScript client\n  pnpm exec openapi-gen
erator-cli generate \\\n    -i "$yaml_file" \\\n    -g typescript-fetch \\\n    
