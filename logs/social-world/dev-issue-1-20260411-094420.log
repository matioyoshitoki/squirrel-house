-contract-sync] Checking if generated types are up-to-date..."\n\n# Stash curren
t generated code state\ncd "$ROOT_DIR"\n\n# Run generation in a temp directory t
o avoid polluting the working tree\nTEMP_DIR=$(mktemp -d)\ntrap "rm -rf $TEMP_DI
R" EXIT\n\n# Copy existing generated files to temp for comparison\ncp -r "$ROOT_
DIR/packages/shared-types/src/generated" "$TEMP_DIR/ts" 2>/dev/null || true\ncp 
-r "$ROOT_DIR/apps/mobile/lib/models/generated" "$TEMP_DIR/dart" 2>/dev/null || 
true\n\n# Run generation\nGENERATOR="@openapitools/openapi-generator-cli"\nCONTR
ACTS_DIR="$ROOT_DIR/docs/api-contracts"\n\nmkdir -p "$TEMP_DIR/ts-new"\nmkdir -p
"$TEMP_DIR/dart-new"\n\nif command -v npx &> /dev/null; then\n  for contract in 
auth profile matching im; do\n    if [ -f "$CONTRACTS_DIR/${contract}.yaml" ]; t
hen\n      npx "$GENERATOR" generate \\\n        -i "$CONTRACTS_DIR/${contract}.
yaml" \\\n        -g typescript-fetch \\\n        -o "$TEMP_DIR/ts-new/${contrac
t}" \\\n        --additional-properties=modelPropertyNaming=original,supportsES6
=true,typescriptThreePlus=true \\\n        > /dev/null 2>&1 || true\n\n      npx
"$GENERATOR" generate \\\n        -i "$CONTRACTS_DIR/${contract}.yaml" \\\n     
  -g dart-dio \\\n        -o "$TEMP_DIR/dart-new/${contract}" \\\n        --addi
tional-properties=pubName=social_world_${contract}_api,pubLibrary=social_world_$
{contract}_api \\\n        > /dev/null 2>&1 || true\n    fi\n  done\nfi\n\n# Com
pare\nDIFF_TS=$(diff -rq "$TEMP_DIR/ts" "$TEMP_DIR/ts-new" 2>/dev/null || true)\
nDIFF_DART=$(diff -rq "$TEMP_DIR/dart" "$TEMP_DIR/dart-new" 2>/dev/null || true)
\n\nif [ -n "$DIFF_TS" ] || [ -n "$DIFF_DART" ]; then\n  echo "❌ Contract sync 
