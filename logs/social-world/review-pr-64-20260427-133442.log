109\tdown(): Promise<void> {\n   110\t  await queryRunner.query(`ALTER TABLE mes
sages MODIFY sender_id CHAR(36) NOT NULL`);\n   111\t}\n   112\t\n   113\t// ✅ 
正确：先处理 NULL 数据，再改约束\n   114\tdown(): Promise<void> {\n   115\t  // 
1. 为 system 消息填充占位值，或删除不符合条件的记录\n   116\t  await queryRunner
.query(`UPDATE messages SET sender_id = \'SYSTEM\' WHERE sender_id IS NULL`);\n 
