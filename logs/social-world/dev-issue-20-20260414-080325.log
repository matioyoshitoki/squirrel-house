rthMonth === 1 && birthDay === 29) {\n     9\t    const isLeapYear = (year: numb
er) =>\n    10\t      (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;\
n    11\t    if (!isLeapYear(now.getUTCFullYear())) {\n    12\t      birthMonth 
