nc {\n   195\t    final error = _validateUrl(state.serverBaseUrl);\n   196\t    
if (error.isNotEmpty) return;\n   197\t    emit(state.copyWith(isSaving: true));
\n   198\t    await _repository.saveServerBaseUrl(state.serverBaseUrl);\n   199\
