,\n   158\t    @Default(false) bool saveSuccess,\n   159\t  }) = _DevToolsState;
\n   160\t}\n   161\t```\n   162\t\n   163\t#### Cubit\n   164\t\n   165\t```dar
t\n   166\t// apps/mobile/lib/presentation/blocs/dev_tools/dev_tools_cubit.dart\
n   167\tclass DevToolsCubit extends Cubit<DevToolsState> {\n   168\t  DevToolsC
ubit(this._repository)\n   169\t      : super(const DevToolsState());\n   170\t\
n   171\t  final DevToolsRepository _repository;\n   172\t\n   173\t  Future<voi
d> load() async {\n   174\t    final url = await _repository.getServerBaseUrl();
\n   175\t    emit(state.copyWith(serverBaseUrl: url));\n   176\t  }\n   177\t\n
  178\t  void onUrlChanged(String url) {\n   179\t    emit(state.copyWith(\n   1
