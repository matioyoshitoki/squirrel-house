tion.id });\n   479\t\n   480\t// im.module.ts 中监听\n   481\t@OnEvent(\'match:
created\')\n   482\tasync handleMatchCreated(payload: MatchCreatedEvent) {\n   4
83\t  await this.imService.createSystemMessage(payload.conversationId, \'你们已
匹配成功，开始聊天吧\');\n   484\t}\n   485\t```\n   486\t\n   487\t> **原则**：
优先使用方案 B 降低模块耦合；只有强一致性要求（如原子性必须包含 message 创建）时
才使用方案 A。\n   488\t\n   489\t### 数据库事务与 Redis 的边界\n   490\t\n   49
1\tRedis 等非数据库操作**不得**放在数据库事务（`dataSource.transaction`）内部执
行。原因：\n   492\t\n   493\t1. Redis 不支持参与数据库的两阶段提交，事务回滚时 
Redis 操作无法回滚，导致数据不一致\n   494\t2. Redis 操作可能因网络延迟拖长数据
库事务持有时间，增加锁竞争和连接池压力\n   495\t\n   496\t```typescript\n   497\
t// ❌ 错误：Redis incr 在事务内执行，DB 回滚后 Redis 未读数无法回滚\n   498\taw
ait this.dataSource.transaction(async (manager) => {\n   499\t  await manager.sa
ve(message);\n   500\t  await this.redisClient.incr(`unread_count:${userId}:${co
nversationId}`); // 无法回滚\n   501\t  await manager.save(conversation);\n   50
2\t});\n   503\t\n   504\t// ✅ 正确：Redis 操作在事务提交成功后执行\n   505\taw
ait this.dataSource.transaction(async (manager) => {\n   506\t  await manager.sa
ve(message);\n   507\t  await manager.save(conversation);\n   508\t});\n   509\t
// 事务已提交，再更新 Redis\n   510\tawait this.redisClient.incr(`unread_count:$
{userId}:${conversationId}`);\n   511\t```\n   512\t\n   513\t> **原则**：事务内
只做数据库操作；事务提交成功后，再执行 Redis、消息队列、事件发射等副作用。若 Red
is 失败，应记录降级日志并预留后台补偿机制（如定时任务重新计算未读数）。\n   514\
t\n   515\t### 跨模块共享资源（Redis、数据库连接池）\n   516\t\n   517\t各业务模
块禁止自行 `new Redis()` 创建独立的 Redis 客户端。重复创建会导致连接数翻倍、资源
