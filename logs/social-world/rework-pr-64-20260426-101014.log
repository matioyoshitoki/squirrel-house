mpl implements AuthRepository {\n   210\t  final Dio _dio;\n   211\t  AuthReposi
toryImpl({Dio? dio}) : _dio = dio ?? getIt<DioClient>().dio;\n   212\t}\n   213\
t\n   214\t// ❌ 错误（会导致多个 Dio 实例，baseUrl 热更新失效）\n   215\tAuthRe
positoryImpl({Dio? dio}) : _dio = dio ?? DioClient().dio;\n   216\t```\n   217\t
\n   218\t## Socket.io 客户端生命周期\n   219\t\n   220\tIM 等实时通信模块使用 `
socket_io_client` 建立 WebSocket 连接。必须遵循以下规范，避免频繁重连、消息丢失
或内存泄漏。\n   221\t\n   222\t### 1. 连接由 App 生命周期统一管理\n   223\t\n  
224\t不要在单个页面（如 `ChatPage`）的 `initState`/`dispose` 中连接/断开 Socket
。应在 `app.dart` 的 `MultiBlocProvider` 层级统一维护 `ImBloc`（或独立 `SocketCl
ient`），仅在用户登出时断开。\n   225\t\n   226\t```dart\n   227\t// ✅ 正确：Ap
p 级别管理连接\n   228\tclass App extends StatefulWidget {\n   229\t  @override\
n   230\t  State<App> createState() => _AppState();\n   231\t}\n   232\t\n   233
\tclass _AppState extends State<App> {\n   234\t  @override\n   235\t  void init
State() {\n   236\t    super.initState();\n   237\t    // 登录状态变更时统一连接
/断开\n   238\t    context.read<AuthBloc>().stream.listen((state) {\n   239\t   
  if (state is AuthAuthenticated) {\n   240\t        context.read<ImBloc>().add(
ImConnectRequested(state.token));\n   241\t      } else if (state is AuthUnauthe
nticated) {\n   242\t        context.read<ImBloc>().add(const ImDisconnectReques
ted());\n   243\t      }\n   244\t    });\n   245\t  }\n   246\t}\n   247\t```\n
  248\t\n   249\t### 2. 显式配置重连策略\n   250\t\n   251\t`socket_io_client` 
默认自动重连，但参数不可控。必须在 `io()` 选项中显式声明：\n   252\t\n   253\t``
`dart\n   254\t_socket = io.io(namespaceUrl, <String, dynamic>{\n   255\t  \'tra
nsports\': [\'websocket\'],\n   256\t  \'autoConnect\': true,\n   257\t  \'recon
nection\': true,\n   258\t  \'reconnectionAttempts\': 5,\n   259\t  \'reconnecti
onDelay\': 1000,\n   260\t  \'reconnectionDelayMax\': 5000,\n   261\t  \'auth\':
<String, dynamic>{\'token\': token},\n   262\t});\n   263\t```\n   264\t\n   265
\t### 3. 连接状态不得覆盖消息列表状态\n   266\t\n   267\tBLoC 中 `ImConnected` /
`ImDisconnected` 等连接状态**不应**作为独立 state 类直接 `emit`，否则 `BlocConsu
mer` 的 builder 会因无法识别新状态而回退到 `CircularProgressIndicator`，导致消息
列表瞬间清空。\n   268\t\n   269\t```dart\n   270\t// ❌ 错误：独立状态类导致 UI
骨架重置\n   271\tclass ImConnected extends ImState {}\n   272\tclass ImDisconne
cted extends ImState {}\n   273\t\n   274\t// ✅ 正确：在现有消息状态中附加连接
标记\n   275\tclass ImMessagesLoaded extends ImState {\n   276\t  final List<Mes
sageItem> messages;\n   277\t  final bool isConnected; // 附加连接标记\n   278\t
 // ...\n   279\t}\n   280\t```\n   281\t\n   282\t### 4. 消息发送失败必须有降级
处理\n   283\t\n   284\tSocket 未连接时发送消息，不能仅停留在 `"sending"` 状态。
应在发送前检查连接状态，未连接时标记为 `"failed"` 或加入本地待发队列，并暴露 `on
Retry` 回调供 UI 重试。\n   285\t\n   286\t```dart\n   287\t// im_bloc.dart\n   
288\tif (_socketClient?.isConnected ?? false) {\n   289\t  _socketClient!.sendMe
ssage(...);\n   290\t} else {\n   291\t  _messages[index] = tempMessage.copyWith
(status: \'failed\');\n   292\t  emit(ImMessagesLoaded(List.unmodifiable(_messag
es)));\n   293\t}\n   294\t```\n   295\t\n   296\t### 5. 进入/离开会话时清理上下
文\n   297\t\n   298\t`ChatPage` 离开时应调用 `setCurrentConversation(null, null
)`，防止旧会话继续接收已读回执或错误地将新消息追加到已离开的会话。\n   299\t\n  
300\t```dart\n   301\t@override\n   302\tvoid dispose() {\n   303\t  context.rea
d<ImBloc>().setCurrentConversation(null, null);\n   304\t  _scrollController.dis
pose();\n   305\t  super.dispose();\n   306\t}\n   307\t```\n   308\t\n   309\t#
## 6. 跨会话消息隔离与分级缓存\n   310\t\n   311\t当 Socket 收到不属于当前显示会
话的消息时，不能直接丢弃，否则用户进入该会话前无法看到最新消息。必须在 BLoC 中按
会话 ID 分级缓存，切换会话时合并。\n   312\t\n   313\t```dart\n   314\t// ❌ 错
误：非当前会话消息直接 return，导致数据丢失\n   315\tvoid _onMessageReceived(ImM
essageReceived event, Emitter<ImState> emit) {\n   316\t  if (event.message.conv
ersationId != _currentConversationId) return;\n   317\t  _messages.add(event.mes
sage);\n   318\t}\n   319\t\n   320\t// ✅ 正确：按 conversationId 分级缓冲\n   
321\tfinal Map<String, List<MessageItem>> _pendingMessages = {};\n   322\t\n   3
23\tvoid _onMessageReceived(ImMessageReceived event, Emitter<ImState> emit) {\n 
 324\t  if (event.message.conversationId == _currentConversationId) {\n   325\t 
