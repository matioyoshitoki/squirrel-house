n+            text: state.isCountingDown ? \'${state.countdown}s\' : \'获取验证
码\',\n+            onPressed: () => context.read<LoginCubit>().startCountdown()
,\n+          );\n+        },\n+      ),\n+    );\n+  }\n+}\n+\n+// ❌ Page 直接
管理倒计时和校验\n+class _LoginPageState extends State<LoginPage> {\n+  bool _is
