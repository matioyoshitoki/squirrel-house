reate: (_) => LoginCubit(),\n+      child: BlocBuilder<LoginCubit, LoginState>(\
n+        builder: (context, state) {\n+          return SwButton(\n+           
text: state.isCountingDown ? '${state.countdown}s' : '获取验证码',\n+           
onPressed: () => context.read<LoginCubit>().startCountdown(),\n+          );\n+ 
      },\n+      ),\n+    );\n+  }\n+}\n+\n+// ❌ Page 直接管理倒计时和校验\n+cl
