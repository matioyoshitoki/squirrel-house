ec-plans/INDEX.md"\n  "docs/QUALITY_SCORE.md"\n  "prd/v1-mvp.md"\n)\n\nfor doc i
n "${REQUIRED_DOCS[@]}"; do\n  if [ ! -f "$doc" ]; then\n    echo "❌ 必需文档缺
失: $doc"\n    echo "   规则: 该文档是 Agent-First 最小可用结构的必需文件"\n    
echo "   修复: 创建 $doc 并补充必要内容"\n    ERRORS=$((ERRORS + 1))\n  fi\ndone
\n\n# 3. 检查死链（docs/ 和 prd/ 下的相对路径链接）\nfor file in $(find docs prd
-name "*.md"); do\n  sed -n \'s/.*\\](\\([^)]*\\)).*/\\1/p\' "$file" | while rea
