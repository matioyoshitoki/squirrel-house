s React from \'react\';\\nimport type { ColorMode } from \'../types\';\\n\\n/** 
主题 Provider 组件 */\\nexport declare const ThemeProvider: React.FC<{\\n  initi
alColorMode?: ColorMode;\\n  children: React.ReactNode;\\n}>;\\n\\n/**\\n * 读取
