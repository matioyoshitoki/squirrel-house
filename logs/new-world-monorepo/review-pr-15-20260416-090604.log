vate calcDiagonalIndex(x: number, y: number, width: number, height: number): num
ber {\n   646\t    const d = x + y;\n   647\t    const minDim = Math.min(width, 
height);\n   648\t    const maxDim = Math.max(width, height);\n   649\t\n   650\
