wardClaimed(ctx, uid, questID, dateKey)\n    if claimed {\n        return CLAIME
D\n    }\n    progress, _ := questRepo.GetDailyProgress(ctx, uid, questID, dateK
ey)\n    if progress >= cfg.TargetValue {\n        return CLAIMABLE, progress\n 
