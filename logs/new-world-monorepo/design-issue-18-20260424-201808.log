');\\n}\\n\\n/**\\n * 模拟 Hover 离开\\n */\\nexport function simulateHoverOut(\
\n  target: { emit: (event: string, ...args: unknown[]) => void }\\n): void {\\n
 target.emit(\'pointerout\');\\n}\\n\\n/**\\n * 模拟 Pressed（按下未释放）\\n */
