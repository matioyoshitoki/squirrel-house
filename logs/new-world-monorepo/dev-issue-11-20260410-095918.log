otobuf/proto"\n)\n\n// LeaderboardSubscriber 排行榜事件订阅者\ntype LeaderboardS
ubscriber struct {\n\tleaderboardUC *wapi.LeaderboardUseCase\n}\n\n// NewLeaderb
oardSubscriber 创建排行榜订阅者\nfunc NewLeaderboardSubscriber(leaderboardUC *wa
pi.LeaderboardUseCase) *LeaderboardSubscriber {\n\treturn &LeaderboardSubscriber
