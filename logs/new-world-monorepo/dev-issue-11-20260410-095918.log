rdSubscriber) HandleEvent(ctx context.Context, event *sharedpb.Event) error {\n\
tswitch event.EventType {\n\tcase sharedpb.EventType_USER_LEVEL_UP:\n\t\treturn 
s.handleUserLevelUp(ctx, event)\n\tcase sharedpb.EventType_ASSET_GAIN:\n\t\tretu
rn s.handleAssetGain(ctx, event)\n\tcase sharedpb.EventType_COMBAT_KILL:\n\t\tre
