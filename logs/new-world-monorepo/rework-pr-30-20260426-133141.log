? camera.height / 2,\n      width: config.width ?? 360,\n      height: config.he
ight ?? 220,\n      title: config.title,\n      showClose: false,\n      showOve
rlay: true,\n      overlayAlpha: 0.6,\n      isModal: true,\n      depth: config
.depth ?? getNextDepth(UIDepthLayer.Dialog, scene),\n      onClose: config.onClo
se,\n      // 不在 super 前传递依赖 this 的回调\n      onOverlayClick: undefined
,\n    };\n\n    super(scene, panelConfig);\n\n    // super() 之后手动绑定 overl
ay 点击事件\n    if (config.closeOnOverlay && this.overlay) {\n      this.overla
y.removeListener(\'pointerdown\');\n      this.overlay.on(\'pointerdown\', () =>
this.cancel());\n    }\n\n    // ...后续代码不变\n  }\n  ```\n- **依据**: ECMASc
ript Class Fields & TDZ 规范；TypeScript `noImplicitAny`/`strict` 模式下编译器明
确报错。\n\n---\n\n## 严重问题（Major）\n\n### 2. UIButton `onClick` 在 yoyo twe
