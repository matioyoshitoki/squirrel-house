 static show(scene: Scene, config: UIToastConfig): UIToast {\\n    const toast =
new UIToast(scene, config);\\n    toast.show();\\n    return toast;\\n  }\\n}\\n
\\nexport class ToastManager {\\n  private static instances = new WeakMap<Scene,
