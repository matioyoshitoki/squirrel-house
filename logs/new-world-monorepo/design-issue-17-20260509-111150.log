onfig.message,\\n      type: config.type ?? \'info\',\\n      duration: config.d
uration ?? 3000,\\n      icon: config.icon ?? \'\',\\n      texture: config.text
ure ?? \'\',\\n      depth: config.depth ?? getNextDepth(UIDepthLayer.Toast, sce
ne),\\n    };\\n\\n    this.baseY = this.y;\\n    this.setDepth(this.config.dept
h);\\n\\n    this.createBackground();\\n    this.createContent();\\n\\n    scene
.add.existing(this);\\n  }\\n\\n  private getTypeColor(): number {\\n    switch 
(this.config.type) {\\n      case \'success\': return UITheme.stoneCyan;\\n     
case \'warning\': return UITheme.warning;\\n      case \'error\': return UITheme
.cinnabarRed;\\n      default: return UITheme.indigoBlue;\\n    }\\n  }\\n\\n  p
rivate createBackground(): void {\\n    const color = this.getTypeColor();\\n   
this.background = this.scene.add.rectangle(0, 0, 350, 56, UITheme.inkBlack, 0.95
);\\n    this.background.setStrokeStyle(2, UITheme.goldBrown);\\n    this.backgr
ound.setOrigin(0.5);\\n    this.add(this.background);\\n\\n    const leftBar = t
his.scene.add.rectangle(-350 / 2 + 2, 0, 4, 56 - 4, color, 1);\\n    this.add(le
ftBar);\\n  }\\n\\n  private createContent(): void {\\n    const msg = this.scen
e.add.text(0, 0, this.config.message,\\n      getInkTextStyle(\'14px\', \'#fffff
f\')\\n    ).setOrigin(0.5);\\n    this.add(msg);\\n  }\\n\\n  show(): void {\\n
   this.setVisible(true);\\n    killTweensOf(this.scene, this, () => {\\n      t
