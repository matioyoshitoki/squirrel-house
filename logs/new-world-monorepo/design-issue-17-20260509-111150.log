n    });\\n\\n    if (this.config.duration > 0) {\\n      if (this.autoHideEvent
) {\\n        this.autoHideEvent.remove();\\n      }\\n      this.autoHideEvent 
= this.scene.time.delayedCall(this.config.duration, () => {\\n        this.dismi
ss();\\n      });\\n    }\\n  }\\n\\n  dismiss(): void {\\n    if (this.autoHide
