ackground!: Phaser.GameObjects.Rectangle;\\n  private baseY = 0;\\n  private aut
oHideEvent?: Phaser.Time.TimerEvent;\\n\\n  constructor(scene: Scene, config: UI
ToastConfig) {\\n    super(scene, config.x ?? 0, config.y ?? 0);\\n\\n    this.c
