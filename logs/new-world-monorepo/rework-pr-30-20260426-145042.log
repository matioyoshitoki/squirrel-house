heme } from '@/ui';\n    40\t\n    41\t// 按钮\n    42\tconst btn = new UIButton
(this, {\n    43\t  x: 100, y: 100,\n    44\t  text: '点击我',\n    45\t  onClic
k: () => console.log('clicked'),\n    46\t});\n    47\t\n    48\t// 面板\n    49
\tconst panel = new UIPanel(this, {\n    50\t  x: 400, y: 300,\n    51\t  width:
400, height: 300,\n    52\t  title: '设置',\n    53\t  showClose: true,\n    54\
t});\n    55\t\n    56\t// 对话框\n    57\tUIDialog.show(this, {\n    58\t  titl
