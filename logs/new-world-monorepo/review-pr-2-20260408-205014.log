t}\n\treturn nil\n}\n\nfunc (c *redisStreamConsumer) consumePartition(ctx contex
t.Context, streamKey string) {\n\tdefer c.wg.Done()\n\tconsumerID := c.config.Co
nsumerID\n\tif consumerID == "" {\n\t\tconsumerID = fmt.Sprintf("consumer-%d", t
ime.Now().UnixNano())\n\t}\n\n\t// 阶段 1: 处理 PEL 中的历史消息\n\tc.processPen
