ncyChecker(client redis.UniversalClient, config *Config) IdempotencyChecker {\n\
tif config == nil {\n\t\tconfig = DefaultConfig()\n\t}\n\treturn &redisIdempoten
cyChecker{\n\t\tclient: client,\n\t\tprefix: config.IdempotentKeyPrefix,\n\t\ttt
l:    config.IdempotentTTL,\n\t}\n}\n\nfunc (c *redisIdempotencyChecker) IsProce
ssed(ctx context.Context, eventID string) (bool, error) {\n\tkey := c.key(eventI
