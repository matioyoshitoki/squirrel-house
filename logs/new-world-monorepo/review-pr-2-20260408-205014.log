eturn\n\t\t}\n\t\tif len(streams) == 0 || len(streams[0].Messages) == 0 {\n\t\t\
treturn\n\t\t}\n\n\t\tc.handleMessages(ctx, streamKey, streams[0].Messages)\n\t}
\n}\n\nfunc (c *redisStreamConsumer) handleMessages(ctx context.Context, streamK
ey string, messages []redis.XMessage) {\n\tfor _, msg := range messages {\n\t\tc
.handleMessage(ctx, streamKey, msg)\n\t}\n}\n\nfunc (c *redisStreamConsumer) han
dleMessage(ctx context.Context, streamKey string, msg redis.XMessage) {\n\tdataV
al, ok := msg.Values["data"]\n\tif !ok {\n\t\t// 无法解析的消息，直接 ACK 避免阻
塞\n\t\tc.ack(ctx, streamKey, msg.ID)\n\t\treturn\n\t}\n\n\tdataBytes, ok := dat
aVal.([]byte)\n\tif !ok {\n\t\tc.ack(ctx, streamKey, msg.ID)\n\t\treturn\n\t}\n\
