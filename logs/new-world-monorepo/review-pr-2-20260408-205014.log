, err := c.checker.IsProcessed(ctx, event.EventId)\n\tif err != nil {\n\t\tlog.C
ontext(ctx).Warnw("idempotency check failed", "event_id", event.EventId, "error"
, err)\n\t\t// 检查失败时不 ACK，让消息保留在 PEL 中稍后重试\n\t\treturn\n\t}\n\
tif processed {\n\t\t// 已处理，直接 ACK\n\t\tc.ack(ctx, streamKey, msg.ID)\n\t\
