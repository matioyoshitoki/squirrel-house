e IdempotencyChecker interface {\n\t// IsProcessed 检查事件是否已处理\n\t// 返回
true 表示已处理，false 表示未处理\n\tIsProcessed(ctx context.Context, eventID st
ring) (bool, error)\n\t// MarkProcessed 标记事件为已处理\n\tMarkProcessed(ctx co
ntext.Context, eventID string) error\n}\n\ntype redisIdempotencyChecker struct {
