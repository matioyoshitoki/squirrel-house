\n\t\tchecker:   checker,\n\t\tprocessor: processor,\n\t\tlogger:    logger,\n\t
\tstopCh:    make(chan struct{}),\n\t}\n}\n\nfunc (c *redisStreamConsumer) Start
(ctx context.Context) error {\n\tlog.Context(ctx).Infow("event consumer starting
",\n\t\t"group", c.config.ConsumerGroup,\n\t\t"consumer_id", c.config.ConsumerID
,\n\t\t"partitions", c.config.Partition,\n\t)\n\n\tfor i := 0; i < c.config.Part
ition; i++ {\n\t\tstreamKey := fmt.Sprintf("%s:%d", c.config.StreamKeyPrefix, i)
