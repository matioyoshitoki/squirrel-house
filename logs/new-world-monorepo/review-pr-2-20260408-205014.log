org/protobuf/proto"\n)\n\n// StreamPublisher 定义事件发布到 Redis Stream 的接口\
ntype StreamPublisher interface {\n\t// Publish 将事件写入对应分区的 Redis Strea
m\n\tPublish(ctx context.Context, event *sharedpb.Event) error\n}\n\ntype redisS
treamPublisher struct {\n\tclient    redis.UniversalClient\n\tconfig    *Config\
n\tpartition int\n}\n\n// NewRedisStreamPublisher 创建基于 Redis Stream 的发布器
\nfunc NewRedisStreamPublisher(client redis.UniversalClient, config *Config) Str
eamPublisher {\n\tif config == nil {\n\t\tconfig = DefaultConfig()\n\t}\n\tif co
nfig.Partition <= 0 {\n\t\tconfig.Partition = 16\n\t}\n\treturn &redisStreamPubl
isher{\n\t\tclient:    client,\n\t\tconfig:    config,\n\t\tpartition: config.Pa
rtition,\n\t}\n}\n\n// Publish 将事件发布到 Redis Stream\n// 分区策略: user_id %
partition\nfunc (p *redisStreamPublisher) Publish(ctx context.Context, event *sh
aredpb.Event) error {\n\tif event == nil {\n\t\treturn fmt.Errorf("event is nil"
)\n\t}\n\tstreamKey := p.streamKey(event.UserId)\n\tdata, err := proto.Marshal(e
vent)\n\tif err != nil {\n\t\treturn fmt.Errorf("marshal event failed: %w", err)
\n\t}\n\treturn p.client.XAdd(ctx, &redis.XAddArgs{\n\t\tStream: streamKey,\n\t\
tValues: map[string]interface{}{\n\t\t\t"data": data,\n\t\t},\n\t}).Err()\n}\n\n
func (p *redisStreamPublisher) streamKey(userID int64) string {\n\tpartition := 
int(userID) % p.partition\n\tif partition < 0 {\n\t\tpartition = -partition\n\t}
\n\treturn fmt.Sprintf("%s:%d", p.config.StreamKeyPrefix, partition)\n}\n',
