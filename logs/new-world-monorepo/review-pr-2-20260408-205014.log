        output='package eventbus\n\nimport (\n\t"context"\n\t"fmt"\n\t"sync"\n\n
\tsharedpb "new-world/api/shared/v1"\n\n\t"github.com/go-kratos/kratos/v2/log"\n
)\n\n// Handler 事件处理器\ntype Handler func(ctx context.Context, event *shared
pb.Event) error\n\n// EventBus 内部内存事件总线接口\ntype EventBus interface {\n
\t// Publish 将事件分发给所有已注册的订阅者\n\tPublish(ctx context.Context, even
t *sharedpb.Event)\n\t// Subscribe 注册某个事件类型的处理器\n\tSubscribe(eventTy
pe sharedpb.EventType, handler Handler)\n\t// Unsubscribe 注销某个事件类型的处理
器\n\tUnsubscribe(eventType sharedpb.EventType, handler Handler)\n}\n\ntype inte
rnalEventBus struct {\n\tmu       sync.RWMutex\n\thandlers map[sharedpb.EventTyp
e][]Handler\n\tlogger   log.Logger\n}\n\n// NewInternalEventBus 创建内部内存事件
总线\nfunc NewInternalEventBus(logger log.Logger) EventBus {\n\tif logger == nil
{\n\t\tlogger = log.DefaultLogger\n\t}\n\treturn &internalEventBus{\n\t\thandler
s: make(map[sharedpb.EventType][]Handler),\n\t\tlogger:   logger,\n\t}\n}\n\nfun
c (b *internalEventBus) Publish(ctx context.Context, event *sharedpb.Event) {\n\
tif event == nil {\n\t\treturn\n\t}\n\tb.mu.RLock()\n\thandlers := b.handlers[ev
ent.EventType]\n\tb.mu.RUnlock()\n\n\tif len(handlers) == 0 {\n\t\treturn\n\t}\n
\n\tfor _, h := range handlers {\n\t\tgo func(handler Handler) {\n\t\t\tif err :
= handler(ctx, event); err != nil {\n\t\t\t\tlog.Context(ctx).Warnw("event handl
er failed",\n\t\t\t\t\t"event_type", event.EventType.String(),\n\t\t\t\t\t"event
_id", event.EventId,\n\t\t\t\t\t"error", err,\n\t\t\t\t)\n\t\t\t}\n\t\t}(h)\n\t}
\n}\n\nfunc (b *internalEventBus) Subscribe(eventType sharedpb.EventType, handle
r Handler) {\n\tif handler == nil {\n\t\treturn\n\t}\n\tb.mu.Lock()\n\tdefer b.m
u.Unlock()\n\tb.handlers[eventType] = append(b.handlers[eventType], handler)\n}\
n\nfunc (b *internalEventBus) Unsubscribe(eventType sharedpb.EventType, handler 
Handler) {\n\tif handler == nil {\n\t\treturn\n\t}\n\tb.mu.Lock()\n\tdefer b.mu.
Unlock()\n\n\thandlers := b.handlers[eventType]\n\tfor i, h := range handlers {\
n\t\tif fmt.Sprintf("%p", h) == fmt.Sprintf("%p", handler) {\n\t\t\tb.handlers[e
ventType] = append(handlers[:i], handlers[i+1:]...)\n\t\t\tbreak\n\t\t}\n\t}\n}\
n',
