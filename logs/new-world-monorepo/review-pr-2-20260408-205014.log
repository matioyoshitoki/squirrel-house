d"`\n}\n\ntype FishDetailsEvent struct {\n\tFishId int64 `json:"fish_id"`\n}\n\n
type PubSub interface {\n\tPublish(ctx context.Context, event Event) error\n\tSu
bscribe(ctx context.Context, handler func(event Event) error) error\n\tClose() e
rror\n}\n\ntype redisPubSub struct {\n\tclient *redis.Client\n\tmu     sync.Mute
