    arguments_part='n00000gn/T/dev-issue-7-1410343024/apps/phaser3/src/city-buil
der/ui/SceneSwitchBar.ts", "content": "/**\\n * 场景切换栏\\n * 底部场景切换按钮
\\n */\\n\\nimport { Scene } from \'phaser\';\\nimport { UISegmentedControl, typ
e UISegmentItem } from \'../../ui/UISegmentedControl\';\\n\\n/**\\n * 场景类型\\
n */\\nexport enum SceneType {\\n  City = \'city\',\\n  Battle = \'battle\',\\n}
\\n\\n/**\\n * 场景切换栏配置\\n */\\nexport interface SceneSwitchBarConfig {\\n
 width: number;\\n  x?: number;\\n  y?: number;\\n}\\n\\n/**\\n * 场景切换栏\\n 
*\\n * 布局 (60px高，居中):\\n * - 城建按钮 | 战斗按钮\\n * - 当前场景按钮高亮显
示\\n */\\nexport class SceneSwitchBar extends Phaser.GameObjects.Container {\\n
 private config: Required<SceneSwitchBarConfig>;\\n  private currentScene: Scene
Type = SceneType.City;\\n  private segmentedControl!: UISegmentedControl;\\n\\n 
private readonly sceneItems: UISegmentItem[] = [\\n    { id: SceneType.City, lab
el: \'城建\', icon: \'城\' },\\n    { id: SceneType.Battle, label: \'战斗\', ico
n: \'战\' },\\n  ];\\n\\n  constructor(scene: Scene, config: SceneSwitchBarConfi
g) {\\n    super(scene, config.x ?? 0, config.y ?? 0);\\n\\n    this.config = {\
\n      width: config.width,\\n      x: config.x ?? 0,\\n      y: config.y ?? 0,
\\n    };\\n\\n    this.createBackground();\\n    this.createSegmentedControl();
\\n\\n    scene.add.existing(this);\\n    this.setScrollFactor(0);\\n    this.se
tDepth(1000);\\n  }\\n\\n  private createBackground(): void {\\n    const { widt
h } = this.config;\\n    const height = 60;\\n\\n    const bg = this.scene.add.r
ectangle(\\n      width / 2, height / 2,\\n      width, height,\\n      0x1a1a2e
, 0.95\\n    );\\n    bg.setStrokeStyle(1, 0x4a9eff, 0.3);\\n    this.add(bg);\\
n  }\\n\\n  private createSegmentedControl(): void {\\n    const centerX = this.
config.width / 2;\\n    const buttonY = 30;\\n\\n    this.segmentedControl = new
UISegmentedControl(this.scene, {\\n      x: centerX,\\n      y: buttonY,\\n     
itemWidth: 100,\\n      itemHeight: 45,\\n      items: this.sceneItems,\\n      
selectedId: this.currentScene,\\n      onSelect: (item) => {\\n        this.swit
chScene(item.id as SceneType);\\n      },\\n    });\\n\\n    this.add(this.segme
ntedControl);\\n  }\\n\\n  private switchScene(sceneType: SceneType): void {\\n 
  if (this.currentScene === sceneType) {\\n      return;\\n    }\\n\\n    if (sc
eneType === SceneType.Battle) {\\n      const canSwitch = this.emit(\'before-swi
tch\', sceneType);\\n      if (!canSwitch) {\\n        this.segmentedControl.sel
ectItem(this.currentScene);\\n        return;\\n      }\\n    }\\n\\n    this.cu
rrentScene = sceneType;\\n\\n    this.emit(\'scene-switch\', sceneType);\\n  }\\
n\\n  getCurrentScene(): SceneType {\\n    return this.currentScene;\\n  }\\n\\n
 setCurrentScene(sceneType: SceneType): void {\\n    if (this.currentScene !== s
ceneType) {\\n      this.currentScene = sceneType;\\n      this.segmentedControl
.selectItem(sceneType);\\n    }\\n  }\\n\\n  isInCityScene(): boolean {\\n    re
turn this.currentScene === SceneType.City;\\n  }\\n\\n  isInBattleScene(): boole
an {\\n    return this.currentScene === SceneType.Battle;\\n  }\\n}\\n\\nexport 
default SceneSwitchBar;\\n"}'
)
