n\';\\nimport { UIAvatar } from \'../../ui/UIAvatar\';\\nimport { UIResourceDisp
lay } from \'../../ui/UIResourceDisplay\';\\n\\nexport interface TopInfoBarConfi
g {\\n  width: number;\\n  x?: number;\\n  y?: number;\\n}\\n\\ninterface Resour
ceDisplay {\\n  key: keyof ResourceInfo;\\n  label: string;\\n  icon: string;\\n
 color: string;\\n}\\n\\nexport class TopInfoBar extends Phaser.GameObjects.Cont
ainer {\\n  private config: Required<TopInfoBarConfig>;\\n  private playerInfo: 
PlayerInfo = {\\n    name: \'玩家\',\\n    level: 1,\\n    exp: 0,\\n    maxExp:
100,\\n    avatar: \'\',\\n  };\\n  private resources: ResourceInfo = {\\n    go
ld: 0,\\n    wood: 0,\\n    stone: 0,\\n    workersAvailable: 0,\\n    workersTo
tal: 0,\\n  };\\n\\n  private background!: Phaser.GameObjects.Rectangle;\\n  pri
vate avatarUI!: UIAvatar;\\n  private levelText!: UIText;\\n  private expBar!: U
IProgressBar;\\n  private nameText!: UIText;\\n  private resourceDisplays: Map<s
tring, UIResourceDisplay> = new Map();\\n  private resourceTexts: Map<string, UI
Text> = new Map();\\n  private settingsButton!: UIButton;\\n\\n  private readonl
y resourceConfigs: ResourceDisplay[] = [\\n    { key: \'gold\', label: \'灵石\',
icon: \'灵\', color: \'#ffd700\' },\\n    { key: \'wood\', label: \'木材\', icon
: \'木\', color: \'#daa520\' },\\n    { key: \'stone\', label: \'矿石\', icon: \
'矿\', color: \'#a9a9a9\' },\\n    { key: \'workersAvailable\', label: \'工匠\',
icon: \'工\', color: \'#87ceeb\' },\\n  ];\\n\\n  constructor(scene: Scene, conf
ig: TopInfoBarConfig) {\\n    super(scene, config.x ?? 0, config.y ?? 0);\\n\\n 
  this.config = {\\n      width: config.width,\\n      x: config.x ?? 0,\\n     
y: config.y ?? 0,\\n    };\\n\\n    this.createBackground();\\n    this.createPl
ayerInfo();\\n    this.createResourceInfo();\\n    this.createSettingsButton();\
\n\\n    scene.add.existing(this);\\n    this.setScrollFactor(0);\\n    this.set
Depth(1000);\\n  }\\n\\n  private createBackground(): void {\\n    const { width
} = this.config;\\n    const height = 70;\\n\\n    this.background = this.scene.
add.rectangle(\\n      width / 2, height / 2,\\n      width, height,\\n      0x1
a1a1a, 0.95\\n    );\\n    this.background.setStrokeStyle(1, 0xc9a227, 0.3);\\n 
  this.add(this.background);\\n  }\\n\\n  private createPlayerInfo(): void {\\n 
  const container = this.scene.add.container(15, 10);\\n\\n    // 头像 (50x50)\\
n    this.avatarUI = new UIAvatar(this.scene, {\\n      x: 25,\\n      y: 25,\\n
     size: 50,\\n      fallbackText: \'道\',\\n      bgColor: 0x333333,\\n      
strokeColor: 0x666666,\\n    });\\n    container.add(this.avatarUI);\\n\\n    //
等级图标 (22x22)\\n    const levelBg = this.scene.add.rectangle(55, 8, 22, 22, 0
xc9a227, 0.9);\\n    this.levelText = new UIText(this.scene, {\\n      x: 55,\\n
     y: 8,\\n      text: \'1\',\\n      fontSize: \'12px\',\\n      color: \'#ff
ffff\',\\n      fontStyle: \'bold\',\\n    });\\n    container.add([levelBg, thi
s.levelText]);\\n\\n    // 经验条\\n    this.expBar = new UIProgressBar(this.sce
ne, {\\n      x: 95,\\n      y: 35,\\n      width: 80,\\n      height: 8,\\n    
 value: 0,\\n      maxValue: 100,\\n      bgColor: 0x333333,\\n      fillColor: 
0x4a9eff,\\n      strokeColor: 0x666666,\\n      showText: false,\\n    });\\n  
 container.add(this.expBar);\\n\\n    // 玩家名\\n    this.nameText = new UIText
(this.scene, {\\n      x: 95,\\n      y: 15,\\n      text: this.playerInfo.name,
\\n      fontSize: \'14px\',\\n      color: \'#ffffff\',\\n      align: \'left\'
,\\n    });\\n    this.nameText.setOrigin(0, 0.5);\\n    container.add(this.name
Text);\\n\\n    this.add(container);\\n  }\\n\\n  private createResourceInfo(): 
void {\\n    const container = this.scene.add.container(0, 0);\\n    const start
X = 250;\\n    const spacing = 120;\\n\\n    this.resourceConfigs.forEach((confi
g, index) => {\\n      const x = startX + index * spacing;\\n      const y = 35;
\\n\\n      const display = new UIResourceDisplay(this.scene, {\\n        x,\\n 
      y,\\n        width: 110,\\n        height: 32,\\n        icon: config.icon
,\\n        value: this.formatResourceValue(config.key),\\n        iconColor: co
nfig.color,\\n        valueColor: config.color,\\n        bgColor: 0xffffff,\\n 
