nfig.key, display);\\n      this.resourceTexts.set(config.key, display.valueText
);\\n      container.add(display);\\n    });\\n\\n    this.add(container);\\n  }
\\n\\n  private createSettingsButton(): void {\\n    const x = this.config.width
- 40;\\n    const y = 35;\\n\\n    this.settingsButton = new UIButton(this.scene
, {\\n      x,\\n      y,\\n      width: 40,\\n      height: 40,\\n      text: \
'设\',\\n      fontSize: \'16px\',\\n      bgColor: 0x333333,\\n      hoverColor
: 0x4a4a5e,\\n      strokeColor: 0x666666,\\n      onClick: () => {\\n        th
is.emit(\'settings-click\');\\n      },\\n    });\\n\\n    this.add(this.setting
sButton);\\n  }\\n\\n  private formatResourceValue(key: keyof ResourceInfo): str
ing {\\n    const value = this.resources[key];\\n    if (key === \'workersAvaila
ble\') {\\n      return `${this.resources.workersAvailable}/${this.resources.wor
kersTotal}`;\\n    }\\n    if (typeof value === \'number\' && value >= 10000) {\
\n      return (value / 10000).toFixed(2) + \'万\';\\n    }\\n    return String(
value ?? 0);\\n  }\\n\\n  setPlayerInfo(info: Partial<PlayerInfo>): void {\\n   
this.playerInfo = { ...this.playerInfo, ...info };\\n\\n    this.levelText.setTe
xt(String(this.playerInfo.level));\\n    this.nameText.setText(this.playerInfo.n
ame);\\n    this.expBar.setMaxValue(this.playerInfo.maxExp);\\n    this.expBar.s
etValue(this.playerInfo.exp);\\n  }\\n\\n  setResources(resources: Partial<Resou
rceInfo>): void {\\n    this.resources = { ...this.resources, ...resources };\\n
\\n    this.resourceConfigs.forEach((config) => {\\n      const display = this.r
esourceDisplays.get(config.key);\\n      if (display) {\\n        display.setVal
ue(this.formatResourceValue(config.key));\\n      }\\n    });\\n  }\\n\\n  setAv
atar(textureKey: string): void {\\n    this.avatarUI.setTexture(textureKey);\\n 
}\\n}\\n\\nexport interface PlayerInfo {\\n  name: string;\\n  level: number;\\n
 exp: number;\\n  maxExp: number;\\n  avatar: string;\\n}\\n\\nexport interface 
ResourceInfo {\\n  gold: number;\\n  wood: number;\\n  stone: number;\\n  worker
sAvailable: number;\\n  workersTotal: number;\\n}\\n\\nexport default TopInfoBar
;\\n"}'
