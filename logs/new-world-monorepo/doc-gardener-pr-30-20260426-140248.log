before-switch\') as Array<(type: SceneType) => boolean>;\n      const canSwitch 
= listeners.length === 0 || listeners.every(fn => fn(sceneType));\n      if (!ca
nSwitch) {\n        this.segmentedControl.setSelectedIndex(this.currentScene ===
SceneType.City ? 0 : 1);\n        return;\n      }\n    }\n\n    this.currentSce
ne = sceneType;\n    this.emit(\'scene-switch\', sceneType);\n  }\n  ```\n- **依
据**: Phaser 3 API 文档 `Phaser.Events.EventEmitter#emit` 返回类型为 `boolean`；
