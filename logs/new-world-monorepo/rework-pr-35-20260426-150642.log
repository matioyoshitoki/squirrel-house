    m.SentAt,\n\t\t\tIsRead:         isRead,\n\t\t}\n\t}\n\n\treturn &apipb.GetM
essageHistoryResponse{\n\t\tMessages: respMessages,\n\t\tHasMore:  hasMore,\n\t}
, nil\n}\n\n// MarkAsRead 标记已读\nfunc (uc *IMUseCase) MarkAsRead(ctx context.
