adCount: 0}, nil\n\t}\n\n\t// 0. 校验会话参与者权限\n\tconv, err := uc.imRepo.Ge
tConversationByID(ctx, req.ConversationId)\n\tif err != nil {\n\t\treturn nil, e
rr\n\t}\n\tuidStr := fmt.Sprintf("%d", uid)\n\tif conv.ParticipantA != uidStr &&
conv.ParticipantB != uidStr {\n\t\treturn nil, ErrIMPermissionDenied\n\t}\n\n\t/
/ 1. 先查询消息（无副作用，失败可安全重试）\n\tmessages, err := uc.imRepo.GetMes
sagesByIDs(ctx, req.MessageIds)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n
\t// 过滤消息：仅保留属于当前 conversation_id 的消息\n\tvalidMessageIDs := make(
[]string, 0, len(messages))\n\tfor _, m := range messages {\n\t\tif m.Conversati
onID == req.ConversationId {\n\t\t\tvalidMessageIDs = append(validMessageIDs, m.
MessageID)\n\t\t}\n\t}\n\n\tnow := uc.nowMs()\n\n\t// 2. 写操作纳入事务\n\ttx, e
rr := uc.txHelper.BeginWorldTx(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}
\n\tdefer func() { _ = tx.Rollback() }()\n\n\treceipts := make([]*repo.ReadRecei
pt, 0, len(validMessageIDs))\n\tfor _, msgID := range validMessageIDs {\n\t\trec
eipts = append(receipts, &repo.ReadReceipt{\n\t\t\tMessageID: msgID,\n\t\t\tRead
erID:  uidStr,\n\t\t\tReadAt:    now,\n\t\t\tCreatedAt: now,\n\t\t})\n\t}\n\tif 
err := uc.imRepo.BatchCreateReadReceiptsTx(ctx, tx, receipts); err != nil {\n\t\
treturn nil, err\n\t}\n\tif err := uc.imRepo.ClearUnreadCountTx(ctx, tx, req.Con
versationId, uidStr); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := tx.Com
mit(); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// 3. 推送已读回执给会话中的
对方（允许失败，仅记日志）\n\tsenderMap := make(map[string][]string)\n\tfor _, m
:= range messages {\n\t\tif m.ConversationID == req.ConversationId && m.SenderID
!= uidStr {\n\t\t\tsenderMap[m.SenderID] = append(senderMap[m.SenderID], m.Messa
geID)\n\t\t}\n\t}\n\n\tfor senderID, msgIDs := range senderMap {\n\t\tvar sUID i
nt64\n\t\tif _, err := fmt.Sscanf(senderID, "%d", &sUID); err == nil && sUID > 0
{\n\t\t\tif err := uc.pusher.PushReadReceipt(ctx, sUID, req.ConversationId, msgI
Ds); err != nil {\n\t\t\t\tuc.log.Warnw("push read receipt failed", "error", err
)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn &apipb.MarkAsReadResponse{ReadCount: int32(le
n(validMessageIDs))}, nil\n}\npackage wapi\n\nimport (\n\t"context"\n\t"errors"\
