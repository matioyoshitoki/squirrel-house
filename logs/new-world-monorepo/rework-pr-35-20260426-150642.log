t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar senderID int64\n\t\tfmt.Sscanf(m.
SenderID, "%d", &senderID)\n\t\tsenderName := senderNameMap[senderID]\n\t\tif se
nderName == "" {\n\t\t\tsenderName = m.SenderID\n\t\t}\n\n\t\trespMessages[i] = 
&apipb.IMMessageContent{\n\t\t\tMessageId:      m.MessageID,\n\t\t\tConversation
Id: m.ConversationID,\n\t\t\tSenderId:       m.SenderID,\n\t\t\tSenderName:     
senderName,\n\t\t\tReceiverId:     m.ReceiverID,\n\t\t\tContent:        m.Conten
