n   804\t    tx, _ := r.db.BeginTx(ctx)  // 错误！\n   805\t    // ... 只能在当
前 Repo 内\n   806\t}\n   807\t```\n   808\t\n   809\t### 12.3 Repo 层事务接口\n
  810\t\n   811\t```go\n   812\t// Repo 层：定义 Tx 方法\n   813\tfunc (r *asset
Repo) DeductTx(ctx context.Context, tx repo.Tx, uid, amount int64) error {\n   8
14\t    // 将 repo.Tx 转换为 ent.Tx\n   815\t    entTx, ok := tx.(*ent.Tx)\n   8
16\t    if !ok {\n   817\t        return errors.New("invalid transaction type")\
