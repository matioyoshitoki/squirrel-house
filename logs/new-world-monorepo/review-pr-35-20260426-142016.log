\n   786\t        // 2. 转移商品所有权\n   787\t        if err := uc.productRepo
.TransferTx(ctx, tx, productId, buyerId); err != nil {\n   788\t            retu
rn err\n   789\t        }\n   790\t        \n   791\t        // 3. 创建交易记录\
n   792\t        if err := uc.orderRepo.CreateTx(ctx, tx, buyerId, productId, pr
ice); err != nil {\n   793\t            return err\n   794\t        }\n   795\t 
      \n   796\t        return nil\n   797\t    })\n   798\t}\n   799\t```\n   8
