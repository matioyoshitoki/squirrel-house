721\t// internal/data/wapi/user_integration_test.go\n   722\tpackage wapi\n   72
3\t\n   724\timport (\n   725\t    "context"\n   726\t    "testing"\n   727\t   
\n   728\t    "github.com/stretchr/testify/assert"\n   729\t    "github.com/stre
tchr/testify/require"\n   730\t    "new-world/internal/biz/repo"\n   731\t    "n
ew-world/internal/data/world/ent"\n   732\t)\n   733\t\n   734\tfunc TestUserRep
