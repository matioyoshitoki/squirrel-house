rr := r.db.Query().Where(...).First(ctx)\\n    if err == nil {\\n        return 
m, nil\\n    }\\n    if !ent.IsNotFound(err) {\\n        return nil, err\\n    }
\\n\\n    created, err := r.db.Create().SetKey(key).Save(ctx)\\n    if err != ni
l {\\n        if ent.IsConstraintError(err) {\\n            // 唯一冲突说明记录
已存在，重新查询\\n            return r.db.Query().Where(...).First(ctx)\\n     
  }\\n        return nil, err\\n    }\\n    return created, nil\\n}\\n```\\n\\n>
**注意**：如果唯一索引涉及外部输入（如 participant_a + participant_b），需确保输
入顺序一致性（如排序后存储），避免 (A,B) 和 (B,A) 被视为不同记录。\\n\\n### 反模
式 2：写后读未分离（Read-After-Write in Tx）\\n\\n**问题**：将无副作用的读取操作
放入事务，导致事务持有锁的时间不必要延长。\\n\\n```go\\n// 不推荐：读取操作不必
