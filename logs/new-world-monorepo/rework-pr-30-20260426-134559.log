'\n}\n\nexport class UIList<T> extends Phaser.GameObjects.Container {\n  setItem
s(items: T[], renderFn: (item: T, index: number) => UIListItem): void;\n  setSel
ectedIndex(index: number): void;\n  getSelectedIndex(): number;\n  on(event: \'s
elect\', callback: (item: T, index: number) => void): this;\n}\n\nexport interfa
ce UIListItemConfig {\n  width: number;\n  height: number;\n  icon?: string;    
      // 左侧图标纹理\n  iconSize?: number;       // 默认 48\n  title?: string;\
