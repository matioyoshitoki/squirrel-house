\n\n// Handler 事件处理器\ntype Handler func(ctx context.Context, event *sharedp
b.Event) error\n\n// EventBus 内部内存事件总线接口\ntype EventBus interface {\n\
t// Publish 将事件分发给所有已注册的订阅者\n\tPublish(ctx context.Context, event
*sharedpb.Event)\n\t// Subscribe 注册某个事件类型的处理器，返回取消订阅函数\n\tS
ubscribe(eventType sharedpb.EventType, handler Handler) (cancel func())\n\t// Un
subscribe 注销某个事件类型的处理器\n\tUnsubscribe(eventType sharedpb.EventType, 
handler Handler)\n}\n\ntype subscription struct {\n\tid      string\n\thandler H
andler\n}\n\ntype internalEventBus struct {\n\tmu       sync.RWMutex\n\thandlers
map[sharedpb.EventType][]subscription\n\tlogger   log.Logger\n\tpool     gopool.
Pool\n}\n\n// NewInternalEventBus 创建内部内存事件总线\nfunc NewInternalEventBus
(logger log.Logger) EventBus {\n\tif logger == nil {\n\t\tlogger = log.DefaultLo
gger\n\t}\n\treturn &internalEventBus{\n\t\thandlers: make(map[sharedpb.EventTyp
e][]subscription),\n\t\tlogger:   logger,\n\t\tpool:     gopool.NewPool("eventbu
s-pool", 1024, gopool.NewConfig()),\n\t}\n}\n\nfunc (b *internalEventBus) Publis
h(ctx context.Context, event *sharedpb.Event) {\n\tif event == nil {\n\t\treturn
\n\t}\n\tb.mu.RLock()\n\tsubs := b.handlers[event.EventType]\n\tb.mu.RUnlock()\n
\n\tif len(subs) == 0 {\n\t\treturn\n\t}\n\n\tfor _, s := range subs {\n\t\th :=
s.handler\n\t\tb.pool.Go(func() {\n\t\t\tif err := h(ctx, event); err != nil {\n
\t\t\t\tlog.Context(ctx).Warnw("event handler failed",\n\t\t\t\t\t"event_type", 
event.EventType.String(),\n\t\t\t\t\t"event_id", event.EventId,\n\t\t\t\t\t"erro
r", err,\n\t\t\t\t)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc (b *internalEventBus) Subsc
ribe(eventType sharedpb.EventType, handler Handler) func() {\n\tif handler == ni
l {\n\t\treturn func() {}\n\t}\n\tid := idgen.SafeNewUUID()\n\tb.mu.Lock()\n\tde
fer b.mu.Unlock()\n\tb.handlers[eventType] = append(b.handlers[eventType], subsc
ription{id: id, handler: handler})\n\n\treturn func() {\n\t\tb.unsubscribeByID(e
ventType, id)\n\t}\n}\n\nfunc (b *internalEventBus) unsubscribeByID(eventType sh
aredpb.EventType, id string) {\n\tb.mu.Lock()\n\tdefer b.mu.Unlock()\n\tsubs := 
b.handlers[eventType]\n\tfor i, s := range subs {\n\t\tif s.id == id {\n\t\t\tb.
handlers[eventType] = append(subs[:i], subs[i+1:]...)\n\t\t\treturn\n\t\t}\n\t}\
n}\n\nfunc (b *internalEventBus) Unsubscribe(eventType sharedpb.EventType, handl
er Handler) {\n\tif handler == nil {\n\t\treturn\n\t}\n\t// Deprecated: Unsubscr
ibe by handler pointer is unreliable for closures and\n\t// multiple subscriptio
ns of the same handler. Use the cancel func returned by\n\t// Subscribe instead,
which is based on a stable UUID.\n\tlog.Context(context.Background()).Warn("Unsu
bscribe by handler pointer is unreliable; use the cancel func returned by Subscr
ibe")\n\ttargetPtr := reflect.ValueOf(handler).Pointer()\n\tb.mu.Lock()\n\tdefer
b.mu.Unlock()\n\tsubs := b.handlers[eventType]\n\tfiltered := make([]subscriptio
n, 0, len(subs))\n\tfor _, s := range subs {\n\t\tif reflect.ValueOf(s.handler).
Pointer() != targetPtr {\n\t\t\tfiltered = append(filtered, s)\n\t\t}\n\t}\n\tif
len(filtered) == 0 {\n\t\tdelete(b.handlers, eventType)\n\t} else {\n\t\tb.handl
ers[eventType] = filtered\n\t}\n}\n',
