\t\tlog.Context(ctx).Warnw("unmarshal event failed", "error", err)\n\t\tc.ack(ct
x, streamKey, msg.ID)\n\t\treturn\n\t}\n\n\t// 幂等检查\n\tprocessed, err := c.c
hecker.IsProcessed(ctx, event.EventId)\n\tif err != nil {\n\t\tlog.Context(ctx).
Warnw("idempotency check failed", "event_id", event.EventId, "error", err)\n\t\t
// 检查失败时不 ACK，让消息保留在 PEL 中稍后重试\n\t\treturn\n\t}\n\tif processe
d {\n\t\t// 已处理，直接 ACK\n\t\tc.ack(ctx, streamKey, msg.ID)\n\t\treturn\n\t}
\n\n\t// 业务处理\n\tif err := c.processor.Process(ctx, event); err != nil {\n\t
\tlog.Context(ctx).Warnw("process event failed", "event_id", event.EventId, "err
or", err)\n\t\tc.retryOrDLQ(ctx, streamKey, msg, event)\n\t\treturn\n\t}\n\n\t//
