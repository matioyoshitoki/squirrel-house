t\t}\n\n\t\tfor _, stream := range streams {\n\t\t\tc.handleMessages(ctx, stream
Key, stream.Messages)\n\t\t}\n\t}\n}\n\nfunc (c *redisStreamConsumer) processPen
ding(ctx context.Context, streamKey, consumerID string) {\n\tfor {\n\t\tselect {
\n\t\tcase <-c.stopCh:\n\t\t\treturn\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\t
default:\n\t\t}\n\n\t\tstreams, err := c.client.XReadGroup(ctx, &redis.XReadGrou
pArgs{\n\t\t\tGroup:    c.config.ConsumerGroup,\n\t\t\tConsumer: consumerID,\n\t
\t\tStreams:  []string{streamKey, "0"},\n\t\t\tCount:    int64(c.config.BatchSiz
e),\n\t\t}).Result()\n\n\t\tif err != nil {\n\t\t\tlog.Context(ctx).Warnw("read 
pending messages error", "stream", streamKey, "error", err)\n\t\t\treturn\n\t\t}
\n\t\tif len(streams) == 0 || len(streams[0].Messages) == 0 {\n\t\t\treturn\n\t\
t}\n\n\t\tc.handleMessages(ctx, streamKey, streams[0].Messages)\n\t}\n}\n\nfunc 
(c *redisStreamConsumer) handleMessages(ctx context.Context, streamKey string, m
essages []redis.XMessage) {\n\tfor _, msg := range messages {\n\t\tc.handleMessa
ge(ctx, streamKey, msg)\n\t}\n}\n\nfunc (c *redisStreamConsumer) handleMessage(c
tx context.Context, streamKey string, msg redis.XMessage) {\n\tdataVal, ok := ms
g.Values["data"]\n\tif !ok {\n\t\t// 无法解析的消息，直接 ACK 避免阻塞\n\t\tc.ac
k(ctx, streamKey, msg.ID)\n\t\treturn\n\t}\n\n\tdataBytes, ok := dataVal.([]byte
)\n\tif !ok {\n\t\tc.ack(ctx, streamKey, msg.ID)\n\t\treturn\n\t}\n\n\tevent := 
