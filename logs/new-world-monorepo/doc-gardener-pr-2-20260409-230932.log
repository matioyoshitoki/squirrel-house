eamKey, consumerID)\n\n\t// 阶段 2: 正常消费新消息\n\tfor {\n\t\tselect {\n\t\tc
ase <-c.stopCh:\n\t\t\treturn\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tdefault
:\n\t\t}\n\n\t\tstreams, err := c.client.XReadGroup(ctx, &redis.XReadGroupArgs{\
n\t\t\tGroup:    c.config.ConsumerGroup,\n\t\t\tConsumer: consumerID,\n\t\t\tStr
eams:  []string{streamKey, ">"},\n\t\t\tCount:    int64(c.config.BatchSize),\n\t
\t\tBlock:    c.config.BlockDuration,\n\t\t}).Result()\n\n\t\tif err == redis.Ni
