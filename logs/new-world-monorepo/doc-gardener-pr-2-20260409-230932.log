c (c *redisStreamConsumer) ack(ctx context.Context, streamKey, msgID string) {\n
\tif err := c.client.XAck(ctx, streamKey, c.config.ConsumerGroup, msgID).Err(); 
err != nil {\n\t\tlog.Context(ctx).Warnw("xack failed", "stream", streamKey, "ms
g_id", msgID, "error", err)\n\t}\n}\n\nfunc (c *redisStreamConsumer) retryOrDLQ(
ctx context.Context, streamKey string, msg redis.XMessage, event *sharedpb.Event
) {\n\t// ACK 当前消息\n\tc.ack(ctx, streamKey, msg.ID)\n\n\tretryCount := 0\n\t
if rc, ok := msg.Values["retry_count"]; ok {\n\t\tif rcStr, ok := rc.(string); o
k {\n\t\t\tretryCount, _ = strconv.Atoi(rcStr)\n\t\t}\n\t}\n\n\tif retryCount >=
c.config.MaxRetry {\n\t\t// 进入 DLQ\n\t\tdata, err := proto.Marshal(event)\n\t\
tif err != nil {\n\t\t\tlog.Context(ctx).Errorw("marshal event for dlq failed", 
"event_id", event.EventId, "error", err)\n\t\t\treturn\n\t\t}\n\t\tif err := c.c
lient.XAdd(ctx, &redis.XAddArgs{\n\t\t\tStream: c.config.DLQKey,\n\t\t\tValues: 
map[string]interface{}{\n\t\t\t\t"data":          data,\n\t\t\t\t"origin_stream"
: streamKey,\n\t\t\t\t"retry_count":   retryCount,\n\t\t\t},\n\t\t}).Err(); err 
!= nil {\n\t\t\tlog.Context(ctx).Errorw("dlq add failed", "event_id", event.Even
tId, "error", err)\n\t\t}\n\t\tlog.Context(ctx).Errorw("event moved to dlq", "ev
ent_id", event.EventId, "stream", streamKey)\n\t\treturn\n\t}\n\n\t// 重新入队，
增加 retry_count\n\tdata, err := proto.Marshal(event)\n\tif err != nil {\n\t\tlo
g.Context(ctx).Errorw("marshal event for requeue failed", "event_id", event.Even
tId, "error", err)\n\t\treturn\n\t}\n\tif err := c.client.XAdd(ctx, &redis.XAddA
rgs{\n\t\tStream: streamKey,\n\t\tValues: map[string]interface{}{\n\t\t\t"data":
       data,\n\t\t\t"retry_count": retryCount + 1,\n\t\t},\n\t}).Err(); err != n
il {\n\t\tlog.Context(ctx).Errorw("requeue failed", "event_id", event.EventId, "
error", err)\n\t}\n}\n',
