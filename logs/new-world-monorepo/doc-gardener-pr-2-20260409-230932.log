d(streamKeys, streamKey)\n\t}\n\n\t// 阶段2: 统一启动所有分区 goroutine\n\tfor _
, streamKey := range streamKeys {\n\t\tc.wg.Add(1)\n\t\tgo c.consumePartition(ct
x, streamKey)\n\t}\n\n\tc.wg.Wait()\n\treturn nil\n}\n\nfunc (c *redisStreamCons
umer) Stop(ctx context.Context) error {\n\tc.stopOnce.Do(func() { close(c.stopCh
) })\n\tc.wg.Wait()\n\tlog.Context(ctx).Info("event consumer stopped")\n\treturn
nil\n}\n\nfunc (c *redisStreamConsumer) Ping(ctx context.Context) error {\n\tret
urn c.client.Ping(ctx).Err()\n}\n\nfunc (c *redisStreamConsumer) ensureConsumerG
roup(ctx context.Context, streamKey string) error {\n\terr := c.client.XGroupCre
ateMkStream(ctx, streamKey, c.config.ConsumerGroup, "$").Err()\n\tif err != nil 
&& !strings.Contains(err.Error(), "BUSYGROUP") {\n\t\treturn err\n\t}\n\treturn 
