键名（优先）或 emoji（回退）\n+  iconPosition?: \'left\' | \'top\';\n+  color?: 
number;          // 纯色回退色（默认 0x4a9eff）\n+  disabledColor?: number;  // 
默认 0x666666\n+  depth?: number;\n+}\n+\n+export class UIButton extends Phaser.
GameObjects.Container {\n+  setDisabled(disabled: boolean): void;\n+  setText(te
xt: string): void;\n+  on(event: \'pointerdown\' | \'pointerover\' | \'pointerou
