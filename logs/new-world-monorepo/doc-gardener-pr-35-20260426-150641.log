\n      if err != nil {\n          return nil, err\n      }\n      defer func() 
{ _ = tx.Rollback() }()\n\n      receipts := make([]*repo.ReadReceipt, 0, len(re
q.MessageIds))\n      for _, msgID := range req.MessageIds {\n          receipts
= append(receipts, &repo.ReadReceipt{...})\n      }\n      // 需要为 BatchCreate
ReadReceipts 和 ClearUnreadCount 增加 Tx 版本\n      if err := uc.imRepo.BatchCr
eateReadReceiptsTx(ctx, tx, receipts); err != nil {\n          return nil, err\n
