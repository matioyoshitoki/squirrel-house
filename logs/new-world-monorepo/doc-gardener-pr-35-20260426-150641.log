      return nil, err  // 返回错误，让客户端重试
  }
  if err := uc.imRepo.ClearUnreadCount(ctx, req.ConversationId, uidStr); err != 
nil {
      return nil, err
  }
  ```
- **依据**: `docs/design-docs/error-handling.md` 第 3.1 节 "不要创建临时错误"、
第 10.4 节 "不丢失原始错误"；`layers.md` 第 10.1 节 Biz 层应返回业务错误。

